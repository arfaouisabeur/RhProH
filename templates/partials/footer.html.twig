<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  .rh-footer {
    font-family: 'DM Sans', sans-serif;
    background: linear-gradient(160deg, #1a0a2e 0%, #3d1a5c 50%, #2a0d45 100%);
    position: relative;
    overflow: hidden;
    padding-top: 64px;
    padding-bottom: 0;
  }

  /* Background decoration */
  .rh-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 70% 50% at 10% 100%, rgba(201,168,76,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 90% 0%, rgba(124,61,172,0.3) 0%, transparent 50%),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.012) 40px,
        rgba(255,255,255,0.012) 41px
      );
    pointer-events: none;
  }

  /* Skyline SVG strip */
  .footer-skyline {
    position: absolute;
    bottom: 52px; /* above the copyright bar */
    left: 0;
    width: 100%;
    height: 90px;
    opacity: 0.06;
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
  }

  /* Gold top accent bar */
  .footer-gold-bar {
    height: 2px;
    background: linear-gradient(90deg, transparent, #b39ddb 30%, #d1c4e9 50%, #b39ddb 70%, transparent);
    margin-bottom: 52px;
    opacity: 0.6;
  }


  /* Brand column */
  .footer-brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .footer-brand-name .brand-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #662696;
    box-shadow: 0 0 8px rgba(141, 76, 201, 0.6);
    flex-shrink: 0;
  }

  .footer-tagline {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    max-width: 240px;
    margin-bottom: 24px;
  }

  /* Social icons */
  .footer-socials {
    display: flex;
    gap: 10px;
  }

  .social-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .social-btn:hover {
    background: rgba(201,168,76,0.15);
    border-color: rgba(201,168,76,0.4);
    color: #e8c97a;
  }

  /* Column headings */
  .footer-col-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a484e0;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-col-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(201,168,76,0.2);
    max-width: 40px;
  }

  /* Links */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: color 0.2s, gap 0.2s;
  }

  .footer-links a::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #824cc9;
    opacity: 0.4;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .footer-links a:hover {
    color: rgba(255,255,255,0.85);
    gap: 10px;
  }

  .footer-links a:hover::before {
    opacity: 1;
  }

  /* Contact items */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .contact-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #914cc9;
  }

  .contact-text {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    padding-top: 5px;
  }

  /* Newsletter badge */
  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.25);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9643df;
    margin-bottom: 14px;
  }

  .footer-badge::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #994cc9;
    box-shadow: 0 0 6px rgba(207, 169, 233, 0.7);
  }

  /* Gold divider */
  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08) 30%, rgba(255,255,255,0.08) 70%, transparent);
    margin: 48px 0 0;
    position: relative;
    z-index: 1;
  }

  /* Copyright bar */
  .footer-bottom {
    position: relative;
    z-index: 1;
    padding: 18px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
  }

  .footer-copyright {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
  }

  .footer-copyright strong {
    color: rgba(255,255,255,0.5);
    font-weight: 600;
  }

  .footer-legal {
    display: flex;
    gap: 20px;
  }

  .footer-legal a {
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.04em;
  }

  .footer-legal a:hover {
    color: rgba(255,255,255,0.55);
  }

  @media (max-width: 768px) {
    .rh-footer { padding-top: 44px; }
    .footer-bottom { justify-content: center; text-align: center; }
    .footer-legal { justify-content: center; }
    .footer-col { margin-bottom: 36px; }
  }
</style>

