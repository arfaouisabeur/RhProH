{# Partial form — used by new.html.twig and edit.html.twig if needed #}
<style>
.field-group label{display:block;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--muted,#7b6b96);margin-bottom:8px;transition:color .2s;}
.field-group{margin-bottom:18px;}
.field-group:focus-within label{color:var(--v-mid,#8b47e8);}
.field-group input[type="text"],.field-group input[type="date"],.field-group select,.field-group textarea{
  width:100%;padding:13px 16px;background:rgba(255,255,255,.9);border:1.5px solid rgba(139,103,200,.2);
  border-radius:10px;font-family:inherit;font-size:14.5px;color:#0d0a1a;
  transition:border-color .22s,box-shadow .22s;outline:none;-webkit-appearance:none;appearance:none;box-sizing:border-box;
}
.field-group input:focus,.field-group select:focus,.field-group textarea:focus{
  border-color:#8b47e8;background:#fff;box-shadow:0 0 0 4px rgba(139,71,232,.1);
}
.field-group textarea{resize:vertical;min-height:100px;}
</style>

<div class="field-group">
  {{ form_label(form.typeConge) }}
  {{ form_widget(form.typeConge) }}
  {{ form_errors(form.typeConge) }}
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
  <div class="field-group">
    {{ form_label(form.dateDebut) }}
    {{ form_widget(form.dateDebut) }}
    {{ form_errors(form.dateDebut) }}
  </div>
  <div class="field-group">
    {{ form_label(form.dateFin) }}
    {{ form_widget(form.dateFin) }}
    {{ form_errors(form.dateFin) }}
  </div>
</div>

<div class="field-group">
  {{ form_label(form.description) }}
  {{ form_widget(form.description, {'attr':{'placeholder':'Motif de votre absence…','rows':4}}) }}
  {{ form_errors(form.description) }}
</div>

{% if form.documentPath is defined %}
<div class="field-group">
  {{ form_label(form.documentPath) }}
  {{ form_widget(form.documentPath) }}
  {{ form_errors(form.documentPath) }}
  <small style="color:var(--muted,#7b6b96);font-size:12px;">PDF, JPEG, PNG — max 5 Mo</small>
</div>
{% endif %}

{{ form_rest(form) }}

<div style="display:flex;gap:12px;margin-top:24px;flex-wrap:wrap;">
  <button type="submit"
    style="display:inline-flex;align-items:center;gap:9px;padding:13px 28px;border-radius:50px;border:none;
           background:linear-gradient(135deg,#8b47e8,#6633cc);color:#fff;
           font-family:inherit;font-size:14.5px;font-weight:700;cursor:pointer;
           box-shadow:0 6px 22px rgba(102,51,204,.38);transition:all .2s;">
    <i class="fas fa-paper-plane"></i> {{ button_label|default('Envoyer') }}
  </button>
  <a href="{{ path('app_conge_tt_index') }}"
    style="display:inline-flex;align-items:center;gap:8px;padding:12px 22px;border-radius:50px;
           color:#7b6b96;border:1.5px solid rgba(139,103,200,.2);text-decoration:none;
           font-size:14px;font-weight:500;background:transparent;transition:all .18s;">
    <i class="fas fa-arrow-left"></i> Retour
  </a>
</div>
