{# _delete_form.html.twig — utilisé dans show.html.twig #}

<form method="post" action="{{ path('app_conge_tt_delete', {'id': conge_tt.id}) }}"
      onsubmit="return confirm('Supprimer cette demande de congé ? Cette action est irréversible.');">
    <input type="hidden" name="_method" value="DELETE">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ conge_tt.id) }}">
    <button type="submit" style="
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.6rem 1.3rem; border-radius: 10px;
        background: rgba(212,115,106,0.12); color: #9a3a33;
        border: 1.5px solid rgba(212,115,106,0.28);
        font-family: 'DM Sans', sans-serif; font-size: 0.85rem; font-weight: 600;
        cursor: pointer; transition: all 0.2s;
    "
    onmouseover="this.style.background='rgba(212,115,106,0.22)'"
    onmouseout="this.style.background='rgba(212,115,106,0.12)'"
    >
        🗑 Supprimer
    </button>
</form>
