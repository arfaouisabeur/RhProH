{% extends 'base.html.twig' %}

{% block title %}Détail de la demande de Congé{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    .app-container {
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at top left, #ecfdf5 0%, #ffffff 50%, #f0fdf4 100%);
        min-height: 90vh; padding: 40px 20px; color: #0f172a;
    }
    .app-container * { box-sizing: border-box; }
    
    .view-wrapper { max-width: 800px; margin: 0 auto; animation: fadeUp 0.6s ease-out; }

    .header-box { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .btn-back { display: flex; align-items: center; gap: 8px; color: #64748b; text-decoration: none; font-weight: 600; padding: 10px 18px; border-radius: 50px; background: white; border: 1px solid #e2e8f0; transition: 0.2s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .btn-back:hover { background: #f8fafc; color: #0f172a; border-color: #cbd5e1; }

    .ticket-card {
        background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 1); border-radius: 24px;
        box-shadow: 0 15px 50px rgba(4, 120, 87, 0.1); overflow: hidden;
    }

    .ticket-header {
        padding: 40px; position: relative; overflow: hidden;
        display: flex; justify-content: space-between; align-items: center;
    }
    .ticket-header.st-pending { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .ticket-header.st-accepted { background: linear-gradient(135deg, #10b981, #059669); }
    .ticket-header.st-rejected { background: linear-gradient(135deg, #f43f5e, #be123c); }
    
    .ticket-header::after {
        content: '\f072'; font-family: 'Font Awesome 6 Free'; font-weight: 900;
        position: absolute; right: -20px; bottom: -30px; font-size: 150px; color: white; opacity: 0.1;
        transform: rotate(-15deg);
    }

    .ticket-title h2 { font-family: 'Outfit', sans-serif; font-size: 2.2rem; margin: 0; color: white; line-height: 1.1; }
    .ticket-title p { color: rgba(255,255,255,0.8); margin: 5px 0 0 0; font-size: 1.1rem; }

    .status-pill {
        background: rgba(255,255,255,0.25); border: 1px solid rgba(255,255,255,0.4);
        backdrop-filter: blur(10px); padding: 8px 20px; border-radius: 50px;
        color: white; font-weight: 700; font-size: 1rem; text-transform: uppercase; letter-spacing: 1px;
    }

    .ticket-body { padding: 40px; }

    .grid-details { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px; }
    .detail-item { background: #f8fafc; padding: 20px; border-radius: 16px; border: 1px dashed #cbd5e1; }
    .detail-item.full { grid-column: 1 / -1; }
    
    .dl-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; color: #64748b; letter-spacing: 1px; margin-bottom: 5px; }
    .dl-val { font-family: 'Outfit', sans-serif; font-size: 1.4rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; }
    .dl-val i { color: #10b981; font-size: 1.1rem; }
    .dl-val.large { font-size: 2rem; color: #064e3b; }

    .divider { height: 1px; background: #e2e8f0; margin: 0 40px 30px 40px; border-style: dashed; }

    .ticket-footer { padding: 0 40px 40px 40px; display: flex; justify-content: space-between; align-items: center; }
    
    .btn-edit {
        display: inline-flex; align-items: center; gap: 8px;
        background: #f1f5f9; color: #0f172a; text-decoration: none;
        padding: 12px 24px; border-radius: 50px; font-weight: 600;
        transition: all 0.3s; border: 1px solid #e2e8f0;
    }
    .btn-edit:hover { background: #e2e8f0; transform: translateY(-2px); }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 600px) {
        .grid-details { grid-template-columns: 1fr; gap: 20px; }
        .ticket-header { flex-direction: column; align-items: flex-start; gap: 20px; padding: 30px; }
        .ticket-body { padding: 30px; }
        .ticket-footer { flex-direction: column; gap: 15px; padding: 0 30px 30px 30px; }
        .ticket-footer > * { width: 100%; text-align: center; justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
{% set st = conge_tt.statut %}
{% set isOk = (st == 'Accepté' or st == 'approuvé') %}
{% set isNo = (st == 'Refusé' or st == 'refusé') %}
{% set cl = isOk ? 'st-accepted' : (isNo ? 'st-rejected' : 'st-pending') %}
{% set d1 = conge_tt.dateDebut ? conge_tt.dateDebut|date('U') : null %}
{% set d2 = conge_tt.dateFin ? conge_tt.dateFin|date('U') : null %}
{% set nbJours = (d1 and d2 and d2 >= d1) ? (((d2 - d1) / 86400)|round(0, 'floor') + 1) : null %}

<div class="app-container">
    <div class="view-wrapper">
        <div class="header-box">
            <a href="{{ path('app_conge_tt_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Tableau de bord</a>
        </div>

        <div class="ticket-card">
            <div class="ticket-header {{ cl }}">
                <div class="ticket-title">
                    <h2>{{ conge_tt.typeConge }}</h2>
                    <p>Demande n°{{ conge_tt.id }}</p>
                </div>
                <div class="status-pill">
                    {% if isOk %}Accepté{% elseif isNo %}Refusé{% else %}En attente{% endif %}
                </div>
            </div>

            <div class="ticket-body">
                <div class="grid-details">
                    <div class="detail-item">
                        <div class="dl-label">Date de départ</div>
                        <div class="dl-val"><i class="fas fa-plane-departure"></i> {{ conge_tt.dateDebut ? conge_tt.dateDebut|date('d/m/Y') : '' }}</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl-label">Date de retour</div>
                        <div class="dl-val"><i class="fas fa-plane-arrival"></i> {{ conge_tt.dateFin ? conge_tt.dateFin|date('d/m/Y') : '' }}</div>
                    </div>
                    <div class="detail-item full" style="display: flex; justify-content: space-between; align-items: center; border: 2px solid #cbd5e1; background: white;">
                        <div>
                            <div class="dl-label">Durée totale</div>
                            <div class="dl-val large">
                                {{ nbJours is not null ? nbJours : '—' }}
                                <span style="font-size:1rem; color:#64748b; font-weight:500;">jour{{ (nbJours ?? 0) > 1 ? 's' : '' }}</span>
                            </div>
                        </div>
                        <i class="fas fa-sun" style="font-size: 3rem; color: #f59e0b; opacity: 0.8;"></i>
                    </div>
                    
                    {% if conge_tt.description %}
                    <div class="detail-item full">
                        <div class="dl-label">Motif / Commentaire</div>
                        <div style="color: #475569; font-style: italic; line-height: 1.6; margin-top: 5px;">
                            "{{ conge_tt.description }}"
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="divider"></div>

            <div class="ticket-footer">
                <div>
                    {{ include('conge_tt/_delete_form.html.twig') }}
                </div>
                
                {% if st != 'Accepté' and st != 'Refusé' %}
                <a href="{{ path('app_conge_tt_edit', {'id': conge_tt.id}) }}" class="btn-edit">
                    <i class="fas fa-pen"></i> Modifier la demande
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
