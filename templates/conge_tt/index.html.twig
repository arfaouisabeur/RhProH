  overflow: hidden;
}

.btn-delete-confirm::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.btn-delete-confirm:hover::before {
  left: 100%;
}

.btn-delete-confirm:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 36px rgba(244, 63, 94, 0.45);
}

.btn-delete-confirm:active {
  transform: translateY(-1px);
}

.btn-delete-cancel i,
.btn-delete-confirm i {
  font-size: 1.1rem;
}

/* Responsive */
@media (max-width: 576px) {
  .delete-modal-modern {
    max-width: 95%;
    margin: 10px auto;
  }
  
  .delete-modal-header {
    padding: 32px 24px 24px;
  }
  
  .delete-modal-body {
    padding: 24px;
  }
  
  .delete-actions {
    flex-direction: column;
  }
  
  .btn-delete-cancel,
  .btn-delete-confirm {
    width: 100%;
  }
}

/* Animation d'entrée du backdrop */
.modal.fade .modal-dialog {
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.modal.show .modal-dialog {
  transform: none;
}
</style>

<script>
// ═══════════════════════════════════════════════════════════
// Script pour la modal de suppression ultra moderne
// ═══════════════════════════════════════════════════════════
(function(){
  const modal = document.getElementById('deleteCongeModal');
  const form = document.getElementById('deleteCongeForm');
  const typeEl = document.getElementById('deleteCongeType');
  const idEl = document.getElementById('deleteCongeId');
  const tokenEl = document.getElementById('deleteCsrfToken');
  
  if(modal && form){
    modal.addEventListener('show.bs.modal', function(evt){
      const btn = evt.relatedTarget;
      if(!btn) return;
      
      const congeId = btn.getAttribute('data-conge-id');
      const congeType = btn.getAttribute('data-conge-type');
      const deleteUrl = btn.getAttribute('data-delete-url');
      const csrfToken = btn.getAttribute('data-csrf-token');
      
      form.action = deleteUrl;
      tokenEl.value = csrfToken;
      typeEl.textContent = congeType || 'Congé';
      idEl.textContent = congeId || '000';
    });
    
    // Animation de fermeture
    modal.addEventListener('hide.bs.modal', function(){
      const content = modal.querySelector('.delete-modal-modern');
      if(content){
        content.style.animation = 'modalSlideOut 0.3s ease-in forwards';
      }
    });
  }
})();

// Animation de sortie
const style = document.createElement('style');
style.textContent = `
  @keyframes modalSlideOut {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(-40px) scale(0.95);
    }
  }
`;
document.head.appendChild(style);

// ── Popup alertes abus ────────────────────────────────────────────────────
function toggleAbuse(btn) {
  const popup = btn.nextElementSibling;
  const isOpen = popup.style.display === 'block';

  // Fermer tous les autres popups ouverts
  document.querySelectorAll('.abuse-popup').forEach(p => p.style.display = 'none');

  if (!isOpen) {
    popup.style.display = 'block';
  }
}

// Fermer le popup en cliquant ailleurs
document.addEventListener('click', function(e) {
  if (!e.target.closest('.abuse-wrapper')) {
    document.querySelectorAll('.abuse-popup').forEach(p => p.style.display = 'none');
  }
});
</script>

{% endblock %}
