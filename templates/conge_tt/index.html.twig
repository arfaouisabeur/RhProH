            <option value="typeConge"{% if sortBy == 'typeConge' %}selected{% endif %}>🏷️ Type de congé</option>
            <option value="dateDebut"{% if sortBy == 'dateDebut' %}selected{% endif %}>📆 Date de début</option>
          <option value="statut"   {% if sortBy == 'statut'    %}selected{% endif %}>📌 Statut</option>
        </select>
      </div>

      <input type="hidden" name="sortDir" id="em-cg-sort-dir" value="{{ sortDir }}">
      <div class="filter-group">
        <span class="filter-label" style="visibility:hidden;">Ordre</span>
        <button type="button" class="btn-filter btn-dir"
          onclick="var d=document.getElementById('em-cg-sort-dir');d.value=(d.value==='asc'?'desc':'asc');document.getElementById('em-cg-form').submit();">
          {% if sortDir == 'asc' %}
            <i class="fas fa-arrow-up-a-z"></i> Croissant
          {% else %}
            <i class="fas fa-arrow-down-z-a"></i> Décroissant
