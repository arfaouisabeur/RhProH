<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
  var p = {{ cg_pending }};
  var a = {{ cg_accepted }};
  var r = {{ cg_rejected }};
  var t = p + a + r;
  var typeRaw = {{ cg_typeMap|json_encode|raw }};
  var RAPPORT  = {{ cg_rapport|json_encode|raw }};

  // -- Ouvrir / fermer modal
  var modal    = document.getElementById('statsCongeModal');
  var closeBtn = document.getElementById('cgmCloseBtn');
  if (!modal) return;

  document.querySelectorAll('[onclick*="statsCongeModal"]').forEach(function(btn){
    btn.removeAttribute('onclick');
    btn.addEventListener('click', openModal);
  });
  document.querySelectorAll('[data-open-stats-conge]').forEach(function(btn){
    btn.addEventListener('click', openModal);
  });

  function openModal(){
    modal.style.display = 'flex';
    var bar = document.getElementById('cgmRateBar');
    if (bar) setTimeout(function(){ bar.style.width = '{{ cg_taux }}%'; }, 120);
    initCharts();
  }
  function closeModal(){ modal.style.display = 'none'; }
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e){ if(e.target===modal) closeModal(); });

  // -- Charts
  var chartsInited = false;
  function initCharts(){
    if (chartsInited) return;
    chartsInited = true;

    // Donut
    var donutCtx = document.getElementById('cgmDonutChart');
    if (donutCtx) {
      new Chart(donutCtx.getContext('2d'), {
        type: 'doughnut',
        data: {
          labels: ['En attente','Approuvées','Refusées'],
          datasets:[{ data:[p,a,r], backgroundColor:['#f59e0b','#10b981','#f43f5e'], borderColor:['#fff','#fff','#fff'], borderWidth:3, hoverOffset:12 }]
        },
        options: { cutout:'66%', animation:{animateRotate:true,duration:900}, plugins:{ legend:{display:true,position:'bottom',labels:{font:{size:11},boxWidth:12}}, tooltip:{callbacks:{label:function(c){var pct=t>0?Math.round(c.parsed/t*100):0;return ' '+c.raw+' ('+pct+'%)';}}} } }
      });
    }

    // Bar - top types
    var barCtx = document.getElementById('cgmBarChart');
    var labels = Object.keys(typeRaw);
    var data   = Object.values(typeRaw);
    // Sort desc, keep top 5
    var combined = labels.map(function(l,i){ return {l:l,v:data[i]}; });
    combined.sort(function(a,b){ return b.v - a.v; });
    combined = combined.slice(0,5);
    labels = combined.map(function(x){ return x.l; });
    data   = combined.map(function(x){ return x.v; });

    if (barCtx && labels.length > 0) {
      var palette = ['rgba(143,76,201,.85)','rgba(245,158,11,.85)','rgba(16,185,129,.85)','rgba(244,63,94,.85)','rgba(59,130,246,.85)'];
      new Chart(barCtx.getContext('2d'), {
        type: 'bar',
        data: { labels: labels, datasets:[{ label:'Demandes', data:data, backgroundColor:palette.slice(0,labels.length), borderRadius:8, borderSkipped:false }] },
        options: { indexAxis:'y', scales:{ x:{ticks:{stepSize:1},grid:{color:'rgba(0,0,0,.04)'}}, y:{grid:{display:false},ticks:{font:{size:11}}} }, plugins:{ legend:{display:false}, tooltip:{callbacks:{label:function(c){return ' '+c.parsed.x+' demande'+(c.parsed.x>1?'s':'');}}} }, animation:{duration:800} }
      });
    } else if (barCtx) {
      barCtx.parentElement.innerHTML += '<p style="text-align:center;color:#94a3b8;font-size:.85rem;margin-top:20px;">Aucune donnée</p>';
    }
  }

  // -- Rapport vocal
  var btnVoice  = document.getElementById('cgmBtnVoice');
  var btnIcon   = document.getElementById('cgmBtnIcon');
  var btnTxt    = document.getElementById('cgmBtnTxt');
  var audioWrap = document.getElementById('cgmAudioWrap');
  var audioEl   = document.getElementById('cgmAudioPlayer');
  var VOCAL_URL = '{{ path("app_conge_tt_rapport_vocal") }}';
  var _paused   = false;

  function lireAvecNavigateur(){
    if (!window.speechSynthesis){ btnTxt.textContent='Non supporté'; return; }
    window.speechSynthesis.cancel();
    var texte = RAPPORT || ('Rapport congés : ' + t + ' demandes. ' + a + ' approuvées, ' + r + ' refusées, ' + p + ' en attente.');
    var utter = new SpeechSynthesisUtterance(texte);
    utter.lang = 'fr-FR'; utter.rate = 0.92; utter.volume = 1;
    function parler(){
      var voices = window.speechSynthesis.getVoices();
      var frVoice = voices.find(function(v){ return v.lang==='fr-FR'; }) || voices.find(function(v){ return v.lang.startsWith('fr'); });
      if (frVoice) utter.voice = frVoice;
      utter.onstart = function(){ btnIcon.className='fas fa-volume-high'; btnTxt.textContent='-¸ Pause'; };
      utter.onend   = function(){ btnIcon.className='fas fa-volume-high'; btnTxt.textContent='ð¤ Rejouer'; btnVoice.disabled=false; _paused=false; };
      utter.onerror = function(e){ btnIcon.className='fas fa-exclamation-triangle'; btnTxt.textContent='Erreur : '+e.error; btnVoice.disabled=false; };
      window.speechSynthesis.speak(utter);
      btnIcon.className='fas fa-volume-high'; btnTxt.textContent='-¸ Pause'; btnVoice.disabled=false;
    }
    if (window.speechSynthesis.getVoices().length > 0) { parler(); }
    else { window.speechSynthesis.onvoiceschanged = parler; }
  }

  if (btnVoice) {
    btnVoice.addEventListener('click', function(){
      if (btnVoice.disabled) return;
      
      // Si un audio ElevenLabs est en cours, le contrôler
      if (audioEl && !audioEl.paused) {
        if (audioEl.paused) {
          audioEl.play();
          btnIcon.className = 'fas fa-volume-high';
          btnTxt.textContent = '⏸️ Pause';
        } else {
          audioEl.pause();
          btnIcon.className = 'fas fa-pause';
          btnTxt.textContent = '▶️ Reprendre';
        }
        return;
      }
      
      // Toggle speechSynthesis si déjà en cours
      if (window.speechSynthesis && window.speechSynthesis.speaking) {
        if (_paused){ 
          window.speechSynthesis.resume(); 
          _paused=false; 
          btnTxt.textContent='⏸️ Pause'; 
        } else { 
          window.speechSynthesis.pause();  
          _paused=true;  
          btnTxt.textContent='▶️ Reprendre'; 
        }
        return;
      }

      // Utiliser directement Web Speech API (gratuit, sans limite, fonctionne parfaitement)
      console.log('[Vocal Congés] 🎤 Utilisation de Web Speech API');
      btnVoice.disabled = true;
      btnIcon.className = 'fas fa-spinner fa-spin';
      btnTxt.textContent = 'Initialisation...';
      
      lireAvecNavigateur();
    });
    
    // Initialiser les voix
    if (window.speechSynthesis) {
      window.speechSynthesis.getVoices();
      let voicesLoaded = false;
      window.speechSynthesis.onvoiceschanged = function() {
        if (!voicesLoaded) {
          voicesLoaded = true;
          console.log('[Vocal Congés] Voix chargées:', window.speechSynthesis.getVoices().length);
        }
      };
    }
  }
})();
</script>

{# --¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â
   AJAX SEARCH --- VUE EMPLOYÉ-° CONGÉ-°S
--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â--¢Â #}
<script>
(function () {
  /* ------ Références DOM ------ */
  var form      = document.getElementById('em-cg-form');
  if (!form) return;                           // RH view -- - rien ÉÂ  faire

  var searchUrl  = form.getAttribute('data-search-url');
  var input      = form.querySelector('input[name="search"]');
  var selBy      = form.querySelector('select[name="searchBy"]');
  var selSort    = form.querySelector('select[name="sortBy"]');
  var dirInput   = document.getElementById('em-cg-sort-dir');
  var tbody      = document.getElementById('em-cg-tbody');
  var countNum   = document.getElementById('em-cg-count-num');
  var countBox   = document.getElementById('em-cg-count');
  var emptySearch = document.getElementById('em-cg-empty-state');   // "aucun résultat"
  var emptyData   = document.getElementById('em-cg-no-data');        // "aucune demande"

  if (!tbody) return;

  /* ------ Spinner ------ */
  function setLoading(on) {
    tbody.style.opacity = on ? '0.4' : '1';
    tbody.style.pointerEvents = on ? 'none' : '';
  }

  /* ------ Badge statut ------ */
  function buildBadge(statut) {
    var ok = (statut === 'Accepté' || statut === 'approuvé');
    var no = (statut === 'Refusé'  || statut === 'refusé');
    if (ok) return '<span class="badge b-accepted"><i class="fas fa-check" style="font-size:.7rem;"></i> Accepté</span>';
    if (no) return '<span class="badge b-rejected"><i class="fas fa-times" style="font-size:.7rem;"></i> Refusé</span>';
    return '<span class="badge b-pending"><i class="fas fa-hourglass-half" style="font-size:.7rem;"></i> En attente</span>';
  }

  /* ------ Construction HTML d'une ligne ------ */
  function buildRow(r, idx) {
    var duree = r.nbJours !== null
      ? '<span class="duree-badge">' + r.nbJours + ' j</span>'
      : '<span style="color:#94a3b8;">---</span>';

    var editBtn = r.editable
      ? '<a href="' + r.editUrl + '" class="btn-act btn-edit" title="Modifier"><i class="fas fa-pencil-alt"></i></a>'
      : '';

    var tr = document.createElement('tr');
    tr.style.animation = 'slideUp .3s cubic-bezier(.16,1,.3,1) ' + (idx * 0.04) + 's both';
    tr.innerHTML =
      '<td><strong style="color:#0f172a;font-family:\'Outfit\';font-size:1.05rem;">' + escHtml(r.typeConge) + '</strong></td>' +
      '<td>' +
        '<div style="font-weight:600;color:#0f172a;">' + escHtml(r.dateDebut) + '</div>' +
        '<div style="font-size:.85rem;color:#64748b;margin-top:2px;">au ' + escHtml(r.dateFin) + '</div>' +
      '</td>' +
      '<td>' + duree + '</td>' +
      '<td>' + buildBadge(r.statut) + '</td>' +
      '<td><div class="action-btns">' +
        '<a href="' + r.showUrl + '" class="btn-act btn-view" title="Afficher"><i class="fas fa-eye"></i></a>' +
        editBtn +
      '</div></td>';
    return tr;
  }

  /* ------ É-°chappement HTML basique ------ */
  function escHtml(str) {
    return String(str || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ------ Mise ÉÂ  jour du tableau ------ */
  function renderRows(rows) {
    tbody.innerHTML = '';
    if (rows.length === 0) {
      if (emptySearch)  { emptySearch.style.display = ''; }
      if (emptyData)    { emptyData.style.display   = 'none'; }
      if (countBox)     { countBox.style.display     = 'none'; }
    } else {
      if (emptySearch)  { emptySearch.style.display = 'none'; }
      if (emptyData)    { emptyData.style.display   = 'none'; }
      if (countBox)     { countBox.style.display     = ''; }
      rows.forEach(function (r, i) { tbody.appendChild(buildRow(r, i)); });
    }
    if (countNum) countNum.textContent = rows.length;
  }

  /* ------ Appel AJAX principal ------ */
  var _timer = null;
  function doSearch(immediate) {
    clearTimeout(_timer);
    _timer = setTimeout(function () {
      var params = new URLSearchParams({
        search:   input  ? input.value   : '',
        searchBy: selBy  ? selBy.value   : 'all',
        sortBy:   selSort ? selSort.value : 'id',
        sortDir:  dirInput ? dirInput.value : 'asc',
      });

      setLoading(true);

      fetch(searchUrl + '?' + params.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function (data) {
        setLoading(false);
        renderRows(data.rows || []);
      })
      .catch(function (err) {
        setLoading(false);
        console.error('[AJAX Congés]', err);
      });
    }, immediate ? 0 : 350);
  }

  /* ------ É-°vénements ------ */

  // 1. É-°criture en temps réel (debounce 350 ms)
  if (input) {
    input.addEventListener('input', function () { doSearch(false); });
  }

  // 2. Changement du critÉÂ¨re de recherche ou de tri
  if (selBy)   selBy.addEventListener('change',   function () { doSearch(true); });
  if (selSort) selSort.addEventListener('change',  function () { doSearch(true); });

  // 3. Bouton ordre ASC/DESC (remplace l'onclick inline)
  var dirBtn = form.querySelector('.btn-dir');
  if (dirBtn && dirInput) {
    dirBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var cur = dirInput.value === 'asc' ? 'desc' : 'asc';
      dirInput.value = cur;
      // Mettre ÉÂ  jour le label du bouton
      dirBtn.innerHTML = cur === 'asc'
        ? '<i class="fas fa-arrow-up-a-z"></i> Croissant'
        : '<i class="fas fa-arrow-down-z-a"></i> Décroissant';
      doSearch(true);
    });
  }

  // 4. Soumission du formulaire -- - AJAX au lieu de rechargement
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    doSearch(true);
  });

  // 5. Lien ÉÂ« Réinitialiser ÉÂ»
  var resetLink = form.querySelector('.btn-reset');
  if (resetLink) {
    resetLink.addEventListener('click', function (e) {
      e.preventDefault();
      if (input)    input.value    = '';
      if (selBy)    selBy.value    = 'all';
      if (selSort)  selSort.value  = 'id';
      if (dirInput) dirInput.value = 'asc';
      doSearch(true);
    });
  }

})();
</script>

