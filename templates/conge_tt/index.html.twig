    {# ===== FIN BARRE ===== #}

    {% if conge_tts|length > 0 %}
    {# compteur mis ÉÂ  jour par le JS #}
    <div id="em-cg-count" style="padding:8px 28px 4px;font-size:.83rem;font-weight:800;color:#64748b;display:flex;align-items:center;gap:7px;">
      <i class="fas fa-list-ul" style="color:#b39ddb;"></i>
