{# ------ Calcul stats congés ------ #}
{% set cg_total    = conge_tts|length %}
{% set cg_pending  = conge_tts|filter(c => c.statut == 'En attente')|length %}
{% set cg_accepted = conge_tts|filter(c => c.statut == 'Accepté' or c.statut == 'approuvé')|length %}
{% set cg_rejected = conge_tts|filter(c => c.statut == 'Refusé'  or c.statut == 'refusé')|length %}
{% set cg_resolved = cg_accepted + cg_rejected %}
{% set cg_taux     = cg_total > 0 ? ((cg_resolved / cg_total) * 100)|round : 0 %}

{# Top types de congé #}
{% set cg_typeMap = {} %}
{% for c in conge_tts %}
  {% if c.typeConge %}
    {% set k = c.typeConge %}
    {% set cg_typeMap = cg_typeMap|merge({(k): (cg_typeMap[k] is defined ? cg_typeMap[k] + 1 : 1)}) %}
  {% endif %}
{% endfor %}

{# Total jours demandés #}
{% set cg_totalJours = 0 %}
{% for c in conge_tts %}
  {% if c.dateDebut and c.dateFin %}
    {% set d1 = c.dateDebut|date('U') %}
    {% set d2 = c.dateFin|date('U') %}
    {% if d2 >= d1 %}
      {% set cg_totalJours = cg_totalJours + (((d2 - d1) / 86400)|round(0,'floor') + 1) %}
    {% endif %}
  {% endif %}
{% endfor %}

{# Texte rapport vocal #}
{% set cg_heure = 'now'|date('H')|number_format %}
{% if cg_heure < 12 %}{% set cg_salut = 'Bonjour' %}{% elseif cg_heure < 18 %}{% set cg_salut = 'Bon aprÉÂ¨s-midi' %}{% else %}{% set cg_salut = 'Bonsoir' %}{% endif %}

{% set cg_rapport = cg_salut ~ '. Voici le rapport analytique des congés, généré le ' ~ 'now'|date('d') ~ ' ' ~ 'now'|date('F Y') ~ '. ' %}
{% set cg_rapport = cg_rapport ~ 'Au total, ' ~ cg_total ~ ' demande' ~ (cg_total > 1 ? 's ont' : ' a') ~ ' été enregistrée' ~ (cg_total > 1 ? 's' : '') ~ '. ' %}
{% set cg_rapport = cg_rapport ~ cg_accepted ~ ' demande' ~ (cg_accepted > 1 ? 's ont été approuvées' : ' a été approuvée') ~ ', ' %}
{% set cg_rapport = cg_rapport ~ cg_rejected ~ ' demande' ~ (cg_rejected > 1 ? 's ont été refusées' : ' a été refusée') ~ ', ' %}
{% set cg_rapport = cg_rapport ~ 'et ' ~ cg_pending ~ ' demande' ~ (cg_pending > 1 ? 's sont' : ' est') ~ ' encore en attente. ' %}
{% set cg_rapport = cg_rapport ~ 'Le taux de résolution est de ' ~ cg_taux ~ ' pourcent. ' %}
{% set cg_rapport = cg_rapport ~ 'Le total des jours de congé demandés est de ' ~ cg_totalJours ~ ' jour' ~ (cg_totalJours > 1 ? 's' : '') ~ '. ' %}
{% if cg_typeMap|length > 0 %}
  {% set cg_topType = cg_typeMap|keys|first %}
  {% set cg_rapport = cg_rapport ~ 'Le type de congé le plus demandé est : ' ~ cg_topType ~ '. ' %}
{% endif %}
{% if cg_taux >= 80 %}
  {% set cg_rapport = cg_rapport ~ 'Excellent résultat : le taux de résolution est trÉÂ¨s satisfaisant. ' %}
{% elseif cg_taux >= 50 %}
  {% set cg_rapport = cg_rapport ~ 'Le taux de résolution est satisfaisant mais peut ÉÂªtre amélioré. ' %}
{% elseif cg_taux > 0 %}
  {% set cg_rapport = cg_rapport ~ 'Attention : le taux de résolution est insuffisant. Des actions sont requises. ' %}
{% endif %}
{% set cg_rapport = cg_rapport ~ 'Fin du rapport. Bonne journée.' %}

