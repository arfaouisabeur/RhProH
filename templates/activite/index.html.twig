{% extends 'base.html.twig' %}
{% block title %}Activités — RHPro{% endblock %}

{% block styles %}
:root { --green: #7c3aed; --green-dark: #6d28d9; --surface: #f5f0ff; --border: #e5e7eb; --text-dark: #111827; --text-muted: #6b7280; }
body { background: var(--surface); }
.act-page { min-height: 100vh; background: var(--surface); font-family: 'Inter', sans-serif; padding-bottom: 60px; }
.act-page-header { background: var(--surface); padding: 36px 0 0; }
.act-page-header-inner { max-width: 1100px; margin: 0 auto; padding: 0 32px; display: flex; justify-content: space-between; align-items: flex-start; gap: 20px; flex-wrap: wrap; }
.act-page-title { font-size: 28px; font-weight: 700; color: var(--green-dark); margin: 0 0 6px; }
.act-page-subtitle { font-size: 14px; color: var(--text-muted); margin: 0; }
.btn-new { display: inline-flex; align-items: center; gap: 8px; background: var(--green); color: #fff; padding: 11px 20px; border-radius: 10px; font-size: 14px; font-weight: 600; text-decoration: none; box-shadow: 0 4px 14px rgba(124,58,237,0.3); transition: background 0.2s, transform 0.15s; }
.btn-new:hover { background: var(--green-dark); color: #fff; text-decoration: none; transform: translateY(-1px); }
.act-content { max-width: 1100px; margin: 28px auto 0; padding: 0 32px; }
.act-card { background: #fff; border-radius: 16px; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,0.05); overflow: hidden; }
.act-card-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; }
.act-card-title { font-size: 16px; font-weight: 600; color: var(--text-dark); margin: 0; display: flex; align-items: center; gap: 8px; }
.act-search { display: flex; align-items: center; gap: 8px; background: #f9fafb; border: 1px solid var(--border); border-radius: 9px; padding: 8px 14px; }
.act-search input { border: none; background: transparent; font-size: 13px; outline: none; color: var(--text-dark); width: 180px; }
table.act-table { width: 100%; border-collapse: collapse; }
.act-table th { font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 12px 20px; text-align: left; background: #f9fafb; border-bottom: 1px solid var(--border); }
.act-table td { padding: 14px 20px; font-size: 14px; color: var(--text-dark); border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
.act-table tbody tr:last-child td { border-bottom: none; }
.act-table tbody tr:hover td { background: #faf5ff; }
.act-titre { font-weight: 600; margin: 0 0 2px; }
.act-desc-text { font-size: 12px; color: var(--text-muted); margin: 0; }
.ev-link { font-size: 13px; color: var(--green-dark); text-decoration: none; font-weight: 500; display: inline-flex; align-items: center; gap: 4px; }
.ev-link:hover { text-decoration: underline; }
.row-btns { display: flex; gap: 6px; justify-content: flex-end; }
.icon-btn { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; text-decoration: none; border: 1px solid var(--border); background: transparent; color: var(--text-muted); cursor: pointer; transition: background 0.2s; }
.icon-btn:hover { background: #ede9fe; color: var(--green-dark); text-decoration: none; }
.icon-btn-danger { border-color: #fecaca; color: #ef4444; background: #fff0f0; }
.icon-btn-danger:hover { background: #fee2e2; }
.act-empty { text-align: center; padding: 60px 32px; color: var(--text-muted); }
{% endblock %}

{% block body %}
{{ include('partials/_confirm_modal.html.twig') }}

<div class="act-page">
  <div class="act-page-header">
    <div class="act-page-header-inner">
      <div>
        <h1 class="act-page-title">✅ Activités</h1>
        <p class="act-page-subtitle">Toutes les activités rattachées aux événements</p>
      </div>
      <a href="{{ path('app_activite_new') }}" class="btn-new">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle activité
      </a>
    </div>
  </div>

  <div class="act-content">
    <div class="act-card">
      <div class="act-card-header">
        <h3 class="act-card-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          Liste des activités
        </h3>
        <div class="act-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="act-search-input" placeholder="Rechercher…">
        </div>
      </div>

      {% if activites|length > 0 %}
      <table class="act-table">
        <thead>
          <tr><th>Activité</th><th>Événement</th><th style="text-align:right;">Actions</th></tr>
        </thead>
        <tbody id="act-tbody">
          {% for activite in activites %}
          <tr data-titre="{{ activite.titre|lower }}">
            <td>
              <p class="act-titre">{{ activite.titre }}</p>
              {% if activite.description %}<p class="act-desc-text">{{ activite.description|slice(0,80) }}{% if activite.description|length > 80 %}…{% endif %}</p>{% endif %}
            </td>
            <td>
              {% if activite.evenement %}
                <a href="{{ path('app_evenement_show', {'id': activite.evenement.id}) }}" class="ev-link">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {{ activite.evenement.titre }}
                </a>
              {% else %}—{% endif %}
            </td>
            <td style="text-align:right;">
              <div class="row-btns">
                <a href="{{ path('app_activite_edit', {'id': activite.id}) }}" class="icon-btn" title="Modifier">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </a>
                <form id="del-act-{{ activite.id }}" method="post" action="{{ path('app_activite_delete', {'id': activite.id}) }}" style="display:inline;">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activite.id) }}">
                  <button type="button" class="icon-btn icon-btn-danger" title="Supprimer"
                    onclick="rhConfirmDelete(document.getElementById('del-act-{{ activite.id }}'), 'Supprimer l\'activité « {{ activite.titre|e('js') }} » ?')">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="act-empty">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.5" style="margin-bottom:12px;"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        <p>Aucune activité pour le moment.</p>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
document.getElementById('act-search-input').addEventListener('input', function () {
  var q = this.value.toLowerCase();
  document.querySelectorAll('#act-tbody tr').forEach(function(row) {
    row.style.display = (row.dataset.titre || '').includes(q) ? '' : 'none';
  });
});
</script>
{% endblock %}
