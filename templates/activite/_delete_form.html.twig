<form method="post" action="{{ path('app_activite_delete', {'id': activite.id}) }}" onsubmit="return confirm('Supprimer cette activité ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activite.id) }}">
    <button type="submit" style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:#fee2e2;color:#991b1b;border-radius:9px;font-size:13px;font-weight:600;border:none;cursor:pointer;">
        Supprimer
    </button>
</form>
