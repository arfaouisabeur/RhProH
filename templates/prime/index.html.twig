{% extends 'base.html.twig' %}

{% block title %}Prime index{% endblock %}

{% block body %}
    <h1>Prime index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Montant</th>
                <th>Date_attribution</th>
                <th>Description</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for prime in primes %}
            <tr>
                <td>{{ prime.id }}</td>
                <td>{{ prime.montant }}</td>
                <td>{{ prime.dateAttribution }}</td>
                <td>{{ prime.description }}</td>
                <td>
                    <a href="{{ path('app_prime_show', {'id': prime.id}) }}">show</a>
                    <a href="{{ path('app_prime_edit', {'id': prime.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_prime_new') }}">Create new</a>
{% endblock %}
