  }

  /* ── CAPTCHA ── */
  .captcha-wrapper {
    margin-top: 20px;
  }

  .captcha-box {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.15);
    border-radius: 12px;
    padding: 10px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .captcha-box:focus-within {
    border-color: var(--purple);
    box-shadow: 0 0 0 4px rgba(91,43,130,0.08);
  }

  .captcha-img {
    height: 44px;
    border-radius: 8px;
    border: 1px solid rgba(91,43,130,0.1);
    background: #1e1e3c;
    flex-shrink: 0;
    transition: opacity 0.3s;
  }

  .captcha-refresh {
    background: rgba(91,43,130,0.08);
    border: none;
    border-radius: 8px;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--purple);
    flex-shrink: 0;
    transition: background 0.2s, transform 0.4s;
  }

  .captcha-refresh:hover {
    background: rgba(91,43,130,0.15);
    transform: rotate(180deg);
  }

  .captcha-input {
    flex: 1;
    padding: 10px 14px !important;
    border: none !important;
    box-shadow: none !important;
    letter-spacing: 4px;
    font-weight: 700;
    font-size: 15px;
    background: transparent !important;
  }

  .captcha-input:focus {
    border: none !important;
    box-shadow: none !important;
  }
</style>


