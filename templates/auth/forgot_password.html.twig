{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4 shadow-sm border-0" style="border-radius:14px; background: #faf8ff;">
                <h3 class="text-center mb-3 fw-bold" style="font-family: 'Playfair Display', serif; color: #1a1020;">Réinitialiser le mot de passe</h3>
                <p class="text-muted text-center mb-4 text-sm">Entrez votre adresse e-mail pour recevoir un code de récupération.</p>

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                <form method="post" action="{{ path('app_forgot_password') }}">
                    <div class="mb-3">
                        <label for="email" class="form-label" style="font-size:12px; font-weight:600; text-transform:uppercase;">Adresse E-mail</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="votre@email.com" required>
                    </div>
                    
                    <button type="submit" class="btn w-100" style="background:#5b2b82; color:white; font-weight:600; padding:12px; border-radius:10px;">
                        Envoyer le lien de réinitialisation
                    </button>
                </form>

                <div class="mt-4 text-center">
                    <a href="{{ path('app_login') }}" style="color:#5b2b82; text-decoration:none; font-weight:600; font-size:13px;">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
