    <rect x="0"   y="100" width="50"  height="160" fill="white"/>
    <rect x="60"  y="60"  width="65"  height="200" fill="white"/>
    <rect x="70"  y="40"  width="45"  height="30"  fill="white"/>
    <rect x="135" y="80"  width="45"  height="180" fill="white"/>
    <rect x="190" y="20"  width="80"  height="240" fill="white"/>
    <rect x="200" y="5"   width="60"  height="25"  fill="white"/>
    <rect x="280" y="70"  width="55"  height="190" fill="white"/>
    <rect x="345" y="10"  width="95"  height="250" fill="white"/>
    <rect x="355" y="0"   width="75"  height="20"  fill="white"/>
    <rect x="450" y="55"  width="60"  height="205" fill="white"/>
    <rect x="520" y="30"  width="80"  height="230" fill="white"/>
    <rect x="610" y="5"   width="100" height="255" fill="white"/>
    <rect x="620" y="-5"  width="80"  height="20"  fill="white"/>
    <rect x="720" y="65"  width="60"  height="195" fill="white"/>
    <rect x="790" y="25"  width="75"  height="235" fill="white"/>
    <rect x="875" y="50"  width="55"  height="210" fill="white"/>
    <rect x="940" y="8"   width="90"  height="252" fill="white"/>
    <rect x="950" y="0"   width="70"  height="18"  fill="white"/>
    <rect x="1040" y="45" width="65"  height="215" fill="white"/>
