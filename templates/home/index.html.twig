{% extends 'base.html.twig' %}

{% block title %}Accueil - RH Pro{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --purple:       #5b2b82;
    --purple-dark:  #3d1a5c;
    --purple-light: #7c3dac;
    --gold:         #b39ddb;
    --gold-light:   #d1c4e9;
    --white:        #ffffff;
    --off-white:    #f7f4f0;
    --text-dark:    #1a1020;
    --text-muted:   #8a7a9a;
    --glass:        rgba(255,255,255,0.07);
    --glass-border: rgba(255,255,255,0.15);
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--off-white);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* ══════════════════════════════
     HERO
  ══════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(160deg, #1a0a2e 0%, #3d1a5c 40%, #5b2b82 70%, #2a0d45 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 70% 60% at 10% 90%, rgba(201,168,76,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 55% 45% at 85% 15%, rgba(124,61,172,0.35) 0%, transparent 55%),
      repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.013) 40px, rgba(255,255,255,0.013) 41px);
    pointer-events: none;
  }

  /* Skyline SVG */
  .hero-skyline {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 260px;
    opacity: 0.08;
    pointer-events: none;
  }

  /* Gold bar top */
  .hero-gold-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #b39ddb 30%, #d1c4e9 50%, #b39ddb 70%, transparent);
    opacity: 0.7;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 120px 0 100px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(201,168,76,0.15);
    border: 1px solid rgba(201,168,76,0.35);
    border-radius: 100px;
    padding: 6px 18px;
    margin-bottom: 32px;
    backdrop-filter: blur(8px);
    animation: fadeUp 0.8s ease both;
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold);
    animation: pulse 2s ease infinite;
  }

  .hero-badge span {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    animation: fadeUp 0.9s ease both;
  }

  .hero-title em {
    font-style: normal;
    color: var(--gold-light);
  }

  .hero-subtitle {
    font-size: 16px;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    max-width: 500px;
    margin-bottom: 44px;
    animation: fadeUp 1s ease both;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    animation: fadeUp 1.1s ease both;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 15px 30px;
    background: linear-gradient(135deg, var(--gold) 0%, #e5e1ff 100%);
    color: #1a0a2e;
    border: none;
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 8px 24px rgba(163, 76, 201, 0.35);
  }

  .btn-hero-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px #e5e1ff;
    color: #1a0a2e;
  }

  .btn-hero-outline {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 14px 28px;
    background: var(--glass);
    color: rgba(255,255,255,0.85);
    border: 1.5px solid var(--glass-border);
    border-radius: 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }

  .btn-hero-outline:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-2px);
    color: var(--white);
  }

  /* Right visual: floating cards stack */
  .hero-visual {
    position: relative;
    height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeUp 1s ease both;
  }

  .hv-card {
    position: absolute;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: 18px;
    backdrop-filter: blur(14px);
    padding: 20px 24px;
  }

  .hv-card:nth-child(1) { width: 240px; top: 20px;  left: 60px;  animation: floatCard 6s ease-in-out infinite 0s; }
  .hv-card:nth-child(2) { width: 220px; top: 130px; right: 20px; animation: floatCard 6s ease-in-out infinite 2s; }
  .hv-card:nth-child(3) { width: 230px; top: 250px; left: 30px;  animation: floatCard 6s ease-in-out infinite 4s; }

  .hv-card-label { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 8px; }
  .hv-card-value { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--white); }
  .hv-card-sub   { font-size: 12px; color: rgba(255,255,255,0.45); margin-top: 4px; }
  .hv-card-bar   { height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 12px; overflow: hidden; }
  .hv-card-fill  { height: 100%; background: linear-gradient(90deg, var(--gold), var(--purple-light)); border-radius: 2px; }

  /* Hero scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeUp 1.3s ease both;
  }

  .scroll-hint span {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  .scroll-arrow {
    width: 28px; height: 28px;
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.4);
    animation: bounce 2s ease infinite;
  }

  /* ══════════════════════════════
     CARDS SECTION
  ══════════════════════════════ */
  .section {
    padding: 96px 0;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 16px;
  }

  .section-label::before {
    content: '';
    width: 20px; height: 2px;
    background: var(--gold);
    border-radius: 1px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .section-title em { font-style: normal; color: var(--purple); }

  .section-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 520px;
  }

  /* Space type cards */
  .space-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 56px;
  }

  .space-card {
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.08);
    border-radius: 20px;
    padding: 36px 30px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .space-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .space-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(91,43,130,0.12);
    border-color: rgba(91,43,130,0.2);
  }

  .space-card:hover::before { opacity: 1; }

  .space-card-icon {
    width: 52px; height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(91,43,130,0.08), rgba(91,43,130,0.04));
    border: 1px solid rgba(91,43,130,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple);
    margin-bottom: 22px;
    transition: background 0.2s;
  }

  .space-card:hover .space-card-icon {
    background: linear-gradient(135deg, var(--purple), var(--purple-light));
    color: var(--white);
    border-color: transparent;
  }

  .space-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 10px;
  }

  .space-card-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 24px;
  }

  .space-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--purple);
    transition: gap 0.2s;
  }

  .space-card:hover .space-card-cta { gap: 12px; }

  /* ══════════════════════════════
     FEATURES
  ══════════════════════════════ */
  .features-section {
    padding: 96px 0;
    background: linear-gradient(160deg, #1a0a2e 0%, #3d1a5c 50%, #2a0d45 100%);
    position: relative;
    overflow: hidden;
  }

  .features-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 60% 50% at 0% 100%, rgba(201,168,76,0.08) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 100% 0%, rgba(124,61,172,0.25) 0%, transparent 50%),
      repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(255,255,255,0.012) 40px, rgba(255,255,255,0.012) 41px);
    pointer-events: none;
  }

  .features-section .section-title { color: var(--white); }
  .features-section .section-desc  { color: rgba(255,255,255,0.5); }
  .features-section .section-label { color: var(--gold-light); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 56px;
    position: relative;
    z-index: 1;
  }

  .feature-card {
    background: var(--glass);
    border: 1px solid var(--glass-border);
    border-radius: 18px;
    padding: 30px 24px;
    backdrop-filter: blur(12px);
    transition: background 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .feature-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .feature-card:hover {
    background: rgba(255,255,255,0.1);
    transform: translateY(-4px);
  }

  .feature-card:hover::after { opacity: 1; }

  .feature-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-light);
    margin-bottom: 18px;
  }

  .feature-title {
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
  }

  .feature-desc {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    line-height: 1.65;
  }

  /* ══════════════════════════════
     STATS
  ══════════════════════════════ */
  .stats-section {
    padding: 96px 0;
    background: var(--off-white);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 56px;
  }

  .stat-card {
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.08);
    border-radius: 20px;
    padding: 40px 32px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 60px; height: 3px;
    background: linear-gradient(90deg, var(--purple), var(--gold));
    border-radius: 0 0 3px 3px;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(91,43,130,0.1);
  }

  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 52px;
    font-weight: 700;
    color: var(--purple);
    line-height: 1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--purple), var(--purple-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stat-sub {
    font-size: 11px;
    color: rgba(148, 48, 195, 0.8);
    margin-top: 6px;
    font-weight: 500;
  }

  /* ══════════════════════════════
     CTA BANNER
  ══════════════════════════════ */
  .cta-section {
    padding: 80px 0;
    background: var(--white);
    position: relative;
    overflow: hidden;
  }

  .cta-inner {
    background: linear-gradient(135deg, #1a0a2e 0%, #3d1a5c 50%, #5b2b82 100%);
    border-radius: 24px;
    padding: 64px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .cta-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(201,168,76,0.1) 0%, transparent 60%),
      repeating-linear-gradient(45deg, transparent, transparent 30px, rgba(255,255,255,0.01) 30px, rgba(255,255,255,0.01) 31px);
    pointer-events: none;
  }

  .cta-text { position: relative; z-index: 1; }

  .cta-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .cta-text h2 em { font-style: normal; color: var(--gold-light); }

  .cta-text p {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 420px;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* Keyframes */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* Responsive */
  @media (max-width: 992px) {
    .space-grid    { grid-template-columns: 1fr 1fr; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .stats-grid    { grid-template-columns: 1fr; max-width: 400px; margin-inline: auto; }
    .hero-visual   { display: none; }
    .cta-inner     { flex-direction: column; text-align: center; }
    .cta-actions   { justify-content: center; }
    .cta-text p    { margin-inline: auto; }
  }

  @media (max-width: 640px) {
    .space-grid    { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .cta-inner     { padding: 40px 28px; }
    .section       { padding: 64px 0; }
    .hero-ctas     { flex-direction: column; }
  }
</style>


<!-- ════════════════════════════════
     HERO
════════════════════════════════ -->
