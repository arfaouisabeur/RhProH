  </svg>

  <div class="hero-inner">
    <div class="container">
      <div class="row align-items-center">

        <!-- Left copy -->
        <div class="col-lg-6">
          <div class="hero-badge"><span>Plateforme RH Professionnelle</span></div>
          <h1 class="hero-title">
            Trouvez votre<br>
            <em>opportunité</em><br>
            professionnelle
          </h1>
          <p class="hero-subtitle">
            Que vous soyez candidat en quête d'opportunités ou employé souhaitant gérer votre carrière, RH Pro centralise tout dans un espace unique et sécurisé.
          </p>
          <div class="hero-ctas">
            <a href="{{ path('app_register_candidat') }}" class="btn-hero-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
              Devenir Candidat
            </a>
            <a href="{{ path('app_register_employe') }}" class="btn-hero-outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2"/></svg>
              Espace Employé
            </a>
          </div>
        </div>

        <!-- Right floating cards -->
        <div class="col-lg-6">
          <div class="hero-visual">
            <div class="hv-card">
              <div class="hv-card-label">Candidats inscrits</div>
              <div class="hv-card-value">12 480</div>
              <div class="hv-card-sub">↑ +8% ce mois</div>
              <div class="hv-card-bar"><div class="hv-card-fill" style="width:82%"></div></div>
            </div>
            <div class="hv-card">
              <div class="hv-card-label">Taux de placement</div>
