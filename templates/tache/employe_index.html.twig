{% extends 'base.html.twig' %}

{% block title %}Board Tâches | {{ projet.titre }} | RH Pro{% endblock %}

{% block styles %}
<style>
    :root {
        --board-bg: #f5f3ff;
        --column-bg: rgba(237,233,254,0.5);
        --card-bg: #ffffff;
        --accent-purple: #6b2d8b;
        --accent-purple-light: #9333ea;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --color-todo: #c4b5fd;
        --color-doing: #fbbf24;
        --color-done: #34d399;
        --color-blocked: #f87171;
    }

    body, html, main {
        background-color: var(--board-bg) !important;
        color: var(--text-main);
    }
    body { font-family: 'Inter', sans-serif; min-height: 100vh; }

    .kanban-wrapper {
        padding: 3rem 2rem;
        max-width: 1600px;
        margin: 0 auto;
        animation: fadeIn 0.6s ease-out;
    }

    /* --- HEADER --- */
    .kanban-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 3rem;
        gap: 2rem;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255,255,255,.8);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
        transition: opacity 0.2s;
    }

    .back-btn:hover { opacity: 0.7; color: #fff; }

    .kanban-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.25rem;
        font-weight: 700;
        margin: 0;
        color: #ffffff;
    }

    .kanban-header h1 span { color: rgba(255,255,255,.6); font-size: 1.25rem; font-weight: 500; display: block; }

    .btn-create-task {
        background: var(--accent-purple);
        color: white;
        padding: 0.8rem 1.75rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        box-shadow: 0 10px 20px rgba(91, 43, 130, 0.15);
        transition: all 0.3s ease;
    }

    .btn-create-task:hover {
        background: var(--accent-purple-light);
        transform: translateY(-2px);
        box-shadow: 0 15px 30px rgba(91, 43, 130, 0.25);
        color: white;
    }

    /* --- BOARD --- */
    .kanban-board {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        align-items: flex-start;
    }

    .kanban-column {
        background: var(--column-bg);
        border-radius: 20px;
        padding: 1.25rem;
        min-height: 70vh;
        border: 1px solid rgba(226, 232, 240, 0.6);
    }

    .column-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        padding: 0 0.5rem;
    }

    .column-title h3 {
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .column-dot { width: 8px; height: 8px; border-radius: 50%; }
    .dot-todo { background: var(--color-todo); box-shadow: 0 0 10px var(--color-todo); }
    .dot-doing { background: var(--color-doing); box-shadow: 0 0 10px var(--color-doing); }
    .dot-done { background: var(--color-done); box-shadow: 0 0 10px var(--color-done); }
    .dot-blocked { background: var(--color-blocked); box-shadow: 0 0 10px var(--color-blocked); }

    .task-count {
        background: rgba(255, 255, 255, 0.5);
        padding: 0.2rem 0.6rem;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
    }

    /* --- CARDS --- */
    .task-cards-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .kanban-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border, #e2e8f0);
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 4px 12px rgba(91, 43, 130, 0.03);
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
    }

    .kanban-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(91, 43, 130, 0.08);
        border-color: var(--accent-purple-light);
    }

    .priority-indicator {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
    }
    .prio-faible { background: #10b981; }
    .prio-moyenne { background: #f59e0b; }
    .prio-haute { background: #f97316; }
    .prio-urgente { background: #ef4444; }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .prio-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        background: #f1f5f9;
        color: var(--text-muted);
    }

    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 0.5rem;
        line-height: 1.4;
    }

    .card-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid #f1f5f9;
    }

    .card-date {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .card-actions {
        display: flex;
        gap: 0.5rem;
    }

    .action-circle {
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: var(--text-muted);
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
        text-decoration: none;
    }

    .action-circle:hover {
        background: var(--accent-purple);
        color: white;
        border-color: var(--accent-purple);
    }

    .delete-btn:hover { background: #ef4444; border-color: #ef4444; }

    .empty-col {
        text-align: center;
        padding: 2rem 1rem;
        border: 2px dashed rgba(255,255,255,0.2);
        border-radius: 12px;
        color: rgba(255,255,255,0.5);
        font-size: 0.8rem;
        font-weight: 500;
    }

    /* Override colonnes pour fond violet */
    .kanban-column {
        background: #fff !important;
        backdrop-filter: none;
        border: 1px solid #ede9fe !important;
        box-shadow: 0 2px 12px rgba(107,45,139,.06);
    }
    .column-title h3 { color: #6b2d8b !important; }
    .task-count { background: #f5f3ff !important; color: #6b2d8b !important; }
    .dot-todo { background: #c4b5fd !important; box-shadow: 0 0 8px #c4b5fd !important; }
    .dot-doing { background: #fbbf24 !important; box-shadow: 0 0 8px #fbbf24 !important; }
    .dot-done { background: #34d399 !important; box-shadow: 0 0 8px #34d399 !important; }
    .dot-blocked { background: #f87171 !important; box-shadow: 0 0 8px #f87171 !important; }
    .btn-create-task { background: #6b2d8b !important; border: none !important; }
    .btn-create-task:hover { background: #5a2474 !important; color: white !important; }
    .back-btn { color: #6b2d8b !important; }
    .kanban-header h1 { color: #6b2d8b !important; }
    .empty-col { border-color: #ede9fe !important; color: #c4b5fd !important; }
    .kanban-card { background: #ede9fe !important; border-color: #ddd6fe !important; }
    .kanban-card:hover { background: #e9d5ff !important; border-color: #c4b5fd !important; }

    @media (max-width: 1200px) {
        .kanban-board { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
        .kanban-board { grid-template-columns: 1fr; }
        .kanban-header { flex-direction: column; align-items: flex-start; }
    }
</style>
{% endblock %}

{% block body %}
<div class="kanban-wrapper">

    <div class="kanban-header">
        <div>
            <a href="{{ path('app_projet_employe_index') }}" class="back-btn">
                <i class="bi bi-arrow-left"></i> Retour aux projets
            </a>
            <h1>{{ projet.titre }}</h1>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <div class="view-toggle">
                <button class="vt-btn active" id="btnKanban" onclick="setView('kanban')">
                    <i class="bi bi-kanban"></i> Kanban
                </button>
                <button class="vt-btn" id="btnCalendar" onclick="setView('calendar')">
                    <i class="bi bi-calendar3"></i> Calendrier
                </button>
            </div>
            <a href="{{ path('app_tache_new_pour_projet', {'projetId': projet.id}) }}" class="btn-create-task">
                <i class="bi bi-plus-circle"></i> Ajouter une tâche
            </a>
        </div>
    </div>

    <div class="kanban-board">
        {# COLUMN: TO DO #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-todo"></span> À Faire</h3>
                {% set todoItems = taches|filter(t => t.statut == 'a_faire') %}
                <span class="task-count">{{ todoItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if todoItems is empty %}
                    <div class="empty-col">Libre de toute tâche</div>
                {% else %}
                    {% for tache in todoItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: IN PROGRESS #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-doing"></span> En Cours</h3>
                {% set doingItems = taches|filter(t => t.statut == 'en_cours') %}
                <span class="task-count">{{ doingItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if doingItems is empty %}
                    <div class="empty-col">Rien n'est entamé</div>
                {% else %}
                    {% for tache in doingItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: COMPLETED #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-done"></span> Terminées</h3>
                {% set doneItems = taches|filter(t => t.statut == 'terminee') %}
                <span class="task-count">{{ doneItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if doneItems is empty %}
                    <div class="empty-col">Zéro finalisé</div>
                {% else %}
                    {% for tache in doneItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        {# COLUMN: BLOCKED #}
        <div class="kanban-column">
            <div class="column-title">
                <h3><span class="column-dot dot-blocked"></span> Bloquées</h3>
                {% set blockedItems = taches|filter(t => t.statut == 'bloquee') %}
                <span class="task-count">{{ blockedItems|length }}</span>
            </div>
            <div class="task-cards-list">
                {% if blockedItems is empty %}
                    <div class="empty-col">Aucun obstacle</div>
                {% else %}
                    {% for tache in blockedItems %}
                        <div class="kanban-card">
                            <div class="priority-indicator prio-{{ tache.level|lower }}"></div>
                            <div class="card-meta">
                                <span class="prio-label">{{ tache.level ?: 'Simple' }}</span>
                                <div class="card-actions">
                                    <a href="{{ path('app_tache_edit', {'id': tache.id}) }}" class="action-circle" title="Modifier">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette tâche ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                        <button class="action-circle delete-btn" title="Supprimer">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <h4 class="card-title">{{ tache.titre }}</h4>
                            <p class="card-desc">{{ tache.description ?: 'Traitement tactique en cours.' }}</p>
                            <div class="card-footer">
                                <div class="card-date">
                                    <i class="bi bi-calendar2-check"></i>
                                    {{ tache.dateFin ? tache.dateFin|date('d/m/Y') : '--/--/--' }}
                                </div>
                                <div style="font-size: 0.65rem; color: #cbd5e1; font-weight: 800;">OP-{{ tache.id }}</div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Calendrier FullCalendar ── #}
    <div id="calendarView" style="display:none">
        <div class="cal-legend">
            <span class="cal-leg-item"><span class="cal-dot" style="background:#6b2d8b"></span>À faire</span>
            <span class="cal-leg-item"><span class="cal-dot" style="background:#f59e0b"></span>En cours</span>
            <span class="cal-leg-item"><span class="cal-dot" style="background:#10b981"></span>Terminée</span>
            <span class="cal-leg-item"><span class="cal-dot" style="background:#ef4444"></span>Bloquée</span>
        </div>
        {% if calendarEvents is empty %}
            <div style="text-align:center;padding:40px;background:#fff;border-radius:16px;color:#94a3b8">
                <i class="bi bi-calendar3" style="font-size:2rem;display:block;margin-bottom:10px"></i>
                Aucune tâche avec des dates à afficher.
            </div>
        {% else %}
            <div id="fullcalendar"></div>
        {% endif %}
    </div>

</div>

{# Styles calendrier #}
<style>
.view-toggle{display:flex;background:#f1f5f9;border-radius:12px;padding:4px;gap:4px}
.vt-btn{padding:8px 18px;border-radius:9px;border:none;background:transparent;color:#64748b;font-weight:600;font-size:.85rem;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px}
.vt-btn.active{background:#6b2d8b;color:#fff;box-shadow:0 2px 8px rgba(107,45,139,.3)}
.cal-legend{display:flex;gap:16px;margin-bottom:16px;flex-wrap:wrap;background:#fff;padding:12px 18px;border-radius:14px;border:1px solid #ede9fe;box-shadow:0 2px 8px rgba(107,45,139,.05)}
.cal-leg-item{display:flex;align-items:center;gap:7px;font-size:.8rem;color:#374151;font-weight:600}
.cal-dot{width:12px;height:12px;border-radius:4px;flex-shrink:0}
#fullcalendar{background:#fff;border-radius:20px;padding:24px;box-shadow:0 8px 32px rgba(107,45,139,.1);border:1px solid #ede9fe}

/* Toolbar */
.fc-toolbar{margin-bottom:20px!important;gap:10px;flex-wrap:wrap}
.fc-toolbar-title{font-size:1.2rem!important;font-weight:800!important;color:#1e293b!important;letter-spacing:-.3px}

/* Boutons navigation */
.fc-button-primary{
    background:linear-gradient(135deg,#6b2d8b,#9333ea)!important;
    border:none!important;border-radius:10px!important;
    font-size:.78rem!important;font-weight:700!important;
    padding:7px 14px!important;letter-spacing:.02em!important;
    box-shadow:0 3px 10px rgba(107,45,139,.3)!important;
    transition:all .2s!important;
}
.fc-button-primary:hover{
    background:linear-gradient(135deg,#5a2474,#7c3aed)!important;
    transform:translateY(-1px)!important;
    box-shadow:0 5px 16px rgba(107,45,139,.4)!important;
}
.fc-button-primary:not(:disabled).fc-button-active{
    background:linear-gradient(135deg,#4a1d63,#6d28d9)!important;
    box-shadow:inset 0 2px 6px rgba(0,0,0,.2)!important;
}
.fc-button-primary:disabled{opacity:.5!important}

/* En-têtes jours */
.fc-col-header-cell{
    background:linear-gradient(135deg,#6b2d8b,#9333ea)!important;
    padding:10px 0!important;
}
.fc-col-header-cell-cushion{
    color:#fff!important;font-size:.72rem!important;
    font-weight:700!important;text-transform:uppercase!important;
    letter-spacing:.1em!important;text-decoration:none!important;
}

/* Numéros de jours */
.fc-daygrid-day-number{
    font-size:.8rem!important;color:#64748b!important;
    font-weight:600!important;padding:6px 8px!important;
    text-decoration:none!important;
}

/* Jour aujourd'hui */
.fc-day-today{background:linear-gradient(135deg,#faf8ff,#f5f3ff)!important}
.fc-day-today .fc-daygrid-day-number{
    background:#6b2d8b!important;color:#fff!important;
    border-radius:50%!important;width:26px!important;height:26px!important;
    display:flex!important;align-items:center!important;justify-content:center!important;
    margin:4px!important;
}

/* Événements */
.fc-event{
    border-radius:8px!important;font-size:.75rem!important;
    font-weight:700!important;padding:3px 8px!important;
    cursor:pointer!important;border:none!important;
    box-shadow:0 2px 6px rgba(0,0,0,.15)!important;
    transition:transform .15s,box-shadow .15s!important;
}
.fc-event:hover{
    transform:translateY(-1px) scale(1.02)!important;
    box-shadow:0 4px 12px rgba(0,0,0,.2)!important;
}
.fc-event-title{font-weight:700!important}

/* Vue liste */
.fc-list-event:hover td{background:#faf8ff!important}
.fc-list-event-dot{border-radius:50%!important}
.fc-list-day-cushion{background:#f5f3ff!important;color:#6b2d8b!important;font-weight:700!important}

/* Grille */
.fc-scrollgrid{border-radius:12px!important;overflow:hidden!important;border-color:#ede9fe!important}
.fc-scrollgrid td,.fc-scrollgrid th{border-color:#f1f5f9!important}
.fc-daygrid-day{transition:background .15s!important}
.fc-daygrid-day:hover{background:#faf8ff!important}
</style>

{# Tooltip popup #}
<div id="cal-popup" style="display:none;position:fixed;z-index:9998;background:#fff;border-radius:16px;padding:18px 22px;box-shadow:0 12px 40px rgba(107,45,139,.2);border:1px solid #ede9fe;min-width:240px;max-width:300px;animation:cal-pop-in .15s ease">
    <style>@keyframes cal-pop-in{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}</style>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
        <strong id="pop-title" style="color:#1e293b;font-size:.92rem;line-height:1.3;max-width:200px"></strong>
        <button onclick="document.getElementById('cal-popup').style.display='none'" style="background:none;border:none;cursor:pointer;color:#94a3b8;font-size:1rem;padding:0;line-height:1;flex-shrink:0">✕</button>
    </div>
    <div id="pop-body" style="font-size:.82rem;color:#64748b;line-height:1.7"></div>
</div>
{% endblock %}

{% block javascripts %}
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script>
// Événements passés directement depuis PHP — pas de requête AJAX
const EVENTS = {{ calendarEvents|json_encode|raw }};
let calendarInstance = null;

function setView(v) {
    const kanban  = document.querySelector('.kanban-board');
    const calView = document.getElementById('calendarView');
    const btnK    = document.getElementById('btnKanban');
    const btnC    = document.getElementById('btnCalendar');
    if (v === 'kanban') {
        kanban.style.display  = '';
        calView.style.display = 'none';
        btnK.classList.add('active');
        btnC.classList.remove('active');
    } else {
        kanban.style.display  = 'none';
        calView.style.display = '';
        btnK.classList.remove('active');
        btnC.classList.add('active');
        if (!calendarInstance) initCalendar();
        else calendarInstance.render();
    }
    localStorage.setItem('tacheView_{{ projet.id }}', v);
}

function initCalendar() {
    const el = document.getElementById('fullcalendar');
    calendarInstance = new FullCalendar.Calendar(el, {
        locale: 'fr',
        initialView: 'dayGridMonth',
        height: 'auto',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,listMonth'
        },
        buttonText: { today: "Aujourd'hui", month: 'Mois', list: 'Liste' },
        events: EVENTS,
        eventDidMount: function(info) {
            // Tooltip natif
            info.el.title = info.event.title + ' — ' + (info.event.extendedProps.statut || '');
        },
        eventClick: function(info) {
            const p = info.event.extendedProps;
            const statutLabels = {
                'a_faire':'🕒 À faire','en_cours':'⌛ En cours',
                'terminee':'✅ Terminée','bloquee':'🔴 Bloquée'
            };
            const prioColors = {
                'faible':'#10b981','moyenne':'#f59e0b',
                'haute':'#f97316','urgente':'#ef4444'
            };
            document.getElementById('pop-title').textContent = info.event.title;
            document.getElementById('pop-body').innerHTML =
                `<div style="display:inline-flex;align-items:center;gap:5px;background:#f5f3ff;color:#6b2d8b;padding:3px 10px;border-radius:20px;font-size:.72rem;font-weight:700;margin-bottom:8px">${statutLabels[p.statut]||p.statut}</div>` +
                (p.priorite ? `<div style="margin-bottom:6px">Priorité : <span style="color:${prioColors[p.priorite]||'#64748b'};font-weight:700;text-transform:capitalize">${p.priorite}</span></div>` : '') +
                `<div style="margin-bottom:6px;display:flex;align-items:center;gap:5px"><span style="color:#a78bfa">📅</span> ${info.event.startStr}</div>` +
                (p.description ? `<div style="color:#94a3b8;font-size:.78rem;border-top:1px solid #f1f5f9;padding-top:8px;margin-top:4px">${p.description.substring(0,120)}${p.description.length>120?'…':''}</div>` : '');
            const popup = document.getElementById('cal-popup');
            popup.style.display = 'block';
            popup.style.left = Math.min(info.jsEvent.pageX+12, window.innerWidth-320)+'px';
            popup.style.top  = Math.min(info.jsEvent.pageY+12, window.innerHeight-220)+'px';
        }
    });
    calendarInstance.render();
}

// Fermer popup en cliquant ailleurs
document.addEventListener('click', function(e) {
    const popup = document.getElementById('cal-popup');
    if (!popup.contains(e.target)) popup.style.display = 'none';
});

const savedView = localStorage.getItem('tacheView_{{ projet.id }}');
if (savedView === 'calendar') {
    localStorage.removeItem('tacheView_{{ projet.id }}');
    setView('calendar');
}
</script>
{% endblock %}
