{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.employee-contracts-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.employee-contracts-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.employee-contracts-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.employee-contracts-wrap { max-width:1200px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.employee-contracts-head {
  margin-bottom:32px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.employee-contracts-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.6rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.employee-contracts-title h1 i { font-size:2.2rem; -webkit-text-fill-color:var(--mv-600); }
.employee-contracts-title p { margin:8px 0 0; color:#64748b; font-size:1.05rem; font-weight:500; }

/* Contract Cards */
.contract-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; padding:32px 36px; margin-bottom:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.08);
  transition:all .3s cubic-bezier(.175,.885,.32,1.275);
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}
.contract-card:hover { 
  transform:translateY(-6px); 
  box-shadow:0 20px 60px rgba(143,76,201,.15);
}

/* Contract Header */
.contract-header {
  display:flex; justify-content:space-between; align-items:flex-start;
  margin-bottom:20px; padding-bottom:20px;
  border-bottom:2px solid rgba(179,157,219,.12);
}
.contract-employee h5 {
  font-family:'Outfit'; font-weight:900; font-size:1.4rem; margin:0;
  color:var(--mv-950);
}
.contract-type {
  color:#64748b; font-weight:600; font-size:.9rem;
  margin-top:4px;
}

/* Status Badge */
.status-badge {
  padding:8px 16px; border-radius:999px; font-weight:800; font-size:.85rem;
  text-transform:uppercase; letter-spacing:.05em;
}
.status-badge.active {
  background:linear-gradient(135deg,#10b981,#059669);
  color:#fff;
}
.status-badge.expired {
  background:linear-gradient(135deg,#ef4444,#dc2626);
  color:#fff;
}

/* Contract Info Grid */
.contract-info {
  display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:24px; margin-bottom:24px;
}
.info-item {
  padding:16px 20px; border-radius:14px;
  background:rgba(143,76,201,.04); border:1px solid rgba(179,157,219,.15);
}
.info-label {
  display:flex; align-items:center; gap:8px;
  font-weight:800; font-size:.85rem; color:var(--mv-700);
  text-transform:uppercase; letter-spacing:.05em; margin-bottom:8px;
}
.info-value {
  font-weight:700; font-size:1.05rem; color:#0f172a;
}
.salary-value {
  color:#10b981; font-family:'Outfit'; font-weight:900;
}
.net-salary {
  color:#2563eb; font-weight:700; font-size:.95rem; margin-top:4px;
}
.tax-info {
  color:#ef4444; font-weight:600; font-size:.85rem; margin-top:2px;
}

/* Description */
.contract-description {
  background:rgba(143,76,201,.06); border-radius:14px;
  padding:16px 20px; margin-bottom:24px;
  border-left:4px solid var(--mv-600);
}
.contract-description .info-label {
  margin-bottom:8px;
}
.contract-description .info-value {
  line-height:1.6; color:#475569;
}

/* Download Button */
.btn-download {
  display:inline-flex; align-items:center; gap:9px; padding:12px 24px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit'; text-decoration:none;
}
.btn-download:hover { 
  transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); 
  color:#fff; text-decoration:none;
}

/* Empty State */
.empty-state {
  text-align:center; padding:60px 20px;
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; color:#64748b;
}
.empty-state i {
  font-size:4rem; color:var(--mv-400); margin-bottom:16px; display:block;
}
.empty-state h3 {
  font-family:'Outfit'; font-weight:800; color:var(--mv-700); margin-bottom:8px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .contract-header { flex-direction:column; align-items:flex-start; gap:16px; }
  .contract-info { grid-template-columns:1fr; }
}
</style>
{% endblock %}

{% block body %}
<div class="employee-contracts-shell">
  <div class="employee-contracts-wrap">

    <!-- 🔥 HEADER -->
    <div class="employee-contracts-head">
      <div class="employee-contracts-title">
        <h1><i class="fas fa-file-contract"></i> Mes Contrats</h1>
        <p>Consultez vos contrats de travail et téléchargez les documents</p>
      </div>
    </div>

    <!-- CONTRACTS -->
    {% for contract in contracts %}
      <div class="contract-card">

        <!-- HEADER -->
        <div class="contract-header">
          <div class="contract-employee">
            <h5>{{ contract.employe.user.fullName }}</h5>
            <div class="contract-type">
              <i class="fas fa-briefcase"></i> {{ contract.type ?? 'Contrat de travail' }}
            </div>
          </div>

          <span class="status-badge 
            {% if contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}
              expired
            {% else %}
              active
            {% endif %}
          ">
            {% if contract.dateFin and contract.dateFin < "now"|date('Y-m-d') %}
              <i class="fas fa-times-circle"></i> Expiré
            {% else %}
              <i class="fas fa-check-circle"></i> Actif
            {% endif %}
          </span>
        </div>

        <!-- INFO GRID -->
        <div class="contract-info">
          <div class="info-item">
            <div class="info-label">
              <i class="fas fa-calendar-plus"></i> Date de début
            </div>
            <div class="info-value">{{ contract.dateDebut|date('d/m/Y') }}</div>
          </div>

          <div class="info-item">
            <div class="info-label">
              <i class="fas fa-calendar-minus"></i> Date de fin
            </div>
            <div class="info-value">{{ contract.dateFin ? contract.dateFin|date('d/m/Y') : 'Indéterminée' }}</div>
          </div>

          <div class="info-item">
            <div class="info-label">
              <i class="fas fa-coins"></i> Salaire
            </div>
            <div class="info-value salary-value">
              {{ convertedSalaires[contract.id] ?? contract.salaireBase }} {{ currency }}
            </div>
            {% if taxData[contract.id] is defined %}
              <div class="net-salary">
                <i class="fas fa-wallet"></i> Net: {{ taxData[contract.id].net }} {{ currency }}
              </div>
              <div class="tax-info">
                <i class="fas fa-receipt"></i> Taxe: {{ taxData[contract.id].tax }} {{ currency }}
              </div>
            {% endif %}
          </div>
        </div>

        <!-- DESCRIPTION -->
        {% if contract.description %}
          <div class="contract-description">
            <div class="info-label">
              <i class="fas fa-file-text"></i> Description
            </div>
            <div class="info-value">{{ contract.description }}</div>
          </div>
        {% endif %}

        <!-- ACTION -->
        <div class="text-end">
          <a href="{{ path('app_employee_contract_pdf', {'id': contract.id}) }}" class="btn-download">
            <i class="fas fa-download"></i> Télécharger PDF
          </a>
        </div>

      </div>

    {% else %}
      <div class="empty-state">
        <i class="fas fa-file-contract"></i>
        <h3>Aucun contrat trouvé</h3>
        <p>Vous n'avez actuellement aucun contrat de travail enregistré.</p>
      </div>
    {% endfor %}

  </div>
</div>

{% endblock %}