{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.employee-salaires-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.employee-salaires-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.employee-salaires-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.employee-salaires-wrap { max-width:1400px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.employee-salaires-head {
  margin-bottom:32px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.employee-salaires-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.6rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.employee-salaires-title h1 i { font-size:2.2rem; -webkit-text-fill-color:var(--mv-600); }
.employee-salaires-title p { margin:8px 0 0; color:#64748b; font-size:1.05rem; font-weight:500; }

/* Chart Card */
.employee-chart-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; padding:32px 36px; margin-bottom:32px;
  box-shadow:0 10px 40px rgba(143,76,201,.08);
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .1s both;
}
.employee-chart-title {
  font-family:'Outfit'; font-weight:900; font-size:1.4rem; margin-bottom:20px;
  color:var(--mv-950); display:flex; align-items:center; gap:10px;
}
.employee-chart-container {
  height:350px; border-radius:16px; overflow:hidden;
  background:rgba(143,76,201,.02);
}

/* Table Card */
.employee-table-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; overflow:hidden;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}
.employee-table-header {
  background:linear-gradient(135deg,var(--mv-950),var(--mv-800));
  color:#fff; padding:20px 24px;
  display:flex; justify-content:space-between; align-items:center;
}
.employee-table-header h5 {
  margin:0; font-family:'Outfit'; font-weight:900; font-size:1.3rem;
  display:flex; align-items:center; gap:10px;
}
.employee-table-responsive { max-height:600px; overflow-y:auto; }
.employee-table {
  margin:0; font-size:.95rem;
}
.employee-table thead {
  background:rgba(143,76,201,.08); position:sticky; top:0; z-index:10;
}
.employee-table thead th {
  border:none; padding:16px 20px; font-weight:800; font-size:.85rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.05em;
}
.employee-table tbody td {
  border:none; padding:16px 20px; vertical-align:middle;
  border-bottom:1px solid rgba(179,157,219,.12);
}
.employee-table tbody tr:hover { background:rgba(143,76,201,.04); }

/* Badge styles */
.employee-badge-amount {
  background:linear-gradient(135deg,#10b981,#059669);
  color:#fff; padding:8px 16px; border-radius:999px;
  font-weight:800; font-size:.9rem;
  display:inline-flex; align-items:center; gap:6px;
}
.employee-badge-status-paid {
  background:linear-gradient(135deg,#10b981,#059669);
  color:#fff; padding:6px 14px; border-radius:999px;
  font-weight:800; font-size:.85rem;
  display:inline-flex; align-items:center; gap:6px;
}
.employee-badge-status-pending {
  background:linear-gradient(135deg,#f59e0b,#d97706);
  color:#fff; padding:6px 14px; border-radius:999px;
  font-weight:800; font-size:.85rem;
  display:inline-flex; align-items:center; gap:6px;
}
.employee-month-text { 
  color:#64748b; font-weight:600; 
  display:flex; align-items:center; gap:8px;
}
.employee-year-text { 
  color:#64748b; font-weight:600;
}

/* Empty State */
.employee-empty-state {
  text-align:center; padding:60px 20px;
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; color:#64748b;
}
.employee-empty-state i {
  font-size:4rem; color:var(--mv-400); margin-bottom:16px; display:block;
}
.employee-empty-state h3 {
  font-family:'Outfit'; font-weight:800; color:var(--mv-700); margin-bottom:8px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .employee-salaires-title h1 { font-size:2.2rem; }
  .employee-table thead th, .employee-table tbody td { padding:12px 16px; }
  .employee-chart-card { padding:24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="employee-salaires-shell">
  <div class="employee-salaires-wrap">

    <!-- 🔥 HEADER -->
    <div class="employee-salaires-head">
      <div class="employee-salaires-title">
        <h1><i class="fas fa-money-bill-wave"></i> Mes Salaires</h1>
        <p>Consultez l'historique de vos paiements et l'évolution de vos salaires</p>
      </div>
    </div>

    <!-- 📈 CHART CARD -->
    <div class="employee-chart-card">
      <h5 class="employee-chart-title">
        <i class="fas fa-chart-line"></i> Évolution des Salaires
      </h5>
      <div class="employee-chart-container">
        {{ render_chart(chart) }}
      </div>
    </div>

    <!-- 💎 TABLE -->
    {% if salaires|length > 0 %}
      <div class="employee-table-card">
        <div class="employee-table-header">
          <h5><i class="fas fa-table"></i> Historique des Salaires</h5>
          <span class="badge bg-light text-dark">{{ salaires|length }} paiement{{ salaires|length > 1 ? 's' : '' }}</span>
        </div>

        <div class="employee-table-responsive">
          <table class="employee-table table align-middle mb-0">
            <thead>
              <tr>
                <th><i class="fas fa-calendar-alt"></i> Mois</th>
                <th><i class="fas fa-calendar"></i> Année</th>
                <th><i class="fas fa-coins"></i> Montant</th>
                <th><i class="fas fa-info-circle"></i> Statut</th>
              </tr>
            </thead>
            <tbody>
              {% for salaire in salaires %}
                <tr>
                  <!-- MOIS -->
                  <td class="employee-month-text">
                    <i class="fas fa-calendar-alt" style="color:var(--mv-500);"></i>
                    {{ [
                      'Janvier','Février','Mars','Avril','Mai','Juin',
                      'Juillet','Août','Septembre','Octobre','Novembre','Décembre'
                    ][salaire.mois-1] }}
                  </td>

                  <!-- ANNÉE -->
                  <td class="employee-year-text">
                    {{ salaire.annee }}
                  </td>

                  <!-- MONTANT -->
                  <td>
                    <span class="employee-badge-amount">
                      <i class="fas fa-coins"></i>
                      {{ salaire.convertedMontant ?? salaire.montant }} {{ currency }}
                    </span>
                  </td>

                  <!-- STATUT -->
                  <td>
                    {% if salaire.statut == 'PAYE' %}
                      <span class="employee-badge-status-paid">
                        <i class="fas fa-check-circle"></i> Payé
                      </span>
                    {% else %}
                      <span class="employee-badge-status-pending">
                        <i class="fas fa-clock"></i> En attente
                      </span>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <div class="employee-empty-state">
        <i class="fas fa-money-bill-wave"></i>
        <h3>Aucun salaire trouvé</h3>
        <p>Vous n'avez actuellement aucun salaire enregistré dans votre historique.</p>
      </div>
    {% endif %}

  </div>
</div>

{% endblock %}