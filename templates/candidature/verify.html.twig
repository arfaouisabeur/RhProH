{% extends 'candidat/base.html.twig' %}
{% block title %}Vérification de candidature{% endblock %}
{% block body %}

<div style="max-width:600px; margin:2rem auto;">
<div class="panel">
    <div class="panel-head">
        <h2 class="panel-title">
            <i class="bi bi-shield-check"></i>
            Vérification Blockchain
        </h2>
    </div>
    <div class="panel-body text-center">

        {% if isValid and candidature %}
            <div style="font-size:56px; margin:15px 0">✅</div>
            <h3 style="color:#3B6D11">Candidature Authentique</h3>
            <p class="text-muted">Cette candidature est certifiée et n'a pas été modifiée.</p>

            <div style="background:#F8F7FF; border:1px solid #AFA9EC; border-radius:8px; padding:20px; margin:20px 0; text-align:left;">
                <div style="margin-bottom:10px; font-size:13px;">
                    <strong>Candidat :</strong>
                    {{ candidature.candidat.user.nom }} {{ candidature.candidat.user.prenom }}
                </div>
                <div style="margin-bottom:10px; font-size:13px;">
                    <strong>Poste :</strong> {{ candidature.offreEmploi.titre }}
                </div>
                <div style="margin-bottom:10px; font-size:13px;">
                    <strong>Date :</strong> {{ candidature.dateCandidature|date('d/m/Y') }}
                </div>
                <div style="font-size:13px;">
                    <strong>Statut :</strong>
                    <span style="color:#3B6D11">✓ Certifié</span>
                </div>
            </div>

        {% elseif isValid and not candidature %}
            <div style="font-size:56px; margin:15px 0">⚠️</div>
            <h3 style="color:#BA7517">Hash valide mais introuvable</h3>
            <p class="text-muted">Ce hash n'existe pas dans notre base de données.</p>

        {% else %}
            <div style="font-size:56px; margin:15px 0">❌</div>
            <h3 style="color:#D85A30">Certificat Invalide</h3>
            <p class="text-muted">Ce hash ne correspond à aucune candidature certifiée.</p>
        {% endif %}

        <div style="background:#1a1a2e; border-radius:8px; padding:15px; margin-top:20px;">
            <div style="font-size:10px; color:#888; margin-bottom:6px; text-transform:uppercase;">Hash vérifié</div>
            <code style="font-size:11px; color:#7F77DD; word-break:break-all">{{ hash }}</code>
        </div>

    </div>
</div>
</div>

{% endblock %}
