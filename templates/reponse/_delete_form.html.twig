<form method="post"
      action="{{ path('app_reponse_delete', {'id': reponse.id}) }}"
      onsubmit="return confirm('Supprimer cette décision RH ? Cette action est irréversible.');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reponse.id) }}">
    <button type="submit" style="
        display: inline-flex; align-items: center; gap: 0.55rem;
        padding: 0.7rem 1.2rem; border-radius: 999px;
        background: rgba(244,63,94,0.10); color: #be123c;
        border: 1.5px solid rgba(244,63,94,0.25);
        font-family: 'Inter', sans-serif; font-size: 0.9rem; font-weight: 800;
        cursor: pointer; transition: transform 0.18s, background 0.18s, box-shadow 0.18s;
    "
    onmouseover="this.style.background='rgba(244,63,94,0.16)';this.style.transform='translateY(-1px)';this.style.boxShadow='0 10px 22px rgba(244,63,94,0.15)'"
    onmouseout="this.style.background='rgba(244,63,94,0.10)';this.style.transform='translateY(0)';this.style.boxShadow='none'"
    >
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>
