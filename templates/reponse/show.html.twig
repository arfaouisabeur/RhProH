{% extends 'base.html.twig' %}

{% block title %}Détail de la Décision RH{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    .hr-container {
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at top right, #eef2ff 0%, #ffffff 50%, #f5f3ff 100%);
        min-height: 90vh; padding: 40px 20px; color: #0f172a;
    }
    .hr-container * { box-sizing: border-box; }
    
    .view-wrapper { max-width: 800px; margin: 0 auto; animation: fadeUp 0.6s ease-out; }

    .header-box { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .btn-back { display: flex; align-items: center; gap: 8px; color: #4f46e5; text-decoration: none; font-weight: 600; padding: 10px 18px; border-radius: 50px; background: rgba(79,70,229,0.1); transition: 0.2s; }
    .btn-back:hover { background: #4f46e5; color: white; }

    .report-card {
        background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border: 1px solid white; border-radius: 24px;
        box-shadow: 0 15px 50px rgba(79, 70, 229, 0.1); overflow: hidden;
    }

    .report-header {
        padding: 40px; position: relative; overflow: hidden;
        display: flex; justify-content: space-between; align-items: center;
    }
    .report-header.h-approuve { background: linear-gradient(135deg, #047857, #10b981); }
    .report-header.h-refuse { background: linear-gradient(135deg, #be123c, #f43f5e); }
    
    .report-header::after {
        content: '\f24e'; font-family: 'Font Awesome 6 Free'; font-weight: 900;
        position: absolute; right: -20px; bottom: -30px; font-size: 150px; color: white; opacity: 0.1;
        transform: rotate(-15deg);
    }

    .report-title h2 { font-family: 'Outfit', sans-serif; font-size: 2.2rem; margin: 0; color: white; line-height: 1.1; }
    .report-title p { color: rgba(255,255,255,0.8); margin: 5px 0 0 0; font-size: 1.1rem; }

    .status-huge {
        background: white; border-radius: 50px; padding: 10px 24px;
        font-weight: 800; font-family: 'Outfit'; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 1px;
    }
    .txt-approuve { color: #047857; }
    .txt-refuse { color: #be123c; }

    .report-body { padding: 40px; }

    .profiles-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    .profile-card { background: #f8fafc; padding: 20px; border-radius: 16px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 15px; }
    
    .avatar-lg { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-weight: 800; color: white; font-family: 'Outfit'; font-size: 1.2rem; }
    .bg-employe { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
    .bg-rh { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }

    .pf-role { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #64748b; letter-spacing: 0.5px; }
    .pf-name { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin-top: 2px; }

    .comment-section { background: rgba(79,70,229,0.05); border-left: 4px solid #4f46e5; padding: 25px; border-radius: 0 16px 16px 0; margin-bottom: 30px; }
    .comment-title { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; color: #4f46e5; letter-spacing: 0.5px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
    .comment-text { color: #334155; font-size: 1.05rem; line-height: 1.6; font-style: italic; }

    .link-conge { display: inline-flex; align-items: center; gap: 10px; background: white; border: 2px solid #e0e7ff; padding: 15px 25px; border-radius: 16px; text-decoration: none; color: #4f46e5; font-weight: 600; width: 100%; transition: all 0.2s; }
    .link-conge:hover { background: #e0e7ff; transform: translateY(-2px); border-color: #c7d2fe; }

    .report-footer { padding: 0 40px 40px 40px; display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed #cbd5e1; padding-top: 30px; margin-top: 10px; }
    
    .btn-edit {
        display: inline-flex; align-items: center; gap: 8px;
        background: linear-gradient(135deg, #4f46e5, #4338ca); color: white; text-decoration: none;
        padding: 12px 24px; border-radius: 50px; font-weight: 600; transition: all 0.3s; box-shadow: 0 4px 15px rgba(79,70,229,0.3);
    }
    .btn-edit:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(79,70,229,0.4); color: white; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 600px) {
        .profiles-grid { grid-template-columns: 1fr; }
        .report-header { flex-direction: column; align-items: flex-start; gap: 20px; padding: 30px; }
        .report-body { padding: 30px; }
        .report-footer { flex-direction: column; gap: 15px; padding: 0 30px 30px 30px; border-top: none; }
        .report-footer > * { width: 100%; text-align: center; justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
{% set isApprouve = (reponse.decision == 'approuvé' or reponse.decision == 'approuve') %}
{% set headClass = isApprouve ? 'h-approuve' : 'h-refuse' %}
{% set txtClass = isApprouve ? 'txt-approuve' : 'txt-refuse' %}

<div class="hr-container">
    <div class="view-wrapper">
        <div class="header-box">
            <a href="{{ path('app_reponse_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Registre RH</a>
        </div>

        <div class="report-card">
            <div class="report-header {{ headClass }}">
                <div class="report-title">
                    <h2>Dossier #{{ reponse.id }}</h2>
                    <p>Décision Officielle RH</p>
                </div>
                <div class="status-huge {{ txtClass }}">
                    {% if isApprouve %}<i class="fas fa-check"></i> Approuvé{% else %}<i class="fas fa-times"></i> Refusé{% endif %}
                </div>
            </div>

            <div class="report-body">
                
                <h3 style="font-family: 'Outfit'; font-size: 1.2rem; color: #0f172a; margin-top: 0; margin-bottom: 20px;">Personnes concernées</h3>
                <div class="profiles-grid">
                    <div class="profile-card">
                        <div class="avatar-lg bg-employe">
                            {% if reponse.employe and reponse.employe.user %}
                                {{ reponse.employe.user.prenom|slice(0,1)|upper }}{{ reponse.employe.user.nom|slice(0,1)|upper }}
                            {% else %}
                                ?
                            {% endif %}
                        </div>
                        <div>
                            <div class="pf-role">Demandeur</div>
                            <div class="pf-name">
                                {% if reponse.employe and reponse.employe.user %}
                                    {{ reponse.employe.user.prenom }} {{ reponse.employe.user.nom }}
                                {% else %}
                                    Non assigné
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    
                    <div class="profile-card">
                        <div class="avatar-lg bg-rh">
                            {% if reponse.rh and reponse.rh.user %}
                                {{ reponse.rh.user.prenom|slice(0,1)|upper }}{{ reponse.rh.user.nom|slice(0,1)|upper }}
                            {% else %}
                                ?
                            {% endif %}
                        </div>
                        <div>
                            <div class="pf-role">Responsable RH</div>
                            <div class="pf-name">
                                {% if reponse.rh and reponse.rh.user %}
                                    {{ reponse.rh.user.prenom }} {{ reponse.rh.user.nom }}
                                {% else %}
                                    Non assigné
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="comment-section">
                    <div class="comment-title"><i class="fas fa-comment-dots"></i> Motif / Justification RH</div>
                    <div class="comment-text">
                        {% if reponse.commentaire %}
                            "{{ reponse.commentaire }}"
                        {% else %}
                            <span style="opacity: 0.6; font-style: normal;">Aucune justification n'a été rédigée pour cette décision.</span>
                        {% endif %}
                    </div>
                </div>

                {% if reponse.congeTt %}
                <a href="{{ path('app_conge_tt_show', {'id': reponse.congeTt.id}) }}" class="link-conge">
                    <div style="background: #e0e7ff; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-file-invoice"></i>
                    </div>
                    <div>
                        <div style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: #64748b;">Voir le congé rattaché</div>
                        <div style="color: #312e81;">Demande n°{{ reponse.congeTt.id }} - {{ reponse.congeTt.typeConge ?? 'Congé' }}</div>
                    </div>
                </a>
                {% endif %}

            </div>

            <div class="report-footer">
                <div>
                    {{ include('reponse/_delete_form.html.twig') }}
                </div>
                
                <a href="{{ path('app_reponse_edit', {'id': reponse.id}) }}" class="btn-edit">
                    <i class="fas fa-pen"></i> Modifier la Décision
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
