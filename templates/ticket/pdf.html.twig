<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Ticket - {{ evenement.titre }}</title>
    <style>
        @page { margin: 0; }
        body { 
            font-family: 'Helvetica', 'Arial', sans-serif; 
            background: #f0f0f0; 
            margin: 0; 
            padding: 40px;
        }
        .outer-container {
            width: 450px;
            margin: 0 auto;
        }
        .ticket-card {
            background: #ffffff;
            border-radius: 30px;
            overflow: hidden;
            position: relative;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        }
        
        /* --- TOP SECTION: IMAGE --- */
        .image-section {
            padding: 15px;
            padding-bottom: 0;
        }
        .image-wrapper {
            width: 100%;
            height: 480px;
            background: #661dbf;
            border-radius: 25px;
            overflow: hidden;
            position: relative;
        }
        .hero-img {
            width: 100%;
            height: 100%;
            display: block;
        }
        .img-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 30px;
            background: linear-gradient(0deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 100%);
            color: #fff;
        }
        .overlay-title {
            font-size: 24px;
            font-weight: 900;
            margin: 0 0 5px 0;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }
        .overlay-date {
            font-size: 14px;
            opacity: 0.9;
            font-weight: bold;
        }

        /* --- SEPARATOR: PERFORATION --- */
        .separator-container {
            height: 40px;
            position: relative;
            margin: 10px 0;
        }
        .notch {
            position: absolute;
            width: 30px;
            height: 30px;
            background: #f0f0f0; /* Matches body background */
            border-radius: 50%;
            top: 5px;
        }
        .notch-left { left: -15px; }
        .notch-right { right: -15px; }
        
        .dashed-line {
            position: absolute;
            top: 19px;
            left: 20px;
            right: 20px;
            border-top: 2px dashed #e0e0e0;
        }

        /* --- BOTTOM SECTION: DETAILS --- */
        .details-section {
            padding: 0 30px 40px 30px;
            text-align: center;
        }
        .brand-logo {
            font-size: 22px;
            font-weight: 800;
            color: #2d3436;
            margin-bottom: 25px;
        }
        .brand-logo span { color: #661dbf; }
        
        .event-main-title {
            color: #661dbf;
            font-size: 26px;
            font-weight: 900;
            margin: 0 0 15px 0;
            text-transform: uppercase;
        }
        .event-location {
            font-size: 14px;
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 25px;
        }
        
        .qr-section {
            margin: 30px 0;
        }
        .qr-img {
            width: 130px;
            height: 130px;
            margin: 0 auto;
            border: 1px solid #eee;
            padding: 5px;
            border-radius: 10px;
        }
        
        .participant-name {
            font-size: 16px;
            font-weight: 700;
            color: #2d3436;
            margin-top: 10px;
        }
        
        .ticket-id {
            background: #661dbf;
            color: #fff;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: bold;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="outer-container">
        <div class="ticket-card">
            <!-- Part 1: Hero Image -->
            <div class="image-section">
                <div class="image-wrapper">
                    {% if eventImage %}
                        <img src="{{ eventImage }}" class="hero-img">
                    {% endif %}
                    <div class="img-overlay">
                        <div class="overlay-title">RHPro Events</div>
                        <div class="overlay-date">{{ formattedDate }}</div>
                    </div>
                </div>
            </div>
            
            <!-- Part 2: Perforation -->
            <div class="separator-container">
                <div class="notch notch-left"></div>
                <div class="notch notch-right"></div>
                <div class="dashed-line"></div>
            </div>
            
            <!-- Part 3: Details -->
            <div class="details-section">
                <div class="brand-logo">RH<span>Pro</span></div>
                
                <h1 class="event-main-title">{{ evenement.titre }}</h1>
                <div class="event-location">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#661dbf" style="vertical-align: middle; margin-right: 4px;">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                    {{ evenement.lieu }}
                </div>
                
                <div class="qr-section">
                    <img src="{{ qrCode }}" class="qr-img">
                </div>
                
                <div class="participant-name">{{ employe.user.fullName|upper }}</div>
                <div class="ticket-id">PASS #{{ participation.id|default('---') }}</div>
            </div>
        </div>
    </div>
</body>
</html>
