<form method="post" action="{{ path('app_demande_service_delete', {'id': demande_service.id}) }}"
      onsubmit="return confirm('Supprimer définitivement cette demande de service ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ demande_service.id) }}">
    <button style="display:inline-flex;align-items:center;gap:8px;border:1.5px solid #fecdd3;background:#fff1f2;cursor:pointer;padding:10px 18px;border-radius:999px;font-weight:900;color:#be123c;font-family:'Outfit',sans-serif;transition:all .18s;"
            onmouseover="this.style.background='#f43f5e';this.style.color='#fff';this.style.borderColor='#f43f5e';"
            onmouseout="this.style.background='#fff1f2';this.style.color='#be123c';this.style.borderColor='#fecdd3';">
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>
