.sm2-chart-box { background:var(--mv-50); border:1.5px solid rgba(143,76,201,.12); border-radius:18px; padding:16px 18px; }
.sm2-chart-label { font-size:.72rem; font-weight:900; text-transform:uppercase; letter-spacing:.09em; color:var(--mv-700); margin-bottom:12px; display:flex; align-items:center; gap:7px; }

/* Progress rate */
.sm2-rate { background:rgba(16,185,129,.07); border:1.5px solid rgba(16,185,129,.2); border-radius:18px; padding:18px 22px; margin-bottom:22px; }
.sm2-rate-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.sm2-rate-lbl  { font-size:.78rem; font-weight:900; text-transform:uppercase; letter-spacing:.09em; color:#059669; }
.sm2-rate-pct  { font-family:'Outfit'; font-weight:900; font-size:1.5rem; color:#0f172a; }
.sm2-bar-track { height:10px; background:rgba(16,185,129,.12); border-radius:999px; overflow:hidden; }
.sm2-bar-fill  { height:100%; border-radius:999px; background:linear-gradient(90deg,#10b981,#059669); transition:width 1.2s cubic-bezier(.16,1,.3,1); width:0%; }

/* Reactions row */
.sm2-react { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:22px; }
.sm2-react-box { border-radius:16px; padding:14px 18px; }
.sm2-react-box-like { background:rgba(16,185,129,.07); border:1.5px solid rgba(16,185,129,.22); }
.sm2-react-box-dis  { background:rgba(244,63,94,.06); border:1.5px solid rgba(244,63,94,.2); }
.sm2-react-lbl { font-size:.7rem; font-weight:900; text-transform:uppercase; letter-spacing:.09em; margin-bottom:6px; display:flex; align-items:center; gap:7px; }
.sm2-react-num { font-family:'Outfit'; font-weight:900; font-size:1.5rem; }

/* Voice report */
.sm2-voice { background:linear-gradient(135deg,rgba(109,40,217,.07),rgba(139,92,246,.04)); border:1.5px solid rgba(109,40,217,.2); border-radius:18px; padding:18px 22px; }
.sm2-voice-row { display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.sm2-voice-info { flex:1; }
.sm2-voice-title { font-family:'Outfit'; font-weight:900; font-size:1.05rem; color:#3b0764; display:flex; align-items:center; gap:8px; }
.sm2-voice-sub { color:#64748b; font-size:.85rem; margin-top:3px; }
.btn-voice {
  display:inline-flex; align-items:center; gap:8px; padding:11px 22px;
  border-radius:999px; border:none; cursor:pointer;
  background:linear-gradient(135deg,#7c3aed,#4c1d95);
  color:#fff; font-weight:900; font-size:.9rem;
  font-family:inherit;
  box-shadow:0 8px 20px rgba(109,40,217,.26);
  transition:transform .2s, box-shadow .2s;
}
.btn-voice:hover { transform:translateY(-2px); box-shadow:0 12px 28px rgba(109,40,217,.36); }
.btn-voice:disabled { opacity:.65; cursor:default; transform:none; }
.sm2-audio-wrap { margin-top:14px; display:none; }
.sm2-audio-wrap audio { width:100%; border-radius:10px; outline:none; }

/* SLA alert */
.sm2-sla { border-radius:16px; padding:14px 18px; margin-bottom:16px; display:flex; align-items:center; gap:14px; }
.sm2-sla-warn { background:rgba(245,158,11,.08); border:1.5px solid rgba(245,158,11,.28); }
.sm2-sla-ok   { background:rgba(16,185,129,.07); border:1.5px solid rgba(16,185,129,.22); }

@media(max-width:640px){
  .sm2-kpis,.sm2-charts,.sm2-react { grid-template-columns:1fr 1fr; }
  .sm2-kpis { grid-template-columns:repeat(2,1fr); }
}
</style>

{# ── Calcul des SLA dépassés (en attente > 7 jours) ── #}
{% set slaDepasses = 0 %}
{% set now = 'now'|date('U') %}
{% for d in demande_services %}
  {% if d.statut == 'En attente' and d.dateDemande %}
    {% set diff = (now - d.dateDemande|date('U')) / 86400 %}
    {% if diff > 7 %}
      {% set slaDepasses = slaDepasses + 1 %}
    {% endif %}
  {% endif %}
{% endfor %}

{# ── Totaux réactions ── #}
{% set totalLikes = 0 %}
{% set totalDislikes = 0 %}
{% if countsMap is defined %}
  {% for id, c in countsMap %}
    {% set totalLikes    = totalLikes    + c.likes %}
    {% set totalDislikes = totalDislikes + c.dislikes %}
  {% endfor %}
{% endif %}

<div id="statsSvcModal" class="sm2" role="dialog" aria-modal="true">
  <div class="sm2-box">

    {# Header #}
    <div class="sm2-top">
      <div>
        <div class="sm2-title"><i class="fas fa-chart-pie"></i> Tableau de bord Services</div>
        <div class="sm2-sub">Analyse complète • {{ total }} demande{{ total > 1 ? 's' : '' }} au total</div>
      </div>
      <button class="sm2-close" id="sm2CloseBtn" aria-label="Fermer">
        <i class="fas fa-xmark"></i>
      </button>
    </div>

    {# Body #}
    <div class="sm2-body">

      {# ── KPIs #}
      <div class="sm2-kpis">
        <div class="sm2-kpi" style="background:linear-gradient(135deg,rgba(143,76,201,.1),rgba(179,157,219,.06));border:1.5px solid rgba(143,76,201,.2);">
          <div class="sm2-kpi-ic" style="background:linear-gradient(135deg,var(--mv-700),var(--mv-600));box-shadow:0 6px 16px var(--mv-glow);"><i class="fas fa-layer-group"></i></div>
          <div><div class="sm2-kpi-val">{{ total }}</div><div class="sm2-kpi-lbl" style="color:var(--mv-800);">Total</div></div>
        </div>
        <div class="sm2-kpi" style="background:#fffbeb;border:1.5px solid #fde68a;">
          <div class="sm2-kpi-ic" style="background:linear-gradient(135deg,#f59e0b,#d97706);box-shadow:0 6px 16px rgba(245,158,11,.24);"><i class="fas fa-hourglass-half"></i></div>
          <div><div class="sm2-kpi-val">{{ pending }}</div><div class="sm2-kpi-lbl" style="color:#92400e;">En attente</div></div>
        </div>
        <div class="sm2-kpi" style="background:#ecfdf5;border:1.5px solid #a7f3d0;">
          <div class="sm2-kpi-ic" style="background:linear-gradient(135deg,#10b981,#059669);box-shadow:0 6px 16px rgba(16,185,129,.24);"><i class="fas fa-check-double"></i></div>
          <div><div class="sm2-kpi-val">{{ accepted }}</div><div class="sm2-kpi-lbl" style="color:#065f46;">Acceptées</div></div>
        </div>
        <div class="sm2-kpi" style="background:#fff1f2;border:1.5px solid #fecdd3;">
          <div class="sm2-kpi-ic" style="background:linear-gradient(135deg,#f43f5e,#e11d48);box-shadow:0 6px 16px rgba(244,63,94,.22);"><i class="fas fa-ban"></i></div>
          <div><div class="sm2-kpi-val">{{ rejected }}</div><div class="sm2-kpi-lbl" style="color:#9f1239;">Refusées</div></div>
        </div>
      </div>

      {# ── Rapport vocal (toujours visible pour debug) #}
      <div class="sm2-voice">
        <div class="sm2-voice-row">
          <div class="sm2-voice-info">
            <div class="sm2-voice-title"><i class="fas fa-waveform-lines"></i> Rapport vocal RH</div>
            <div class="sm2-voice-sub">Synthèse vocale du navigateur (Web Speech API) - Gratuit et illimité</div>
          </div>
          <button type="button" class="btn-voice" id="btnVoiceReport">
            <i class="fas fa-volume-high" id="btnVoiceIcon"></i>
            <span id="btnVoiceTxt">🎤 Écouter le rapport</span>
          </button>
        </div>
        <div class="sm2-audio-wrap" id="sm2AudioWrap">
          <audio id="sm2AudioPlayer" controls style="width:100%;border-radius:12px;"></audio>
          <div style="font-size:.75rem;color:#64748b;margin-top:6px;text-align:center;">
            <i class="fas fa-info-circle"></i> Rapport généré le {{ 'now'|date('d/m/Y à H:i') }}
          </div>
        </div>
      </div>

      {# ── SLA Alert #}
      {% if slaDepasses > 0 %}
      <div class="sm2-sla sm2-sla-warn">
        <div style="width:38px;height:38px;border-radius:12px;background:rgba(245,158,11,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="fas fa-exclamation-triangle" style="color:#d97706;"></i>
        </div>
        <div>
          <div style="font-weight:900;color:#92400e;">{{ slaDepasses }} demande{{ slaDepasses > 1 ? 's' : '' }} en retard SLA</div>
          <div style="font-size:.82rem;color:#b45309;">En attente depuis plus de 7 jours — action requise</div>
        </div>
      </div>
      {% else %}
      <div class="sm2-sla sm2-sla-ok">
        <div style="width:38px;height:38px;border-radius:12px;background:rgba(16,185,129,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="fas fa-shield-check" style="color:#059669;"></i>
        </div>
        <div>
          <div style="font-weight:900;color:#065f46;">Aucun retard SLA détecté</div>
          <div style="font-size:.82rem;color:#047857;">Toutes les demandes sont traitées dans les délais</div>
        </div>
      </div>
      {% endif %}

      {# ── Graphiques #}
      <div class="sm2-charts">
        <div class="sm2-chart-box">
          <div class="sm2-chart-label"><i class="fas fa-chart-pie"></i> Répartition par statut</div>
          <canvas id="sm2DonutChart" width="220" height="220"></canvas>
        </div>
        <div class="sm2-chart-box">
          <div class="sm2-chart-label"><i class="fas fa-chart-bar"></i> Top types de service</div>
          <canvas id="sm2BarChart" height="220"></canvas>
        </div>
      </div>

      {# ── Taux de résolution #}
      <div class="sm2-rate">
        <div class="sm2-rate-row">
          <div>
            <div class="sm2-rate-lbl"><i class="fas fa-bullseye"></i> Taux de résolution</div>
            <div style="font-size:.78rem;color:#64748b;margin-top:2px;">Demandes traitées (acceptées + refusées) / total</div>
          </div>
          <div class="sm2-rate-pct" id="sm2RatePct">{{ tauxRes }}%</div>
        </div>
        <div class="sm2-bar-track">
          <div class="sm2-bar-fill" id="sm2RateBar" style="width:0%;"></div>
        </div>
      </div>

      {# ── Réactions like/dislike #}
      {% if totalLikes + totalDislikes > 0 %}
      <div class="sm2-react">
        <div class="sm2-react-box sm2-react-box-like">
          <div class="sm2-react-lbl" style="color:#059669;"><i class="fas fa-thumbs-up"></i> J'aime</div>
          <div class="sm2-react-num" style="color:#059669;">{{ totalLikes }}</div>
          {% if totalLikes + totalDislikes > 0 %}
          <div style="font-size:.75rem;color:#065f46;margin-top:4px;">{{ ((totalLikes / (totalLikes + totalDislikes)) * 100)|round }}% satisfaction</div>
          {% endif %}
        </div>
        <div class="sm2-react-box sm2-react-box-dis">
          <div class="sm2-react-lbl" style="color:#be123c;"><i class="fas fa-thumbs-down"></i> Je n'aime pas</div>
          <div class="sm2-react-num" style="color:#be123c;">{{ totalDislikes }}</div>
          <div style="font-size:.75rem;color:#9f1239;margin-top:4px;">{{ totalLikes + totalDislikes }} réaction{{ (totalLikes + totalDislikes) > 1 ? 's' : '' }} au total</div>
        </div>
      </div>
      {% endif %}

    </div>{# /sm2-body #}
  </div>{# /sm2-box #}
</div>{# /statsSvcModal #}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function(){
  // ── Donut statuts
  var p = {{ pending }};
  var a = {{ accepted }};
  var r = {{ rejected }};
  var t = p + a + r;

  // Top types data (depuis Twig)
  var typeCountRaw = {{ typeCountRaw|json_encode|raw }};
  var topLabels = Object.keys(typeCountRaw);
  var topData   = Object.values(typeCountRaw);

  // Trier par valeur décroissante, garder top 5
  var combined = topLabels.map(function(l,i){ return {l:l,v:topData[i]}; });
  combined.sort(function(a,b){ return b.v - a.v; });
  combined = combined.slice(0,5);
  topLabels = combined.map(function(x){ return x.l; });
  topData   = combined.map(function(x){ return x.v; });

  // ══ Modal open / close
  var modal    = document.getElementById('statsSvcModal');
  var closeBtn = document.getElementById('sm2CloseBtn');

  // Ouvrir le modal — on enregistre les listeners AVANT le check modal
  var openBtns = document.querySelectorAll('[onclick*="statsSvcModal"]');
  openBtns.forEach(function(b){
    b.removeAttribute('onclick');
    b.addEventListener('click', function(){ if (modal) openModal(); });
  });

  if (!modal) return;

  function openModal(){
    modal.style.display = 'flex';
    // Animer la barre de taux de résolution
    var bar = document.getElementById('sm2RateBar');
    if (bar) setTimeout(function(){ bar.style.width = '{{ tauxRes }}%'; }, 100);
    // Initialiser les charts (une seule fois)
    initCharts();
  }
  function closeModal(){ modal.style.display = 'none'; }
  if (closeBtn)  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });

  // ══ Charts init
  var chartsInited = false;
  function initCharts(){
    if (chartsInited) return;
    chartsInited = true;

    // Donut
    var donutCtx = document.getElementById('sm2DonutChart');
    if (donutCtx) {
      new Chart(donutCtx.getContext('2d'), {
        type: 'doughnut',
        data: {
          labels: ['En attente','Acceptées','Refusées'],
          datasets:[{
            data: [p, a, r],
            backgroundColor: ['#f59e0b','#10b981','#f43f5e'],
            borderColor: ['#fff','#fff','#fff'],
            borderWidth: 3,
            hoverOffset: 14
          }]
        },
        options: {
          cutout: '68%',
          animation: { animateRotate:true, duration:900 },
          plugins: {
            legend: { display:true, position:'bottom', labels:{ font:{size:11}, boxWidth:12 } },
            tooltip: { callbacks: { label: function(c){ var pct=t>0?Math.round(c.parsed/t*100):0; return ' '+c.raw+' ('+pct+'%)'; } } }
          }
        }
      });
    }

    // Bar chart
    var barCtx = document.getElementById('sm2BarChart');
    if (barCtx && topLabels.length > 0) {
      var palette = [
        'rgba(143,76,201,.85)','rgba(245,158,11,.85)','rgba(16,185,129,.85)',
        'rgba(244,63,94,.85)','rgba(59,130,246,.85)'
      ];
      new Chart(barCtx.getContext('2d'), {
        type: 'bar',
        data: {
          labels: topLabels,
          datasets:[{
            label: 'Demandes',
            data: topData,
            backgroundColor: palette.slice(0, topLabels.length),
            borderRadius: 8,
            borderSkipped: false,
          }]
        },
        options: {
          indexAxis: 'y',
          scales: {
            x: { ticks:{ stepSize:1 }, grid:{ color:'rgba(0,0,0,.04)' } },
            y: { grid:{ display:false }, ticks:{ font:{size:11} } }
          },
          plugins: {
            legend: { display:false },
            tooltip: { callbacks: { label: function(c){ return ' '+c.parsed.x+' demande'+(c.parsed.x>1?'s':''); } } }
          },
          animation: { duration:800 }
        }
      });
    } else if (barCtx) {
      barCtx.parentElement.innerHTML +=
        '<p style="text-align:center;color:#94a3b8;font-size:.85rem;margin-top:30px;">Aucune donnée disponible</p>';
    }
  }

  // ══ Rapport vocal — ElevenLabs avec fallback speechSynthesis
  var btnVoice   = document.getElementById('btnVoiceReport');
  var btnIcon    = document.getElementById('btnVoiceIcon');
  var btnTxt     = document.getElementById('btnVoiceTxt');
  var audioWrap  = document.getElementById('sm2AudioWrap');
  var audioEl    = document.getElementById('sm2AudioPlayer');
  var VOCAL_URL  = '{{ path("app_demande_service_rapport_vocal") }}';
  var RAPPORT_TEXTE = {{ rapportTexte is defined ? rapportTexte|json_encode|raw : '""' }};

  // ── Fallback : synthèse vocale navigateur avec chunking ──
  function lireAvecNavigateur() {
    if (!window.speechSynthesis) {
      btnIcon.className = 'fas fa-exclamation-triangle';
      btnTxt.textContent = 'Synthèse vocale non supportée';
      return;
    }
    
    // IMPORTANT: Arrêter TOUTE synthèse en cours
    window.speechSynthesis.cancel();
    
    // Attendre que le cancel soit effectif
    setTimeout(function() {
      // Si le texte est vide, construire un résumé depuis les données de la page
      var texte = RAPPORT_TEXTE;
      if (!texte || texte.trim() === '') {
        var tx = (p + a + r) > 0 ? Math.round((a + r) / (p + a + r) * 100) : 0;
        texte = 'Bonjour. Voici le rapport analytique des demandes de service RH. '
          + 'Au total, ' + (p + a + r) + ' demandes ont été enregistrées. '
          + a + ' demandes ont été acceptées, '
          + r + ' demandes ont été refusées, '
          + 'et ' + p + ' demandes sont encore en attente de traitement. '
          + 'Le taux de résolution est de ' + tx + ' pour cent. '
          + 'Merci de votre attention.';
      }

      // Nettoyer le texte
      texte = texte
        .replace(/[^\wÀ-ÿ\s\.,!?;:'-]/gu, ' ')
        .replace(/\s+/g, ' ')
        .replace(/pourcent/g, 'pour cent')
        .trim();

      // SOLUTION: Diviser en phrases courtes (max 80 caractères par chunk)
      var sentences = texte.split(/\.\s+/);
      var chunks = [];
      var currentChunk = '';
      
      for (var i = 0; i < sentences.length; i++) {
        var sentence = sentences[i].trim();
        if (!sentence) continue;
        
        // Ajouter le point final si manquant
        if (!sentence.endsWith('.')) {
          sentence += '.';
        }
        
        // Si ajouter cette phrase dépasse 80 chars, créer un nouveau chunk
        if (currentChunk.length + sentence.length > 80) {
          if (currentChunk) {
            chunks.push(currentChunk.trim());
          }
          currentChunk = sentence + ' ';
        } else {
          currentChunk += sentence + ' ';
        }
      }
      
      // Ajouter le dernier chunk
      if (currentChunk.trim()) {
        chunks.push(currentChunk.trim());
      }
      
      // Limiter à 5 chunks maximum pour ne pas être trop long
      if (chunks.length > 5) {
        chunks = chunks.slice(0, 5);
        chunks[4] = chunks[4] + ' Fin du rapport.';
      }
      
      console.log('[Vocal] 📝 Texte divisé en', chunks.length, 'chunks');
      chunks.forEach(function(chunk, idx) {
        console.log('[Vocal] Chunk', idx + 1, ':', chunk.substring(0, 50) + '...');
      });

      // Fonction pour parler chunk par chunk
      var currentChunkIndex = 0;
      var voices = [];
      var selectedVoice = null;
      
      function speakNextChunk() {
        if (currentChunkIndex >= chunks.length) {
          console.log('[Vocal] ✅ Tous les chunks terminés');
          btnIcon.className = 'fas fa-volume-high';
          btnTxt.textContent = '🎤 Rejouer';
          btnVoice.disabled = false;
          _synthPaused = false;
          return;
        }
        
        var chunk = chunks[currentChunkIndex];
        console.log('[Vocal] 🎤 Speaking chunk', currentChunkIndex + 1, '/', chunks.length);
        
        var utter = new SpeechSynthesisUtterance(chunk);
        utter.lang = 'fr-FR';
        utter.rate = 0.9;
        utter.pitch = 1.0;
        utter.volume = 1.0;
        
        // Utiliser la voix sélectionnée
        if (selectedVoice) {
          utter.voice = selectedVoice;
        }
        
        utter.onstart = function() {
          if (currentChunkIndex === 0) {
            console.log('[Vocal] ✅ Synthèse démarrée');
            btnIcon.className = 'fas fa-volume-high';
            btnTxt.textContent = '⏸ Pause (' + (currentChunkIndex + 1) + '/' + chunks.length + ')';
            btnVoice.disabled = false;
          }
        };
        
        utter.onend = function() {
          console.log('[Vocal] ✅ Chunk', currentChunkIndex + 1, 'terminé');
          currentChunkIndex++;
          // Petit délai entre les chunks pour éviter les problèmes
          setTimeout(speakNextChunk, 200);
        };
        
        utter.onerror = function(e) {
          console.error('[Vocal] ❌ Erreur chunk', currentChunkIndex + 1, ':', e.error);
          
          // Si synthesis-failed, essayer un message ultra-simple
          if (e.error === 'synthesis-failed' && currentChunkIndex === 0) {
            console.log('[Vocal] 🔄 Fallback vers message simple');
            window.speechSynthesis.cancel();
            
            setTimeout(function() {
              var simpleMsg = 'Rapport vocal. ' + (p + a + r) + ' demandes. ' 
                            + a + ' acceptées. ' + r + ' refusées.';
              var simpleUtter = new SpeechSynthesisUtterance(simpleMsg);
              simpleUtter.lang = 'fr-FR';
              simpleUtter.rate = 0.9;
              
              simpleUtter.onstart = function() {
                btnIcon.className = 'fas fa-volume-high';
                btnTxt.textContent = '⏸ Pause';
                btnVoice.disabled = false;
              };
              
              simpleUtter.onend = function() {
                btnIcon.className = 'fas fa-volume-high';
                btnTxt.textContent = '🎤 Rejouer';
                btnVoice.disabled = false;
              };
              
              simpleUtter.onerror = function() {
                btnIcon.className = 'fas fa-exclamation-triangle';
                btnTxt.textContent = 'Synthèse indisponible';
                btnVoice.disabled = false;
              };
              
              window.speechSynthesis.speak(simpleUtter);
            }, 500);
          } else {
            // Passer au chunk suivant en cas d'erreur
            currentChunkIndex++;
            setTimeout(speakNextChunk, 200);
          }
        };
        
        try {
          window.speechSynthesis.speak(utter);
        } catch (err) {
          console.error('[Vocal] ❌ Exception:', err);
          currentChunkIndex++;
          setTimeout(speakNextChunk, 200);
        }
      }
      
      // Charger les voix et démarrer
      function startSpeaking() {
        voices = window.speechSynthesis.getVoices();
        console.log('[Vocal] Voix disponibles:', voices.length);
        
        if (voices.length === 0) {
          console.warn('[Vocal] ⚠️ Aucune voix disponible!');
          btnIcon.className = 'fas fa-exclamation-triangle';
          btnTxt.textContent = 'Aucune voix disponible';
          btnVoice.disabled = false;
          return;
        }
        
        // Choisir une voix française (éviter Google)
        var voixFr = voices.filter(function(v) { return v.lang.startsWith('fr'); });
        console.log('[Vocal] Voix françaises:', voixFr.length);
        
        selectedVoice = voixFr.find(function(v) { 
          return !v.name.toLowerCase().includes('google'); 
        }) || voixFr[0] || voices[0];
        
        if (selectedVoice) {
          console.log('[Vocal] Voix sélectionnée:', selectedVoice.name);
        }
        
        btnIcon.className = 'fas fa-spinner fa-spin';
        btnTxt.textContent = 'Démarrage...';
        
        // Démarrer la lecture des chunks
        setTimeout(speakNextChunk, 100);
      }
      
      // Vérifier si les voix sont chargées
      var loadedVoices = window.speechSynthesis.getVoices();
      if (loadedVoices.length > 0) {
        startSpeaking();
      } else {
        var voicesLoaded = false;
        window.speechSynthesis.onvoiceschanged = function() {
          if (!voicesLoaded) {
            voicesLoaded = true;
            startSpeaking();
          }
        };
        
        // Timeout de sécurité
        setTimeout(function() {
          if (!voicesLoaded) {
            voicesLoaded = true;
            startSpeaking();
          }
        }, 2000);
      }
    }, 300);
  }

  var _synthPaused = false;
  var _audioLoaded = false;

  if (btnVoice) {
    btnVoice.addEventListener('click', function(){
      if (btnVoice.disabled) return;

      // Si un audio ElevenLabs est en cours, le contrôler
      if (audioEl && _audioLoaded && !audioEl.paused) {
        audioEl.pause();
        btnIcon.className = 'fas fa-play';
        btnTxt.textContent = '▶ Reprendre';
        return;
      }

      if (audioEl && _audioLoaded && audioEl.paused) {
        audioEl.play();
        btnIcon.className = 'fas fa-volume-high';
        btnTxt.textContent = '⏸ Pause';
        return;
      }

      // Si speechSynthesis est actif, basculer pause/reprise
      if (window.speechSynthesis && window.speechSynthesis.speaking) {
        if (_synthPaused) { 
          window.speechSynthesis.resume(); 
          _synthPaused = false; 
          btnTxt.textContent = '⏸ Pause'; 
        } else { 
          window.speechSynthesis.pause();  
          _synthPaused = true;  
          btnTxt.textContent = '▶ Reprendre'; 
        }
        return;
      }

      // Utiliser ElevenLabs API (haute qualité, voix professionnelle)
      console.log('[Vocal] 🎤 Utilisation de ElevenLabs API');
      btnVoice.disabled = true;
      btnIcon.className = 'fas fa-spinner fa-spin';
      btnTxt.textContent = 'Génération audio...';
      
      // Appeler l'endpoint ElevenLabs
      fetch(VOCAL_URL)
        .then(function(response) {
          if (!response.ok) {
            throw new Error('Erreur HTTP ' + response.status);
          }
          return response.blob();
        })
        .then(function(blob) {
          console.log('[Vocal] ✅ Audio reçu:', blob.size, 'bytes');
          
          // Créer une URL pour le blob audio
          var audioUrl = URL.createObjectURL(blob);
          audioEl.src = audioUrl;
          _audioLoaded = true;
          
          // Configurer les événements audio
          audioEl.onplay = function() {
            btnIcon.className = 'fas fa-volume-high';
            btnTxt.textContent = '⏸ Pause';
            btnVoice.disabled = false;
          };
          
          audioEl.onpause = function() {
            btnIcon.className = 'fas fa-play';
            btnTxt.textContent = '▶ Reprendre';
          };
          
          audioEl.onended = function() {
            btnIcon.className = 'fas fa-volume-high';
            btnTxt.textContent = '🎤 Rejouer';
            btnVoice.disabled = false;
          };
          
          audioEl.onerror = function(e) {
            console.error('[Vocal] ❌ Erreur lecture audio:', e);
            btnIcon.className = 'fas fa-exclamation-triangle';
            btnTxt.textContent = 'Erreur lecture';
            btnVoice.disabled = false;
            
            // Fallback vers Web Speech API
            console.log('[Vocal] 🔄 Fallback vers Web Speech API');
            lireAvecNavigateur();
          };
          
          // Lancer la lecture
          audioEl.play()
            .then(function() {
              console.log('[Vocal] ✅ Lecture démarrée');
            })
            .catch(function(error) {
              console.error('[Vocal] ❌ Erreur play():', error);
              btnIcon.className = 'fas fa-exclamation-triangle';
              btnTxt.textContent = 'Erreur lecture';
              btnVoice.disabled = false;
              
              // Fallback vers Web Speech API
              console.log('[Vocal] 🔄 Fallback vers Web Speech API');
              lireAvecNavigateur();
            });
        })
        .catch(function(error) {
          console.error('[Vocal] ❌ Erreur ElevenLabs:', error);
          btnIcon.className = 'fas fa-exclamation-triangle';
          btnTxt.textContent = 'Erreur API';
          btnVoice.disabled = false;
          
          // Fallback vers Web Speech API
          console.log('[Vocal] 🔄 Fallback vers Web Speech API');
          lireAvecNavigateur();
        });
    });

    // Charger les voix dès que disponibles (Chrome les charge en async)
    if (window.speechSynthesis) {
      // Forcer le chargement des voix
      window.speechSynthesis.getVoices();
      
      // Gestionnaire pour le chargement des voix
      var voicesLoaded = false;
      window.speechSynthesis.onvoiceschanged = function() {
        if (!voicesLoaded) {
          voicesLoaded = true;
          var voices = window.speechSynthesis.getVoices();
          console.log('[Vocal] Voix chargées:', voices.length);
        }
      };
      
      // Timeout pour forcer le chargement si nécessaire
      setTimeout(function() {
        if (!voicesLoaded) {
          window.speechSynthesis.getVoices();
        }
      }, 1000);
    }
  }
})();
</script>

{# ══════ AJAX SEARCH — VUE RH SERVICES ══════ #}
<script>
(function () {
  var form = document.getElementById('rh-svc-form');
  if (!form) return;

  var searchUrl  = form.getAttribute('data-search-url');
  var input      = form.querySelector('input[name="search"]');
  var selBy      = form.querySelector('select[name="searchBy"]');
  var selSort    = form.querySelector('select[name="sortBy"]');
  var dirInput   = document.getElementById('rh-svc-sort-dir');
  var tbody      = document.getElementById('rh-svc-tbody');
  var emptySearch = document.getElementById('rh-svc-empty-search');
  var emptyData   = document.getElementById('rh-svc-empty-data');

  if (!tbody) return;

  var repondreBase = '{{ path("app_demande_service_repondre", {"id": "__ID__"}) }}';
  var showBase     = '{{ path("app_demande_service_show",     {"id": "__ID__"}) }}';

  function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function buildPill(st) {
    if (st === 'Accepté' || st === 'approuvé') return '<span class="pill p-ok">Accepté</span>';
    if (st === 'Refusé'  || st === 'refusé')   return '<span class="pill p-no">Refusé</span>';
    return '<span class="pill p-pend">En attente</span>';
  }

  function buildRow(r, idx) {
    var isPend = (r.statut === 'En attente');
    var nom = (r.prenom || r.nom)
      ? '<div class="who"><div class="av av-em">' + escHtml((r.prenom||'').charAt(0).toUpperCase() + (r.nom||'').charAt(0).toUpperCase()) + '</div>'
        + '<div><div class="nm">' + escHtml((r.prenom||'') + ' ' + (r.nom||'')) + '</div><div class="sb">Employé</div></div></div>'
      : '<span style="color:#94a3b8;">Non défini</span>';

    var actionUrl = repondreBase.replace('__ID__', r.id);
    var showUrl   = showBase.replace('__ID__', r.id);

    var actions = isPend
      ? '<button type="button" class="btn-dec btn-ok" data-bs-toggle="modal" data-bs-target="#rhDecisionModal"'
          + ' data-id="' + r.id + '" data-decision="approuvé"'
          + ' data-type="' + escHtml(r.typeNom || 'Service') + '"'
          + ' data-action="' + actionUrl + '">'
          + '<i class="fas fa-check"></i> Accepter</button>'
        + '<button type="button" class="btn-dec btn-no" data-bs-toggle="modal" data-bs-target="#rhDecisionModal"'
          + ' data-id="' + r.id + '" data-decision="refusé"'
          + ' data-type="' + escHtml(r.typeNom || 'Service') + '"'
          + ' data-action="' + actionUrl + '">'
          + '<i class="fas fa-times"></i> Refuser</button>'
      : '<span style="color:#94a3b8;font-weight:800;font-size:.88rem;">Décision prise</span>';

    var tr = document.createElement('tr');
    tr.style.animation = 'slideUp .3s cubic-bezier(.16,1,.3,1) ' + (idx * 0.04) + 's both';
    tr.innerHTML =
      '<td>' + nom + '</td>' +
      '<td style="font-weight:800;color:#0f172a;">' + escHtml(r.typeNom || '—') + '</td>' +
      '<td style="color:#64748b;font-weight:700;">' + escHtml(r.date || '—') + '</td>' +
      '<td>' + buildPill(r.statut) + '</td>' +
      '<td><div class="act">' +
        '<a class="btn-ghost" href="' + showUrl + '" title="Voir"><i class="fas fa-eye"></i></a>' +
        actions +
      '</div></td>';
    return tr;
  }

  function renderRows(rows) {
    tbody.innerHTML = '';
    if (rows.length === 0) {
      if (emptySearch) emptySearch.style.display = '';
      if (emptyData)   emptyData.style.display   = 'none';
    } else {
      if (emptySearch) emptySearch.style.display = 'none';
      if (emptyData)   emptyData.style.display   = 'none';
      rows.forEach(function (r, i) {
        tbody.appendChild(buildRow(r, i));
        // Rebind modal trigger events after DOM insert
      });
      // Re-attach modal data handlers for newly created buttons
      tbody.querySelectorAll('[data-bs-target="#rhDecisionModal"]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var dec  = btn.getAttribute('data-decision');
          var type = btn.getAttribute('data-type');
          var act  = btn.getAttribute('data-action');
          var titleEl    = document.getElementById('rhDecisionTitle');
          var subtitleEl = document.getElementById('rhDecisionSubtitle');
          var valueEl    = document.getElementById('rhDecisionValue');
          var submitEl   = document.getElementById('rhDecisionSubmit');
          var formEl     = document.getElementById('rhDecisionForm');
          if (titleEl)    titleEl.textContent    = (dec === 'approuvé' ? '✅ Approuver' : '❌ Refuser') + ' — ' + type;
          if (subtitleEl) subtitleEl.textContent = dec === 'approuvé' ? 'Cette demande sera marquée comme acceptée.' : 'Cette demande sera marquée comme refusée.';
          if (valueEl)    valueEl.value          = dec;
          if (submitEl)   { submitEl.textContent = dec === 'approuvé' ? 'Confirmer l\'approbation' : 'Confirmer le refus'; submitEl.style.background = dec === 'approuvé' ? 'linear-gradient(135deg,#10b981,#059669)' : 'linear-gradient(135deg,#f43f5e,#e11d48)'; submitEl.style.color = '#fff'; }
          if (formEl)     formEl.action = act;
        });
      });
    }
  }

  var _timer = null;
  function doSearch(immediate) {
    clearTimeout(_timer);
    _timer = setTimeout(function () {
      var params = new URLSearchParams({
        search:   input   ? input.value   : '',
        searchBy: selBy   ? selBy.value   : 'all',
        sortBy:   selSort ? selSort.value : 'dateDemande',
        sortDir:  dirInput ? dirInput.value : 'desc',
      });
      fetch(searchUrl + '?' + params.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function (data) { renderRows(data.rows || []); })
      .catch(function (err) { console.error('[AJAX RH Services]', err); });
    }, immediate ? 0 : 350);
  }

  if (input)   input.addEventListener('input',   function () { doSearch(false); });
  if (selBy)   selBy.addEventListener('change',  function () { doSearch(true); });
  if (selSort) selSort.addEventListener('change', function () { doSearch(true); });

  var dirBtn = form.querySelector('.btn-dir-rh');
  if (dirBtn && dirInput) {
    dirBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var cur = dirInput.value === 'asc' ? 'desc' : 'asc';
      dirInput.value = cur;
      dirBtn.innerHTML = cur === 'asc'
        ? '<i class="fas fa-arrow-up-a-z"></i> Croissant'
        : '<i class="fas fa-arrow-down-z-a"></i> Décroissant';
      doSearch(true);
    });
  }

  form.addEventListener('submit', function (e) { e.preventDefault(); doSearch(true); });

  var resetLink = form.querySelector('.btn-reset');
  if (resetLink) {
    resetLink.addEventListener('click', function (e) {
      e.preventDefault();
      if (input)    input.value    = '';
      if (selBy)    selBy.value    = 'all';
      if (selSort)  selSort.value  = 'dateDemande';
      if (dirInput) dirInput.value = 'desc';
      doSearch(true);
    });
  }

  // Chargement initial
  doSearch(true);
})();
</script>

{# ══════ AJAX SEARCH — VUE EMPLOYÉ SERVICES ══════ #}
<script>
(function () {
  var form = document.getElementById('em-svc-form');
  if (!form) return;

  var searchUrl  = form.getAttribute('data-search-url');
  var input      = form.querySelector('input[name="search"]');
  var selBy      = form.querySelector('select[name="searchBy"]');
  var selSort    = form.querySelector('select[name="sortBy"]');
  var dirInput   = document.getElementById('em-svc-sort-dir');
  var tbody      = document.getElementById('em-svc-tbody');
  var countNum   = document.getElementById('em-svc-count-num');
  var countBox   = document.getElementById('em-svc-count');
  var emptySearch = document.getElementById('em-svc-empty-search');
  var emptyData   = document.getElementById('em-svc-empty-data');

  if (!tbody) return;

  function setLoading(on) {
    tbody.style.opacity = on ? '0.4' : '1';
    tbody.style.pointerEvents = on ? 'none' : '';
  }

  function escHtml(s) {
    return String(s || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function buildPill(statut) {
    var ok = (statut === 'Accepté' || statut === 'approuvé');
    var no = (statut === 'Refusé'  || statut === 'refusé');
    if (ok) return '<span class="pill p-ok">Accepté</span>';
    if (no) return '<span class="pill p-no">Refusé</span>';
    return '<span class="pill p-pend">En attente</span>';
  }

  function buildRow(r, idx) {
    var nom = (r.prenom || r.nom)
      ? escHtml((r.prenom || '') + ' ' + (r.nom || '')).trim()
      : '<span style="color:#94a3b8">—</span>';

    var editBtn = (r.statut === 'En attente')
      ? '<a class="btn-ghost btn-ghost-em" href="' + r.editUrl + '" title="Modifier"><i class="fas fa-pen"></i></a>'
      : '';

    var tr = document.createElement('tr');
    tr.style.animation = 'slideUp .3s cubic-bezier(.16,1,.3,1) ' + (idx * 0.04) + 's both';
    tr.innerHTML =
      '<td style="font-weight:800;">' + nom + '</td>' +
      '<td style="font-weight:800;color:#0f172a;">' + escHtml(r.typeNom || '—') + '</td>' +
      '<td style="color:#64748b;font-weight:700;">' + escHtml(r.date || '—') + '</td>' +
      '<td>' + buildPill(r.statut) + '</td>' +
      '<td><div class="act">' +
        '<a class="btn-ghost btn-ghost-em" href="' + r.showUrl + '" title="Voir"><i class="fas fa-eye"></i></a>' +
        editBtn +
      '</div></td>';
    return tr;
  }

  function renderRows(rows) {
    tbody.innerHTML = '';
    if (rows.length === 0) {
      if (emptySearch) emptySearch.style.display = '';
      if (emptyData)   emptyData.style.display   = 'none';
      if (countBox)    countBox.style.display     = 'none';
    } else {
      if (emptySearch) emptySearch.style.display = 'none';
      if (emptyData)   emptyData.style.display   = 'none';
      if (countBox)    countBox.style.display     = '';
      rows.forEach(function (r, i) { tbody.appendChild(buildRow(r, i)); });
    }
    if (countNum) countNum.textContent = rows.length;
  }

  var _timer = null;
  function doSearch(immediate) {
    clearTimeout(_timer);
    _timer = setTimeout(function () {
      var params = new URLSearchParams({
        search:   input   ? input.value    : '',
        searchBy: selBy   ? selBy.value    : 'all',
        sortBy:   selSort ? selSort.value  : 'dateDemande',
        sortDir:  dirInput ? dirInput.value : 'desc',
      });
      setLoading(true);
      fetch(searchUrl + '?' + params.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      })
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function (data) { setLoading(false); renderRows(data.rows || []); })
      .catch(function (err) { setLoading(false); console.error('[AJAX Services]', err); });
    }, immediate ? 0 : 350);
  }

  if (input) input.addEventListener('input', function () { doSearch(false); });
  if (selBy)   selBy.addEventListener('change',  function () { doSearch(true); });
  if (selSort) selSort.addEventListener('change', function () { doSearch(true); });

  var dirBtn = form.querySelector('.btn-dir-em');
  if (dirBtn && dirInput) {
    dirBtn.addEventListener('click', function (e) {
      e.preventDefault();
      var cur = dirInput.value === 'asc' ? 'desc' : 'asc';
      dirInput.value = cur;
      dirBtn.innerHTML = cur === 'asc'
        ? '<i class="fas fa-arrow-up-a-z"></i> Croissant'
        : '<i class="fas fa-arrow-down-z-a"></i> Décroissant';
      doSearch(true);
    });
  }

  form.addEventListener('submit', function (e) { e.preventDefault(); doSearch(true); });

  var resetLink = form.querySelector('.btn-reset');
  if (resetLink) {
    resetLink.addEventListener('click', function (e) {
      e.preventDefault();
      if (input)    input.value    = '';
      if (selBy)    selBy.value    = 'all';
      if (selSort)  selSort.value  = 'dateDemande';
      if (dirInput) dirInput.value = 'desc';
      doSearch(true);
    });
  }
})();
</script>

{# ══════ LIKE / DISLIKE AJAX ══════ #}
<script>
(function () {
  var CSRF = document.querySelector('meta[name="csrf-token"]');
  var reactBase = '{{ path("app_demande_service_react", {"typeId": 0, "reaction": "like"}) }}';
  // remplace /react/0/like par /react/{id}/{reaction}
  function reactUrl(typeId, reaction) {
    return reactBase.replace('/0/', '/' + typeId + '/').replace('/like', '/' + reaction);
  }

  document.querySelectorAll('.btn-react').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var typeId   = btn.getAttribute('data-type-id');
      var reaction = btn.getAttribute('data-reaction');
      if (!typeId || !reaction) return;

      // UI optimiste : toggle visuel immédiat
      btn.classList.add('loading');

      fetch(reactUrl(typeId, reaction), {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Content-Type': 'application/json'
        }
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        // Mettre à jour les compteurs
        var likesEl    = document.getElementById('likes-'    + typeId);
        var dislikesEl = document.getElementById('dislikes-' + typeId);
        if (likesEl)    likesEl.textContent    = data.likes;
        if (dislikesEl) dislikesEl.textContent = data.dislikes;

        // Mettre à jour l'état actif des boutons
        var card = btn.closest('.react-card');
        if (card) {
          card.querySelectorAll('.btn-like,.btn-dislike').forEach(function (b) {
            b.classList.remove('active');
          });
        }
        if (data.reaction) {
          var activeBtn = card
            ? card.querySelector('.btn-' + data.reaction)
            : document.querySelector('[data-type-id="'+typeId+'"][data-reaction="'+data.reaction+'"]');
          if (activeBtn) activeBtn.classList.add('active');
        }
      })
      .catch(function (err) { console.error('[Like/Dislike]', err); })
      .finally(function () { btn.classList.remove('loading'); });
    });
  });
})();
</script>
{% endblock %}
