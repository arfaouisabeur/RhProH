          <span class="filter-label"><i class="fas fa-sort"></i> Trier par</span>
          <select name="sortBy" class="filter-select" style="min-width:165px;">
            <option value="dateDemande"{% if sortBy == 'dateDemande' %}selected{% endif %}>📅 Date de demande</option>
            <option value="type"       {% if sortBy == 'type'        %}selected{% endif %}>🏷️ Type de service</option>
            <option value="statut"     {% if sortBy == 'statut'      %}selected{% endif %}>📌 Statut</option>
          </select>
        </div>

        <input type="hidden" name="sortDir" id="em-svc-sort-dir" value="{{ sortDir }}">
        <div class="filter-group">
          <span class="filter-label" style="visibility:hidden;">Ordre</span>
          <button type="button" class="btn-filter btn-dir-em"
            onclick="var d=document.getElementById('em-svc-sort-dir');d.value=(d.value==='asc'?'desc':'asc');document.getElementById('em-svc-form').submit();">
            {% if sortDir == 'asc' %}
              <i class="fas fa-arrow-up-a-z"></i> Croissant
            {% else %}
              <i class="fas fa-arrow-down-z-a"></i> Décroissant
            {% endif %}
          </button>
        </div>

        {% if search %}
          <div class="filter-group">
            <span class="filter-label" style="visibility:hidden;">Reset</span>
            <a href="{{ path('app_demande_service_index') }}" class="btn-filter btn-reset">
              <i class="fas fa-xmark"></i> Réinitialiser
            </a>
          </div>
        {% endif %}
      </form>

      {% if demande_services|length > 0 %}
      <div id="em-svc-count" style="padding:8px 28px 4px;font-size:.83rem;font-weight:800;color:#64748b;display:flex;align-items:center;gap:7px;">
        <i class="fas fa-list-ul" style="color:#b39ddb;"></i>
        <span id="em-svc-count-num">{{ demande_services|length }}</span> résultat(s)
      </div>
      <div style="overflow:auto;">
        <table>
          <thead>
            <tr>
              <th style="display:none;">Nom</th>
              <th>Type service</th>
              <th>Date</th>
              <th>Statut</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="em-svc-tbody">
            {% for d in demande_services %}
              {% set st  = d.statut %}
              {% set isOk = (st == 'Accepté' or st == 'approuvé') %}
              {% set isNo = (st == 'Refusé'  or st == 'refusé') %}
              <tr>
                <td style="font-weight:800;display:none;">
                  {% if d.employe and d.employe.user %}
                    {{ d.employe.user.prenom }} {{ d.employe.user.nom }}
                  {% else %}
                    <span style="color:#94a3b8;">—</span>
                  {% endif %}
                </td>
                <td style="font-weight:800;color:#0f172a;">{{ d.type ? d.type.nom : '—' }}</td>
                <td style="color:#64748b;font-weight:700;">
                  {% if d.dateDemande and d.dateDemande != '0000-00-00' %}{{ d.dateDemande|date('d/m/Y') }}{% else %}—{% endif %}
                </td>
                <td>
                  {% if isOk %}<span class="pill p-ok">Accepté</span>
                  {% elseif isNo %}<span class="pill p-no">Refusé</span>
                  {% else %}<span class="pill p-pend">En attente</span>{% endif %}
                </td>
                <td>
                  <div class="act">
                    <a class="btn-ghost btn-ghost-em" href="{{ path('app_demande_service_show', {'id': d.id}) }}" title="Voir"><i class="fas fa-eye"></i></a>
                    {% if st == 'En attente' %}
                      <a class="btn-ghost btn-ghost-em" href="{{ path('app_demande_service_edit', {'id': d.id}) }}" title="Modifier"><i class="fas fa-pen"></i></a>
                    {% endif %}
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% else %}
        <div class="empty-state" id="em-svc-empty-search" style="display:none;">
          <i class="fas fa-search"></i>
          <h4>Aucun résultat</h4>
          <p>Essayez un autre terme de recherche.</p>
        </div>
        <div class="empty-state" id="em-svc-empty-data">
          <i class="fas fa-inbox"></i>
          <h4>Aucune demande</h4>
          <p>Crée ta première demande de service.</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endif %}

{# ══════════════════════
   MODAL STATISTIQUES SERVICES — VERSION ENRICHIE
══════════════════════ #}
<style>
/* ── Stats Modal enrichi ── */
.sm2 { display:none; position:fixed; inset:0; z-index:9999; background:rgba(46,13,82,.58); backdrop-filter:blur(9px); -webkit-backdrop-filter:blur(9px); align-items:center; justify-content:center; }
.sm2-box {
  background:#fff; border-radius:28px; padding:0;
  max-width:860px; width:96%; position:relative;
  box-shadow:0 32px 90px rgba(46,13,82,.26);
  animation:modalPop .35s cubic-bezier(.175,.885,.32,1.275);
  overflow:hidden; max-height:92vh; display:flex; flex-direction:column;
}
.sm2-top {
  background:linear-gradient(135deg,var(--mv-950),var(--mv-700));
  padding:22px 28px 18px; flex-shrink:0;
  display:flex; justify-content:space-between; align-items:flex-start;
}
.sm2-title { font-family:'Outfit'; font-weight:900; font-size:1.6rem; color:#fff; display:flex; align-items:center; gap:12px; }
.sm2-sub   { color:rgba(255,255,255,.65); font-size:.88rem; margin-top:4px; }
.sm2-close {
  width:36px; height:36px; border-radius:50%; border:none;
