}
.sm2-close:hover { background:rgba(255,255,255,.28); }
.sm2-body { overflow-y:auto; padding:24px 28px 28px; flex:1; }

/* KPI row */
.sm2-kpis { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:22px; }
.sm2-kpi {
  border-radius:16px; padding:14px 16px; display:flex; align-items:center; gap:12px;
  transition:transform .2s;
}
.sm2-kpi:hover { transform:translateY(-3px); }
.sm2-kpi-ic { width:42px; height:42px; border-radius:14px; display:flex; align-items:center; justify-content:center; color:#fff; font-size:18px; flex-shrink:0; }
.sm2-kpi-val { font-family:'Outfit'; font-weight:900; font-size:1.7rem; color:#0f172a; line-height:1; }
.sm2-kpi-lbl { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.09em; margin-top:2px; }

/* Charts row */
