{% extends 'base.html.twig' %}

{% block title %}Détail de la demande de Service{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

.app-container {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 15% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.app-container::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:540px; height:540px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat 9s ease-in-out infinite;
}
.app-container::after {
  content:''; position:fixed; bottom:-110px; left:-110px;
  width:400px; height:400px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 12s ease-in-out infinite;
}
.app-container * { box-sizing:border-box; }

.view-wrapper {
  max-width:840px; margin:0 auto;
  position:relative; z-index:1;
  animation: slideUp .7s cubic-bezier(.16,1,.3,1) both;
}

/* ── Nav ── */
.header-box { display:flex; justify-content:space-between; align-items:center; margin-bottom:26px; }
.btn-back {
  display:flex; align-items:center; gap:9px; color:#64748b;
  text-decoration:none; font-weight:700; padding:10px 20px;
  border-radius:999px; background:rgba(255,255,255,.88);
  border:1.5px solid rgba(179,157,219,.3);
  transition:.2s; box-shadow:0 4px 14px rgba(0,0,0,.06);
  backdrop-filter:blur(10px);
}
.btn-back:hover { background:#fff; color:var(--mv-700); border-color:var(--mv-500); transform:translateX(-2px); }

/* ── Ticket card ── */
.ticket-card {
  background:rgba(255,255,255,.9);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.25);
  border-radius:28px;
  box-shadow:0 18px 56px rgba(143,76,201,.12);
  overflow:hidden;
}

/* ── Ticket header (statut-dependent) ── */
.ticket-header {
  padding:42px 46px; position:relative; overflow:hidden;
  display:flex; justify-content:space-between; align-items:center;
}
/* status gradients – keep yellow/green/red for meaning */
.ticket-header.st-pending  { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
.ticket-header.st-accepted { background: linear-gradient(135deg, var(--mv-950) 0%, var(--mv-700) 60%, var(--mv-600) 100%); }
.ticket-header.st-rejected { background: linear-gradient(135deg, #f43f5e 0%, #be123c 100%); }

.ticket-header::before {
  content:''; position:absolute; top:-80px; left:-80px;
  width:280px; height:280px; border-radius:50%;
  background:rgba(255,255,255,.08); pointer-events:none;
}
.ticket-header::after {
  content:'\f0b1'; font-family:'Font Awesome 6 Free'; font-weight:900;
  position:absolute; right:-20px; bottom:-30px; font-size:170px;
  color:rgba(255,255,255,.08); transform:rotate(-15deg); pointer-events:none;
}
.ticket-title h2 {
  font-family:'Outfit',sans-serif; font-size:2.2rem;
  margin:0; color:#fff; line-height:1.12;
  text-shadow:0 2px 8px rgba(0,0,0,.14);
}
.ticket-title p { color:rgba(255,255,255,.78); margin:7px 0 0; font-size:1.05rem; }

.status-pill {
  background:rgba(255,255,255,.22); border:1.5px solid rgba(255,255,255,.4);
  backdrop-filter:blur(12px); padding:9px 22px; border-radius:999px;
  color:#fff; font-weight:800; font-size:.95rem;
  text-transform:uppercase; letter-spacing:.08em;
  flex-shrink:0;
  animation: pillSlide .6s cubic-bezier(.16,1,.3,1) .3s both;
}

/* ── Body ── */
.ticket-body { padding:40px 46px; }

/* Réponse box */
.reponse-box {
  border-radius:20px; padding:24px 28px; margin-bottom:28px;
  display:flex; gap:16px; align-items:flex-start;
  animation: slideDown .5s ease-out;
}
.reponse-box.accepted {
  background: linear-gradient(135deg, rgba(179,157,219,.12), rgba(143,76,201,.07));
  border:1.5px solid rgba(143,76,201,.25);
}
.reponse-box.refused {
  background: linear-gradient(135deg, #fff1f2, #ffe4e6);
  border:1.5px solid #fecdd3;
}
.reponse-icon {
  width:44px; height:44px; border-radius:14px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center; color:#fff; font-size:18px;
}
.reponse-icon.ok  { background:linear-gradient(135deg,var(--mv-700),var(--mv-600)); box-shadow:0 6px 16px var(--mv-glow); }
.reponse-icon.no  { background:linear-gradient(135deg,#f43f5e,#e11d48); box-shadow:0 6px 16px rgba(244,63,94,.22); }
.reponse-box h4 { font-family:'Outfit'; font-size:1.08rem; font-weight:900; margin:0 0 6px; color:#0f172a; }
.reponse-box p  { margin:0; color:#475569; font-style:italic; line-height:1.6; font-size:.95rem; }

/* Detail grid */
.grid-details { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:28px; }
.detail-item {
  background: linear-gradient(135deg, var(--mv-50), #ffffff);
  padding:20px; border-radius:18px;
  border:1.5px solid rgba(179,157,219,.22);
  box-shadow:0 4px 14px rgba(143,76,201,.06);
  transition:transform .2s, box-shadow .2s, border-color .2s;
}
.detail-item:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(143,76,201,.12); border-color:rgba(143,76,201,.3); }
.detail-item.full { grid-column:1/-1; }
.dl-label { font-size:.76rem; font-weight:900; text-transform:uppercase; color:#64748b; letter-spacing:.1em; margin-bottom:7px; }
.dl-val { font-family:'Outfit',sans-serif; font-size:1.25rem; font-weight:700; color:#0f172a; display:flex; align-items:center; gap:9px; }
.dl-val i { color:var(--mv-600); font-size:1rem; }

/* ── Priority badges ── */
.prio-high   { color:#be123c; background:#fff1f2; border:1px solid #fecdd3; padding:3px 10px; border-radius:999px; font-size:.82rem; font-weight:800; }
.prio-medium { color:#b45309; background:#fffbeb; border:1px solid #fde68a; padding:3px 10px; border-radius:999px; font-size:.82rem; font-weight:800; }
.prio-low    { color:#047857; background:#ecfdf5; border:1px solid #a7f3d0; padding:3px 10px; border-radius:999px; font-size:.82rem; font-weight:800; }

/* ── Footer actions ── */
.divider { height:1px; background:linear-gradient(90deg,transparent,rgba(179,157,219,.3),transparent); margin:0 46px 28px; }
.ticket-footer {
  padding:0 46px 42px;
  display:flex; justify-content:space-between; align-items:center;
  gap:12px; flex-wrap:wrap;
}
.btn-edit {
  display:inline-flex; align-items:center; gap:9px; text-decoration:none;
  background: linear-gradient(135deg, var(--mv-700), var(--mv-600)); color:#fff;
  padding:13px 26px; border-radius:999px; font-weight:900; font-family:'Outfit';
  box-shadow:0 12px 28px var(--mv-glow);
  transition:transform .2s, box-shadow .2s;
  position:relative; overflow:hidden;
}
.btn-edit::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.15),transparent);
  opacity:0; transition:opacity .2s;
}
.btn-edit:hover { transform:translateY(-3px); box-shadow:0 18px 38px var(--mv-glow); }
.btn-edit:hover::before { opacity:1; }

/* ── Animations ── */
@keyframes slideUp   { from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideDown { from{opacity:0;transform:translateY(-14px);}to{opacity:1;transform:translateY(0);} }
@keyframes pillSlide { from{opacity:0;transform:translateX(18px);}to{opacity:1;transform:translateX(0);} }
@keyframes orbFloat  { 0%,100%{transform:translate(0,0);}50%{transform:translate(-25px,18px);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0);}50%{transform:translate(18px,-22px);} }

@media(max-width:620px){
  .grid-details{grid-template-columns:1fr;gap:14px;}
  .ticket-header{flex-direction:column;align-items:flex-start;gap:18px;padding:28px;}
  .ticket-body{padding:28px;}
  .ticket-footer{flex-direction:column;padding:0 28px 32px;}
  .ticket-footer>*{width:100%;justify-content:center;}
  .divider{margin:0 28px 22px;}
}
</style>
{% endblock %}

{% block body %}
{% set st = demande_service.statut %}
{% set isOk = (st == 'Accepté' or st == 'approuvé') %}
{% set isNo = (st == 'Refusé' or st == 'refusé') %}
{% set cl = isOk ? 'st-accepted' : (isNo ? 'st-rejected' : 'st-pending') %}

<div class="app-container">
    <div class="view-wrapper">
        <div class="header-box">
            <a href="{{ path('app_demande_service_index') }}" class="btn-back">
                <i class="fas fa-arrow-left"></i> Mes demandes
            </a>
        </div>

        <div class="ticket-card">
            <div class="ticket-header {{ cl }}">
                <div class="ticket-title">
                    <h2>{{ demande_service.type ? demande_service.type.nom : demande_service.titre }}</h2>
                    <p>
                        {% if demande_service.type %}
                            Catégorie : {{ demande_service.type.categorie }} — Demande n°{{ demande_service.id }}
                        {% else %}
                            Demande n°{{ demande_service.id }}
                        {% endif %}
                    </p>
                </div>
                <div class="status-pill">
                    {% if isOk %}<i class="fas fa-check-circle"></i> Accepté
                    {% elseif isNo %}<i class="fas fa-times-circle"></i> Refusé
                    {% else %}<i class="fas fa-hourglass-half"></i> En attente{% endif %}
                </div>
            </div>

            <div class="ticket-body">

                {# ── Réponse RH ── #}
                {% if isOk or isNo %}
                <div class="reponse-box {{ isOk ? 'accepted' : 'refused' }}">
                    <div class="reponse-icon {{ isOk ? 'ok' : 'no' }}">
                        <i class="fas {{ isOk ? 'fa-check' : 'fa-times' }}"></i>
                    </div>
                    <div>
                        <h4>
                            {% if isOk %}Demande Acceptée par le RH
                            {% else %}Demande Refusée par le RH{% endif %}
                        </h4>
                        <p>Le statut de votre demande a été mis à jour. Pour toute question, contactez votre RH.</p>
                    </div>
                </div>
                {% endif %}

                <div class="grid-details">
                    <div class="detail-item">
                        <div class="dl-label">Type de service</div>
                        <div class="dl-val">
                            <i class="fas fa-toolbox"></i>
                            {{ demande_service.type ? demande_service.type.nom : '—' }}
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="dl-label">Catégorie</div>
                        <div class="dl-val">
                            <i class="fas fa-folder-open"></i>
                            {{ demande_service.type ? demande_service.type.categorie : '—' }}
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="dl-label">Date de demande</div>
                        <div class="dl-val">
                            <i class="fas fa-calendar-alt"></i>
                            {{ demande_service.dateDemande ?: '—' }}
                        </div>
                    </div>
                    <div class="detail-item">
                        <div class="dl-label">Priorité</div>
                        <div class="dl-val">
                            <i class="fas fa-flag"></i>
                            {% set prio = demande_service.priorite %}
                            {% if prio == 'Haute' or prio == 'haute' or prio == 'high' %}
                                <span class="prio-high"><i class="fas fa-arrow-up"></i> {{ prio }}</span>
                            {% elseif prio == 'Moyenne' or prio == 'moyenne' or prio == 'medium' %}
                                <span class="prio-medium"><i class="fas fa-minus"></i> {{ prio }}</span>
                            {% elseif prio == 'Basse' or prio == 'basse' or prio == 'low' %}
                                <span class="prio-low"><i class="fas fa-arrow-down"></i> {{ prio }}</span>
                            {% else %}
                                {{ prio ?: 'Non définie' }}
                            {% endif %}
                        </div>
                    </div>

                    {% if demande_service.description %}
                    <div class="detail-item full">
                        <div class="dl-label">Description</div>
                        <div style="color:#475569;font-style:italic;line-height:1.75;margin-top:7px;font-size:.97rem;">
                            "{{ demande_service.description }}"
                        </div>
                    </div>
                    {% endif %}

                    {% if demande_service.pdfPath %}
                    <div class="detail-item full">
                        <div class="dl-label">Pièce jointe</div>
                        <div class="dl-val" style="margin-top:6px;">
                            <i class="fas fa-paperclip"></i>
                            {{ demande_service.pdfPath }}
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="divider"></div>

            <div class="ticket-footer">
                <div>
                    {{ include('demande_service/_delete_form.html.twig') }}
                </div>
                {% if st == 'En attente' %}
                <a href="{{ path('app_demande_service_edit', {'id': demande_service.id}) }}" class="btn-edit">
                    <i class="fas fa-pen"></i> Modifier la demande
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
