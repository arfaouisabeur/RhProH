{% extends 'base.html.twig' %}
{% block title %}{{ evenement.titre }} — Événements{% endblock %}

{% block styles %}
:root {
  --green: #7c3aed;
  --green-dark: #6d28d9;
  --surface: #f5f0ff;
  --border: #e5e7eb;
  --text-dark: #111827;
  --text-muted: #6b7280;
  --purple: #7c3aed;
}
body { background: var(--surface); }

.show-page { min-height: 100vh; background: var(--surface); font-family: 'Inter', sans-serif; padding-bottom: 60px; }

.show-breadcrumb {
  max-width: 1100px; margin: 0 auto;
  padding: 24px 32px 0;
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--text-muted);
}
.show-breadcrumb a { color: var(--green-dark); text-decoration: none; font-weight: 500; }
.show-breadcrumb a:hover { text-decoration: underline; }

/* Hero image */
.show-hero {
  position: relative;
  height: 300px;
  overflow: hidden;
  margin: 20px 0;
  background: linear-gradient(135deg, #4c1d95, #7c3aed);
}
.show-hero img { width:100%; height:100%; object-fit:cover; opacity:0.7; }
.show-hero-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(6,78,59,0.85) 0%,transparent 60%); }
.show-hero-content { position:absolute; bottom:28px; left:0; right:0; max-width:1100px; margin:0 auto; padding:0 32px; }
.show-hero-badge {
  display:inline-flex; align-items:center; gap:5px;
  background:rgba(255,255,255,0.15); border:1px solid rgba(255,255,255,0.25);
  border-radius:100px; padding:4px 12px; font-size:11px; font-weight:600; color:#fff;
  margin-bottom:10px;
}
.show-hero-title { font-size: clamp(22px,4vw,36px); font-weight:700; color:#fff; margin:0; }

/* Layout */
.show-layout {
  max-width: 1100px;
  margin: 28px auto 0;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 24px;
}
@media (max-width: 768px) { .show-layout { grid-template-columns: 1fr; padding: 0 16px; } }

/* Section cards */
.show-section {
  background: #fff;
  border-radius: 16px;
  border: 1px solid var(--border);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  padding: 24px;
  margin-bottom: 20px;
}
.show-section-title {
  font-size: 16px; font-weight: 700; color: var(--text-dark);
  margin: 0 0 16px; padding-bottom: 14px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 8px;
}
.show-desc { font-size: 14px; color: #374151; line-height: 1.75; margin: 0; }

/* Activités */
.act-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px; padding-bottom: 14px; border-bottom: 1px solid var(--border);
}
.act-header h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin: 0; display: flex; align-items: center; gap: 8px; }

.btn-sm-green {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border-radius: 9px; font-size: 12px; font-weight: 600;
  background: var(--green); color: #fff; border: none; cursor: pointer;
  font-family: 'Inter', sans-serif; transition: background 0.2s, transform 0.15s;
  text-decoration: none;
}
.btn-sm-green:hover { background: var(--green-dark); color: #fff; text-decoration: none; transform: translateY(-1px); }


.act-item {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 14px 0; border-bottom: 1px solid #f3f4f6;
}
.act-item:last-child { border-bottom: none; padding-bottom: 0; }
.act-icon {
  width: 36px; height: 36px; border-radius: 10px;
  background: #ede9fe; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; color: var(--green-dark);
}
.act-body { flex: 1; }
.act-title { font-size: 14px; font-weight: 600; color: var(--text-dark); margin: 0 0 3px; }
.act-desc-text { font-size: 13px; color: var(--text-muted); margin: 0; }
.act-row-actions { display: flex; gap: 5px; flex-shrink: 0; }
.icon-btn {
  width: 30px; height: 30px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; border: 1px solid var(--border);
  background: transparent; color: var(--text-muted); cursor: pointer; transition: background 0.2s;
}
.icon-btn:hover { background: #f5f3ff; color: var(--green-dark); text-decoration: none; }
.icon-btn-danger { border-color: #fecaca; color: #ef4444; background: #fff0f0; }
.icon-btn-danger:hover { background: #fee2e2; }

/* Inline form */
.add-form {
  background: #f5f0ff; border: 1.5px dashed #a78bfa;
  border-radius: 12px; padding: 20px; margin-top: 16px;
}
.add-form h4 { font-size: 13px; font-weight: 600; color: var(--green-dark); margin: 0 0 14px; }
.add-form .form-group { margin-bottom: 12px; }
.add-form label { font-size: 12px; font-weight: 600; color: var(--text-muted); display: block; margin-bottom: 4px; }
.add-form input, .add-form textarea {
  width: 100%; padding: 9px 13px;
  border: 1.5px solid var(--border); border-radius: 9px;
  font-size: 13px; font-family: 'Inter', sans-serif;
  color: var(--text-dark); background: #fff; box-sizing: border-box; outline: none;
}
.add-form input:focus, .add-form textarea:focus { border-color: var(--green); }
.add-form textarea { resize: vertical; }
.add-form .form-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
.btn-cancel {
  background: transparent; color: var(--text-muted);
  border: 1px solid var(--border); padding: 8px 16px;
  border-radius: 9px; font-size: 12px; font-weight: 600; cursor: pointer;
  font-family: 'Inter', sans-serif;
}

/* Participations */
.part-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600;
}
.part-pending  { background: #fef3c7; color: #92400e; }
.part-accepted { background: #ede9fe; color: #5b21b6; }
.part-refused  { background: #fee2e2; color: #991b1b; }

.part-row {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px; padding: 12px 0; border-bottom: 1px solid #f3f4f6;
}
.part-row:last-child { border-bottom: none; }
.part-name { font-size: 14px; font-weight: 600; color: var(--text-dark); margin: 0; }
.part-date { font-size: 12px; color: var(--text-muted); margin: 0; }

/* Sidebar */
.sidebar-card {
  background: #fff; border-radius: 16px; border: 1px solid var(--border);
  padding: 22px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}
.sidebar-title {
  font-size: 12px; font-weight: 600; color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 16px;
}
.info-row {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 10px 0; border-bottom: 1px solid #f3f4f6;
}
.info-row:last-child { border-bottom: none; padding-bottom: 0; }
.info-icon {
  width: 32px; height: 32px; border-radius: 8px; background: #ede9fe;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: var(--green-dark);
}
.info-label { font-size: 11px; color: var(--text-muted); margin-bottom: 2px; }
.info-value { font-size: 13px; font-weight: 600; color: var(--text-dark); }

.act-sidebar {
  display: flex; flex-direction: column; gap: 10px;
}
.sidebar-action-btn {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px; border-radius: 10px; font-size: 13px; font-weight: 600;
  text-decoration: none;  transition: background 0.2s, transform 0.15s;
  border: none; cursor: pointer; font-family: 'Inter', sans-serif; width: 100%; text-align: left;
}
.sidebar-action-btn:hover { transform: translateY(-1px); text-decoration: none; }
.btn-edit-sidebar { background: #ede9fe; color: #5b21b6; }
.btn-edit-sidebar:hover { background: #c4b5fd; color: #5b21b6; }
.btn-parts-sidebar { background: #dbeafe; color: #1e40af; }
.btn-parts-sidebar:hover { background: #bfdbfe; color: #1e40af; }
.btn-back-sidebar { background: #f3f4f6; color: var(--text-muted); border: 1px solid var(--border); }
.btn-back-sidebar:hover { background: #e5e7eb; color: var(--text-dark); }
.btn-del-sidebar { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
.btn-del-sidebar:hover { background: #fecaca; }

.no-items { text-align: center; padding: 32px; color: var(--text-muted); font-size: 14px; }
{% endblock %}

{% block body %}
{{ include('partials/_confirm_modal.html.twig') }}
<div class="show-page">
  <div class="show-breadcrumb">
    <a href="{{ path('app_evenement_index') }}">Événements</a>
    <span>›</span>
    <span>{{ evenement.titre }}</span>
  </div>

  {# Hero #}
  <div class="show-hero">
    {% if evenement.imageUrl %}
      <img src="{{ evenement.imageUrl }}" alt="{{ evenement.titre }}">
    {% endif %}
    <div class="show-hero-overlay"></div>
    <div class="show-hero-content">
      <div class="show-hero-badge">
        {% set today = "now"|date("Y-m-d") %}
        {% if evenement.dateDebut <= today and evenement.dateFin >= today %}● En cours
        {% elseif evenement.dateDebut > today %}● À venir
        {% else %}● Terminé{% endif %}
      </div>
      <h1 class="show-hero-title">{{ evenement.titre }}</h1>
    </div>
  </div>

  <div class="show-layout">
    {# Main column #}
    <div>
      {% if evenement.description %}
      <div class="show-section">
        <h3 class="show-section-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><line x1="21" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="21" y1="18" x2="3" y2="18"/></svg>
          Description
        </h3>
        <p class="show-desc">{{ evenement.description }}</p>
      </div>
      {% endif %}

      {# Activités #}
      <div class="show-section">
        <div class="act-header">
          <h3>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Activités ({{ evenement.activites|length }})
          </h3>
          <button type="button" class="btn-sm-green" id="btn-add-act" onclick="document.getElementById('add-act-form').style.display='block';this.style.display='none';">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Ajouter
          </button>
        </div>

        {# Inline add form — s'ouvre automatiquement si erreurs #}
        <div id="add-act-form" class="add-form"
          style="display:{{ activiteForm.vars.submitted and not activiteForm.vars.valid ? 'block' : 'none' }};">
          <h4>➕ Nouvelle activité</h4>

          {% if activiteForm.vars.submitted and not activiteForm.vars.valid %}
          <div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:9px;padding:12px;margin-bottom:14px;font-size:12px;color:#991b1b;display:flex;align-items:center;gap:8px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
            Veuillez corriger les erreurs ci-dessous.
          </div>
          {% endif %}

          {{ form_start(activiteForm, {'attr': {'novalidate': 'novalidate'}, 'action': path('app_evenement_show', {'id': evenement.id}), 'method': 'POST'}) }}
            <div class="form-group">
              {{ form_label(activiteForm.titre) }}
              {{ form_widget(activiteForm.titre, {'attr': {'style': activiteForm.titre.vars.errors|length > 0 ? 'border-color:#ef4444;background:#fff5f5;' : ''}}) }}
              {% for error in activiteForm.titre.vars.errors %}
                <div style="display:flex;align-items:center;gap:5px;margin-top:5px;font-size:12px;color:#ef4444;font-weight:500;">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
                  {{ error.message }}
                </div>
              {% endfor %}
            </div>
            <div class="form-group">
              {{ form_label(activiteForm.description) }}
              {{ form_widget(activiteForm.description) }}
              {% for error in activiteForm.description.vars.errors %}
                <div style="display:flex;align-items:center;gap:5px;margin-top:5px;font-size:12px;color:#ef4444;font-weight:500;">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
                  {{ error.message }}
                </div>
              {% endfor %}
            </div>
            <div class="form-actions">
              <button type="button" class="btn-cancel"
                onclick="document.getElementById('add-act-form').style.display='none';document.getElementById('btn-add-act').style.display='inline-flex';">
                Annuler
              </button>
              <button type="submit" class="btn-sm-green">
                ✓ Enregistrer
              </button>
            </div>
          {{ form_end(activiteForm) }}
        </div>

        {% if evenement.activites|length > 0 %}
          {% for activite in evenement.activites %}
          <div class="act-item">
            <div class="act-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            </div>
            <div class="act-body">
              <p class="act-title">{{ activite.titre }}</p>
              {% if activite.description %}<p class="act-desc-text">{{ activite.description }}</p>{% endif %}
            </div>
            <div class="act-row-actions">
              <a href="{{ path('app_activite_edit', {'id': activite.id}) }}" class="icon-btn" title="Modifier">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </a>
              <form id="del-act-{{ activite.id }}" method="post" action="{{ path('app_activite_delete', {'id': activite.id}) }}" style="display:inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activite.id) }}">
                <button type="button" class="icon-btn icon-btn-danger" title="Supprimer"
                  onclick="rhConfirmDelete(document.getElementById('del-act-{{ activite.id }}'), 'Supprimer l\'activité {{ activite.titre|e('js') }} ?')">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
            </div>
          </div>
          {% endfor %}
        {% else %}
          <div class="no-items">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="1.5" style="margin-bottom:8px;"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            <p>Aucune activité pour cet événement.</p>
          </div>
        {% endif %}
      </div>

      {# Participations #}
      <div class="show-section">
        <h3 class="show-section-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Participations ({{ participations|length }})
        </h3>

        {% if participations|length > 0 %}
          {% for p in participations %}
          <div class="part-row">
            <div>
              <p class="part-name">{{ p.employe.user.prenom }} {{ p.employe.user.nom }}</p>
              <p class="part-date">Inscrit le {{ p.dateInscription }}</p>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <span class="part-badge {% if p.statut == 'en_attente' %}part-pending{% elseif p.statut == 'accepte' %}part-accepted{% else %}part-refused{% endif %}">
                {% if p.statut == 'en_attente' %}⏳ En attente{% elseif p.statut == 'accepte' %}✓ Accepté{% else %}✗ Refusé{% endif %}
              </span>
              {% if p.statut == 'en_attente' %}
              <div style="display:flex;gap:6px;">
                <form method="post" action="{{ path('app_event_participation_accept', {'id': p.id}) }}" style="display:inline;">
                  <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ p.id) }}">
                  <button type="submit" style="background:#ede9fe;color:#5b21b6;padding:5px 12px;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;">✓ Accepter</button>
                </form>
                <form method="post" action="{{ path('app_event_participation_refuse', {'id': p.id}) }}" style="display:inline;">
                  <input type="hidden" name="_token" value="{{ csrf_token('refuse' ~ p.id) }}">
                  <button type="submit" style="background:#fee2e2;color:#991b1b;padding:5px 12px;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;">✗ Refuser</button>
                </form>
              </div>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        {% else %}
          <p class="no-items" style="padding:24px 0;">Aucune participation pour cet événement.</p>
        {% endif %}
      </div>
    </div>
    {# ── Section Avis & Sentiment (RH) #}
{% if evenement.ratings|length > 0 %}
<div class="show-section" id="ratings-section">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--border);">
        <h3 class="show-section-title" style="margin:0;border:none;padding:0;">
            ⭐ Avis employés ({{ evenement.ratings|length }})
        </h3>
        <button id="btn-analyze-all"
            onclick="analyzeAllRatings({{ evenement.id }})"
            style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;
                   border-radius:9px;font-size:12px;font-weight:600;border:none;cursor:pointer;
                   background:#ede9fe;color:#5b21b6;font-family:'Inter',sans-serif;">
            🤖 Analyser les sentiments
        </button>
    </div>

    <div id="sentiment-summary" style="display:none;
        background:#f5f0ff;border:1.5px solid #a78bfa;border-radius:12px;
        padding:16px;margin-bottom:16px;">
        <p style="font-size:13px;font-weight:600;color:#5b21b6;margin:0 0 10px;">
            📊 Résumé de l'analyse IA
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <span id="sum-positif"
                style="background:#d1fae5;color:#065f46;padding:6px 12px;border-radius:100px;font-size:12px;font-weight:600;">
            </span>
            <span id="sum-negatif"
                style="background:#fee2e2;color:#991b1b;padding:6px 12px;border-radius:100px;font-size:12px;font-weight:600;">
            </span>
            <span id="sum-neutre"
                style="background:#f3f4f6;color:#6b7280;padding:6px 12px;border-radius:100px;font-size:12px;font-weight:600;">
            </span>
        </div>
        <p id="sum-incoherent" style="font-size:12px;color:#92400e;margin:10px 0 0;display:none;"></p>
    </div>

    {% for rating in evenement.ratings %}
    <div style="padding:16px 0;border-bottom:1px solid #f3f4f6;" id="rating-block-{{ rating.id }}">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
            <div style="flex:1;">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <span style="font-size:13px;font-weight:600;color:#111827;">
                        {{ rating.employe.user.prenom }} {{ rating.employe.user.nom }}
                    </span>
                    <span style="color:#f59e0b;font-size:13px;">
                        {% for i in 1..rating.etoiles %}★{% endfor %}
                        {% for i in rating.etoiles+1..5 %}☆{% endfor %}
                    </span>
                    <span id="badge-{{ rating.id }}" class="sentiment-badge"></span>
                </div>
                <p style="font-size:13px;color:#374151;margin:0;line-height:1.6;">
                    {{ rating.commentaire }}
                </p>
                <p id="incoherence-{{ rating.id }}"
                   style="display:none;font-size:11px;color:#92400e;margin:6px 0 0;
                          background:#fef3c7;padding:4px 8px;border-radius:6px;">
                    ⚠️ Commentaire potentiellement incohérent avec la note
                </p>
            </div>
            <span style="font-size:11px;color:#9ca3af;white-space:nowrap;">
                {{ rating.dateCreation }}
            </span>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}

<style>
.sentiment-badge {
    display:inline-flex;align-items:center;gap:4px;
    padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;
}
.sentiment-positif { background:#d1fae5;color:#065f46; }
.sentiment-negatif { background:#fee2e2;color:#991b1b; }
.sentiment-neutre  { background:#f3f4f6;color:#6b7280; }
</style>

<script>
async function analyzeAllRatings(evenementId) {
    const btn = document.getElementById('btn-analyze-all');
    btn.disabled = true;
    btn.textContent = '⏳ Analyse en cours...';

    try {
        const res  = await fetch(`/sentiment/evenement/${evenementId}`);
        const data = await res.json();

        document.getElementById('sum-positif').textContent = `😊 Positif : ${data.pct_positif}% (${data.positif})`;
        document.getElementById('sum-negatif').textContent = `😞 Négatif : ${data.pct_negatif}% (${data.negatif})`;
        document.getElementById('sum-neutre').textContent  = `😐 Neutre : ${data.neutre}`;
        document.getElementById('sentiment-summary').style.display = 'block';

        if (data.incoherents > 0) {
            const el = document.getElementById('sum-incoherent');
            el.textContent = `⚠️ ${data.incoherents} avis potentiellement incohérent(s) avec la note`;
            el.style.display = 'block';
        }

        if (data.details) {
            Object.entries(data.details).forEach(([ratingId, result]) => {
                setBadge(ratingId, result);
            });
        }

    } catch (e) {
        btn.textContent = '❌ Erreur API';
    } finally {
        btn.disabled = false;
        btn.textContent = '🔄 Réanalyser';
    }
}

function setBadge(ratingId, result) {
    const badge = document.getElementById(`badge-${ratingId}`);
    if (!badge) return;
    badge.className = `sentiment-badge ${result.color}`;
    badge.textContent = `${result.emoji} ${result.label.charAt(0).toUpperCase() + result.label.slice(1)}`;

    if (!result.coherent) {
        const warn = document.getElementById(`incoherence-${ratingId}`);
        if (warn) warn.style.display = 'block';
    }
}
</script>

