{% extends 'base.html.twig' %}

{% block title %}Mon Calendrier Événements (Bundle) — RHPro{% endblock %}

{% block stylesheets %}
<!-- FullCalendar CSS -->
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css' rel='stylesheet' />
{% endblock %}

{% block styles %}
    :root {
        --fc-border-color: #e5e7eb;
        --purple-primary: #7c3aed;
    }
    .cal-page { min-height: 100vh; background: #fdfaff; padding-bottom: 60px; font-family: 'Inter', sans-serif; }
    .cal-header { background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 100%); padding: 40px 0; color: white; margin-bottom: 30px; box-shadow: 0 4px 20px rgba(124, 58, 237, 0.15); }
    .cal-container { max-width: 1100px; margin: 0 auto; padding: 0 20px; }
    .cal-card { background: #fff; border-radius: 24px; border: 1px solid #e5e7eb; padding: 30px; box-shadow: 0 10px 40px rgba(0,0,0,0.04); }
    
    .fc .fc-toolbar-title { font-size: 1.5rem; font-weight: 800; color: #111827; }
    .fc .fc-button { text-transform: capitalize; }
    .fc-event { border-radius: 6px; padding: 2px 4px; font-size: 0.85rem; border: none !important; cursor: pointer; transition: transform 0.15s ease; }
    .fc-event:hover { transform: scale(1.02); filter: brightness(1.1); }
    
    .cal-legend { display: flex; gap: 20px; margin-top: 20px; font-size: 0.85rem; color: #6b7280; padding: 15px; background: #f9fafb; border-radius: 12px; }
    .legend-item { display: flex; align-items: center; gap: 6px; }
    .dot { width: 10px; height: 10px; border-radius: 50%; }

    .btn-back-list { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: rgba(255, 255, 255, 0.15); color: white; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 0.9rem; margin-top: 15px; border: 1px solid rgba(255,255,255,0.2); transition: background 0.2s; }
    .btn-back-list:hover { background: rgba(255, 255, 255, 0.25); color: #fff; }
{% endblock %}

{% block body %}
<div class="cal-page">
    <div class="cal-header">
        <div class="cal-container">
            <h1 class="fw-bold m-0 text-white">🗓️ Mon Calendrier (via Bundle)</h1>
            <p class="opacity-75 m-0 mb-3 text-white">Gestion officielle par tattali/calendar-bundle</p>
            <a href="{{ path('app_employe_evenements') }}" class="btn-back-list text-white">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Retour à la liste
            </a>
        </div>
    </div>

    <div class="cal-container">
        <div class="cal-card">
            <div id="calendar" style="min-height: 600px;"></div>
            
            <div class="cal-legend">
                <div class="legend-item"><span class="dot" style="background: #6d28d9;"></span><span>Participation Acceptée</span></div>
                <div class="legend-item"><span class="dot" style="background: #f59e0b;"></span><span>En attente de validation</span></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js'></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            locale: 'fr',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,listMonth'
            },
            buttonText: {
                today: 'Aujourd\'hui', month: 'Mois', week: 'Semaine', list: 'Liste'
            },
            // IMPORTANT : Le bundle attend les paramètres start/end en POST dans cette version
            events: {
                url: '{{ path("fc_load_events") }}',
                method: 'POST',
                failure: function() {
                    console.error('Erreur de chargement des événements');
                }
            },
            eventClick: function(info) {
                if (info.event.url) {
                    window.location.href = info.event.url;
                    return false;
                }
            }
        });
        calendar.render();
    });
</script>
{% endblock %}
