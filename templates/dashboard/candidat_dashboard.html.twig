{% extends 'base.html.twig' %}

{% block navbar %}
    {% include 'partials/headercandidat.html.twig' %}
{% endblock %}

{% block title %}Dashboard Candidat - Mon Espace{% endblock %}

{% block body %}
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --purple:       #5b2b82;
    --purple-dark:  #3d1a5c;
    --purple-light: #7c3dac;
    --gold:         #b39ddb;
    --gold-light:   #d1c4e9;
    --white:        #ffffff;
    --off-white:    #f7f4f0;
    --text-dark:    #1a1020;
    --text-muted:   #8a7a9a;
    --glass:        rgba(255,255,255,0.07);
    --glass-border: rgba(255,255,255,0.15);
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--off-white);
    color: var(--text-dark);
  }

  /* ══════════════════════════
     LAYOUT
  ══════════════════════════ */
  .dashboard-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 68px);
  }

  /* ══════════════════════════
     SIDEBAR
  ══════════════════════════ */
  .db-sidebar {
    background: linear-gradient(180deg, #1a0a2e 0%, #3d1a5c 60%, #2a0d45 100%);
    position: sticky;
    top: 68px;
    height: calc(100vh - 68px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    padding: 28px 0 24px;
  }

  .db-sidebar::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 80% 40% at 50% 0%, rgba(201,168,76,0.07) 0%, transparent 60%),
      repeating-linear-gradient(45deg, transparent, transparent 30px, rgba(255,255,255,0.011) 30px, rgba(255,255,255,0.011) 31px);
    pointer-events: none;
  }

  .db-sidebar::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 1px; height: 100%;
    background: linear-gradient(180deg, transparent, rgba(201,168,76,0.2) 30%, rgba(201,168,76,0.2) 70%, transparent);
  }

  /* Sidebar user area */
  .sidebar-user {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 20px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin-bottom: 12px;
  }

  .sidebar-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(201,168,76,0.45);
    box-shadow: 0 0 0 4px rgba(201,168,76,0.08);
    margin-bottom: 12px;
  }

  .sidebar-avatar-initials {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--purple), var(--purple-light));
    border: 2px solid rgba(201,168,76,0.45);
    box-shadow: 0 0 0 4px rgba(201,168,76,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 12px;
  }

  .sidebar-name {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    text-align: center;
    margin-bottom: 5px;
  }

  .sidebar-role {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.28);
    border-radius: 100px;
    padding: 3px 10px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-light);
  }

  .sidebar-role::before {
    content: '';
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 4px var(--gold);
  }

  /* Sidebar nav */
  .sidebar-nav {
    position: relative;
    z-index: 1;
    flex: 1;
    padding: 0 10px;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-section {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.22);
    padding: 14px 10px 6px;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 11px;
    border-radius: 9px;
    font-size: 12.5px;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
  }

  .sidebar-link:hover { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.85); }

  .sidebar-link.active {
    background: rgba(255,255,255,0.1);
    color: var(--white);
  }

  .sidebar-link.active .sl-icon { color: var(--gold-light); background: rgba(201,168,76,0.12); border-color: rgba(201,168,76,0.22); }

  .sl-icon {
    width: 26px; height: 26px;
    border-radius: 7px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.35);
    flex-shrink: 0;
    transition: all 0.15s;
  }

  .sidebar-link:hover .sl-icon { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }

  .sl-badge {
    margin-left: auto;
    background: rgba(201,168,76,0.2);
    border-radius: 100px;
    padding: 1px 7px;
    font-size: 10px;
    font-weight: 700;
    color: var(--gold-light);
  }

  .sidebar-sep { height: 1px; background: rgba(255,255,255,0.06); margin: 8px 10px; }

  /* ══════════════════════════
     MAIN CONTENT
  ══════════════════════════ */
  .db-main {
    padding: 36px 40px;
    overflow-y: auto;
  }

  /* Page header */
  .db-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 32px;
    animation: fadeUp 0.7s ease both;
  }

  .db-header-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 7px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .db-header-label::before {
    content: '';
    width: 16px; height: 2px;
    background: var(--gold);
    border-radius: 1px;
  }

  .db-header-title {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--text-dark);
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .db-header-title em { font-style: normal; color: var(--purple); }
  .db-header-sub { font-size: 13px; color: var(--text-muted); }

  .db-date {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.1);
    border-radius: 9px;
    padding: 8px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
    white-space: nowrap;
  }

  /* ── KPI CARDS ── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease both;
  }

  .kpi-card {
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.08);
    border-radius: 16px;
    padding: 22px 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(91,43,130,0.1); }

  .kpi-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .kpi-card:hover::before { opacity: 1; }

  .kpi-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .kpi-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kpi-icon.purple { background: rgba(91,43,130,0.1); color: var(--purple); }
  .kpi-icon.gold   { background: rgba(201,168,76,0.12); color: var(--gold); }
  .kpi-icon.green  { background: rgba(34,197,94,0.1);  color: #16a34a; }
  .kpi-icon.blue   { background: rgba(59,130,246,0.1); color: #2563eb; }

  .kpi-trend {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 100px;
  }

  .kpi-trend.up   { background: rgba(34,197,94,0.1);  color: #16a34a; }
  .kpi-trend.down { background: rgba(239,68,68,0.1);  color: #dc2626; }
  .kpi-trend.neu  { background: rgba(107,114,128,0.1); color: #6b7280; }

  .kpi-value {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1;
    margin-bottom: 4px;
  }

  .kpi-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  /* ── CONTENT ROW ── */
  .content-row {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
    margin-bottom: 20px;
    animation: fadeUp 0.9s ease both;
  }

  /* ── CARDS ── */
  .rh-card {
    background: var(--white);
    border: 1.5px solid rgba(91,43,130,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  .rh-card-header {
    padding: 18px 22px;
    border-bottom: 1px solid rgba(91,43,130,0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rh-card-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .rh-card-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: rgba(91,43,130,0.08);
    border: 1px solid rgba(91,43,130,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple);
  }

  .rh-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--text-dark);
  }

  .rh-card-action {
    font-size: 11px;
    font-weight: 600;
    color: var(--purple);
    text-decoration: none;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.15s;
  }

  .rh-card-action:hover { gap: 8px; }

  .rh-card-body { padding: 20px 22px; }

  /* ── CANDIDATURE LIST ── */
  .candidature-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .candidature-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    background: var(--off-white);
    border-radius: 12px;
    border: 1px solid rgba(91,43,130,0.07);
    transition: border-color 0.15s, background 0.15s;
  }

  .candidature-item:hover { background: #f0ebf8; border-color: rgba(91,43,130,0.15); }

  .ci-logo {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--purple), var(--purple-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    flex-shrink: 0;
  }

  .ci-info { flex: 1; }

  .ci-poste {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 2px;
  }

  .ci-company {
    font-size: 11px;
    color: var(--text-muted);
  }

  .ci-date {
    font-size: 10px;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .status-badge::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
  }

  .status-badge.en-cours  { background: rgba(59,130,246,0.1);  color: #2563eb; }
  .status-badge.en-cours::before  { background: #2563eb; }
  .status-badge.accepte   { background: rgba(34,197,94,0.1);   color: #16a34a; }
  .status-badge.accepte::before   { background: #16a34a; }
  .status-badge.refuse    { background: rgba(239,68,68,0.1);   color: #dc2626; }
  .status-badge.refuse::before    { background: #dc2626; }
  .status-badge.attente   { background: rgba(201,168,76,0.12); color: #92660a; }
  .status-badge.attente::before   { background: var(--gold); }

  /* ── PROFILE COMPLETION ── */
  .completion-card .rh-card-body { padding: 22px; }

  .completion-percent {
    font-family: 'Playfair Display', serif;
    font-size: 40px;
    font-weight: 700;
    color: var(--purple);
    line-height: 1;
    margin-bottom: 4px;
  }

  .completion-label { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; }

  .progress-bar-wrap {
    height: 8px;
    background: rgba(91,43,130,0.08);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 18px;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--purple), var(--purple-light));
    border-radius: 4px;
    transition: width 1s ease;
  }

  .completion-steps {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .completion-step {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
  }

  .step-check {
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-check.done { background: rgba(34,197,94,0.1); color: #16a34a; }
  .step-check.todo { background: rgba(91,43,130,0.08); color: var(--text-muted); }

  .step-text.done { color: var(--text-dark); }
  .step-text.todo { color: var(--text-muted); }

  /* ── OFFRES RECOMMANDÉES ── */
  .offre-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(91,43,130,0.06);
  }

  .offre-item:last-child { border-bottom: none; padding-bottom: 0; }

  .offre-logo {
    width: 36px; height: 36px;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--gold), #a8832a);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    color: #1a0a2e;
    flex-shrink: 0;
    font-family: 'Playfair Display', serif;
  }

  .offre-info { flex: 1; }

  .offre-poste {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 2px;
  }

  .offre-meta {
    font-size: 11px;
    color: var(--text-muted);
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .offre-tag {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    background: rgba(91,43,130,0.07);
    border-radius: 5px;
    padding: 2px 7px;
    font-size: 10px;
    color: var(--purple);
    font-weight: 500;
  }

  .btn-postuler {
    padding: 6px 14px;
    background: linear-gradient(135deg, var(--purple), var(--purple-dark));
    color: var(--white);
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    white-space: nowrap;
    text-decoration: none;
    display: inline-block;
  }

  .btn-postuler:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(91,43,130,0.3); color: var(--white); }

  /* ── ACTIVITY FEED ── */
  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .activity-item {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(91,43,130,0.05);
    position: relative;
  }

  .activity-item:last-child { border-bottom: none; }

  .activity-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-top: 5px;
    flex-shrink: 0;
  }

  .activity-dot.purple { background: var(--purple); box-shadow: 0 0 0 3px rgba(91,43,130,0.15); }
  .activity-dot.gold   { background: var(--gold);   box-shadow: 0 0 0 3px rgba(201,168,76,0.15); }
  .activity-dot.green  { background: #16a34a;        box-shadow: 0 0 0 3px rgba(34,197,94,0.15); }
  .activity-dot.blue   { background: #2563eb;        box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }

  .activity-text { font-size: 12px; color: var(--text-dark); line-height: 1.5; flex: 1; }
  .activity-text strong { font-weight: 600; }
  .activity-time { font-size: 10px; color: var(--text-muted); white-space: nowrap; margin-top: 2px; }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
    text-align: center;
  }

  .empty-icon {
    width: 56px; height: 56px;
    border-radius: 16px;
    background: rgba(91,43,130,0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--purple);
    opacity: 0.5;
    margin-bottom: 16px;
  }

  .empty-state p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

  /* Keyframes */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .kpi-grid { grid-template-columns: 1fr 1fr; }
    .content-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .dashboard-shell { grid-template-columns: 1fr; }
    .db-sidebar { display: none; }
    .db-main { padding: 20px 16px; }
    .kpi-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .kpi-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="dashboard-shell">

  <!-- ════════════════════════
       SIDEBAR
  ════════════════════════ -->
  <aside class="db-sidebar">

    <div class="sidebar-user">
      {% if app.user.avatarPath %}
        <img src="{{ asset(app.user.avatarPath) }}" class="sidebar-avatar" alt="Avatar">
      {% else %}
        <div class="sidebar-avatar-initials">
          {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
        </div>
      {% endif %}
      <div class="sidebar-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
      <div class="sidebar-role">Candidat</div>
    </div>

    <nav class="sidebar-nav">

      <div class="sidebar-section">Navigation</div>

      <a class="sidebar-link active" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span>
        Tableau de bord
      </a>

      <a class="sidebar-link" href="{{ path('app_candidat_profile') }}">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
        Mon Profil
      </a>

      <div class="sidebar-section">Recrutement</div>

      <a class="sidebar-link" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
        Offres d'emploi
        <span class="sl-badge">12</span>
      </a>

      <a class="sidebar-link" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span>
        Mes Candidatures
        <span class="sl-badge">3</span>
      </a>

      <a class="sidebar-link" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
        Entretiens
      </a>

      <div class="sidebar-section">Outils</div>

      <a class="sidebar-link" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
        Événements
      </a>

      <a class="sidebar-link" href="#">
        <span class="sl-icon"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg></span>
        Services RH
      </a>

      <div class="sidebar-sep"></div>

      <a class="sidebar-link" href="{{ path('app_logout') }}" style="color:#f87171;">
        <span class="sl-icon" style="color:#f87171;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
        Déconnexion
      </a>

    </nav>
  </aside>

  <!-- ════════════════════════
       MAIN
  ════════════════════════ -->
  <main class="db-main">

    <!-- Header -->
    <div class="db-header">
      <div>
        <div class="db-header-label">Tableau de bord</div>
        <h1 class="db-header-title">Bonjour, <em>{{ app.user.prenom }}</em> 👋</h1>
        <p class="db-header-sub">Voici un aperçu de votre espace candidat</p>
      </div>
      <div class="db-date">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {{ "now"|date("d M Y") }}
      </div>
    </div>

    <!-- KPI row -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon purple">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <span class="kpi-trend up">↑ +2</span>
        </div>
        <div class="kpi-value">3</div>
        <div class="kpi-label">Candidatures envoyées</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon green">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <span class="kpi-trend neu">—</span>
        </div>
        <div class="kpi-value">1</div>
        <div class="kpi-label">Entretiens planifiés</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon gold">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <span class="kpi-trend up">↑ +5</span>
        </div>
        <div class="kpi-value">12</div>
        <div class="kpi-label">Offres disponibles</div>
      </div>

      <div class="kpi-card">
        <div class="kpi-top">
          <div class="kpi-icon blue">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <span class="kpi-trend up">75%</span>
        </div>
        <div class="kpi-value">75%</div>
        <div class="kpi-label">Profil complété</div>
      </div>
    </div>

    <!-- Row 1: candidatures + completion -->
    <div class="content-row">

      <!-- Mes candidatures -->
      <div class="rh-card">
        <div class="rh-card-header">
          <div class="rh-card-header-left">
            <div class="rh-card-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <span class="rh-card-title">Mes Candidatures</span>
          </div>
          <a href="#" class="rh-card-action">
            Voir tout
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <div class="rh-card-body">
          <div class="candidature-list">

            <div class="candidature-item">
              <div class="ci-logo">TN</div>
              <div class="ci-info">
                <div class="ci-poste">Développeur Full Stack</div>
                <div class="ci-company">TechNova · Tunis</div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                <span class="status-badge en-cours">En cours</span>
                <span class="ci-date">Il y a 2 jours</span>
              </div>
            </div>

            <div class="candidature-item">
              <div class="ci-logo" style="background:linear-gradient(135deg,var(--gold),#a8832a);color:#1a0a2e;">AM</div>
              <div class="ci-info">
                <div class="ci-poste">Chef de Projet Digital</div>
                <div class="ci-company">Agora Media · Sfax</div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                <span class="status-badge attente">En attente</span>
                <span class="ci-date">Il y a 5 jours</span>
              </div>
            </div>

            <div class="candidature-item">
              <div class="ci-logo" style="background:linear-gradient(135deg,#2563eb,#1e40af);">DS</div>
              <div class="ci-info">
                <div class="ci-poste">Data Analyst Junior</div>
                <div class="ci-company">DataSphere · Remote</div>
              </div>
              <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                <span class="status-badge accepte">Accepté</span>
                <span class="ci-date">Il y a 1 semaine</span>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Profile completion -->
      <div class="rh-card completion-card">
        <div class="rh-card-header">
          <div class="rh-card-header-left">
            <div class="rh-card-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="rh-card-title">Profil</span>
          </div>
          <a href="{{ path('app_candidat_profile') }}" class="rh-card-action">Compléter →</a>
        </div>
        <div class="rh-card-body">
          <div class="completion-percent">75%</div>
          <div class="completion-label">de votre profil est complété</div>
          <div class="progress-bar-wrap">
            <div class="progress-bar-fill" style="width: 75%"></div>
          </div>
          <div class="completion-steps">
            <div class="completion-step">
              <div class="step-check done"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
              <span class="step-text done">Informations personnelles</span>
            </div>
            <div class="completion-step">
              <div class="step-check done"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
              <span class="step-text done">Niveau d'étude</span>
            </div>
            <div class="completion-step">
              <div class="step-check done"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
              <span class="step-text done">Expérience</span>
            </div>
            <div class="completion-step">
              <div class="step-check todo"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
              <span class="step-text todo">Photo de profil</span>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content-row -->

    <!-- Row 2: offres + activité -->
    <div class="content-row" style="animation-delay:0.1s;">

      <!-- Offres recommandées -->
      <div class="rh-card">
        <div class="rh-card-header">
          <div class="rh-card-header-left">
            <div class="rh-card-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <span class="rh-card-title">Offres recommandées</span>
          </div>
          <a href="#" class="rh-card-action">Toutes les offres →</a>
        </div>
        <div class="rh-card-body">

          <div class="offre-item">
            <div class="offre-logo">NX</div>
            <div class="offre-info">
              <div class="offre-poste">UX Designer</div>
              <div class="offre-meta">
                <span>Nexio · Tunis</span>
                <span class="offre-tag">CDI</span>
                <span class="offre-tag">Présentiel</span>
              </div>
            </div>
            <a href="#" class="btn-postuler">Postuler</a>
          </div>

          <div class="offre-item">
            <div class="offre-logo" style="background:linear-gradient(135deg,var(--purple),var(--purple-light));color:var(--white);">SM</div>
            <div class="offre-info">
              <div class="offre-poste">Développeur React</div>
              <div class="offre-meta">
                <span>SoftMark · Remote</span>
                <span class="offre-tag">Freelance</span>
                <span class="offre-tag">Remote</span>
              </div>
            </div>
            <a href="#" class="btn-postuler">Postuler</a>
          </div>

          <div class="offre-item">
            <div class="offre-logo" style="background:linear-gradient(135deg,#2563eb,#1e40af);color:var(--white);">PL</div>
            <div class="offre-info">
              <div class="offre-poste">Product Manager</div>
              <div class="offre-meta">
                <span>Pixel Labs · Sousse</span>
                <span class="offre-tag">CDD</span>
                <span class="offre-tag">Hybride</span>
              </div>
            </div>
            <a href="#" class="btn-postuler">Postuler</a>
          </div>

        </div>
      </div>

      <!-- Activité récente -->
      <div class="rh-card">
        <div class="rh-card-header">
          <div class="rh-card-header-left">
            <div class="rh-card-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <span class="rh-card-title">Activité récente</span>
          </div>
        </div>
        <div class="rh-card-body">
          <div class="activity-list">
            <div class="activity-item">
              <div class="activity-dot green"></div>
              <div style="flex:1;">
                <div class="activity-text">Candidature <strong>acceptée</strong> — DataSphere</div>
                <div class="activity-time">Il y a 1 semaine</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot purple"></div>
              <div style="flex:1;">
                <div class="activity-text">Candidature envoyée à <strong>TechNova</strong></div>
                <div class="activity-time">Il y a 2 jours</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot gold"></div>
              <div style="flex:1;">
                <div class="activity-text">Profil mis à jour — <strong>expérience ajoutée</strong></div>
                <div class="activity-time">Il y a 3 jours</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot blue"></div>
              <div style="flex:1;">
                <div class="activity-text">Entretien planifié avec <strong>DataSphere</strong></div>
                <div class="activity-time">Demain à 10h00</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /row 2 -->

  </main>

</div><!-- /dashboard-shell -->

{% endblock %}
