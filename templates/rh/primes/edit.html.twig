{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.prime-edit-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.prime-edit-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.prime-edit-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.prime-edit-wrap { max-width:1000px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.prime-edit-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  gap:18px; flex-wrap:wrap; margin-bottom:28px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.prime-edit-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.4rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.prime-edit-title h1 i { font-size:2rem; -webkit-text-fill-color:var(--mv-600); }
.prime-edit-title p { margin:8px 0 0; color:#64748b; font-size:1.02rem; font-weight:500; }

/* Back button */
.btn-back-prime-edit {
  display:inline-flex; align-items:center; gap:9px; padding:11px 22px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.93rem; cursor:pointer;
  transition:all .2s; backdrop-filter:blur(10px); text-decoration:none;
}
.btn-back-prime-edit:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); box-shadow:0 8px 20px rgba(143,76,201,.16); color:var(--mv-700); }

/* Glass card */
.glass-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  padding:32px 36px;
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}

/* Employee box */
.employee-box-prime {
  padding:16px 20px; border-radius:14px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  border:1.5px solid rgba(179,157,219,.28);
  color:var(--mv-700); font-weight:800; font-size:1.05rem;
  display:flex; justify-content:space-between; align-items:center;
}

/* Form elements */
.form-label-prime-edit {
  display:block; margin-bottom:8px; font-weight:800; font-size:.88rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.06em;
}
.form-label-prime-edit i { margin-right:6px; color:var(--mv-600); }

.form-control-prime-edit {
  width:100%; padding:12px 16px; border-radius:14px;
  border:1.5px solid rgba(179,157,219,.28); background:var(--mv-50);
  font-family:inherit; font-size:.95rem; color:#0f172a;
  outline:none; transition:all .2s;
}
.form-control-prime-edit:focus { border-color:var(--mv-600); box-shadow:0 0 0 4px rgba(143,76,201,.14); background:#fff; }

.input-group-modern {
  display:flex; align-items:stretch;
}
.input-group-modern .form-control-prime-edit {
  border-top-right-radius:0; border-bottom-right-radius:0;
}
.input-group-text-modern {
  padding:12px 16px; border-radius:0 14px 14px 0;
  border:1.5px solid rgba(179,157,219,.28); border-left:none;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-weight:800; font-size:.9rem;
}

.conversion-info {
  margin-top:8px; padding:8px 12px; border-radius:10px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-size:.85rem; font-weight:700;
}

/* Buttons */
.btn-save-prime-edit {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit';
}
.btn-save-prime-edit:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

.btn-cancel-prime-edit {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.95rem; cursor:pointer;
  transition:all .2s; text-decoration:none;
}
.btn-cancel-prime-edit:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); color:var(--mv-700); }

/* Alert */
.alert-modern {
  padding:16px 20px; border-radius:16px; margin-bottom:20px;
  background:#fff1f2; border:1.5px solid #fecdd3; color:#be123c;
  font-weight:700; display:flex; align-items:center; gap:10px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .prime-edit-head { flex-direction:column; align-items:flex-start; }
  .glass-card { padding:24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="prime-edit-shell">
  <div class="prime-edit-wrap">

    <!-- 🔙 BACK BUTTON & HEADER -->
    <div class="prime-edit-head">
      <div>
        <a href="{{ path('app_rh_prime_index') }}" class="btn-back-prime-edit">
          <i class="fas fa-arrow-left"></i> Retour aux Primes
        </a>
        <div class="prime-edit-title" style="margin-top:16px;">
          <h1><i class="fas fa-edit"></i> Modifier la Prime</h1>
          <p>Mettre à jour les informations de la prime d'employé</p>
        </div>
      </div>
    </div>

    <!-- FORM ERRORS -->
    {% if form_errors(form) %}
        <div class="alert-modern">
            <i class="fas fa-exclamation-triangle"></i>
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <!-- 💎 FORM CARD -->
    <div class="glass-card">

        <!-- 👤 EMPLOYEE (LOCKED) -->
        <div class="mb-4">
            <label class="form-label-prime-edit">
                <i class="fas fa-user-circle"></i> Employé
            </label>

            <div class="employee-box-prime">
                {{ prime.contract.employe.user.fullName }}
                <span class="badge bg-primary">Prime #{{ prime.id }}</span>
            </div>
        </div>

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        <div class="row g-4">

            <!-- 💰 MONTANT -->
            <div class="col-md-6">
                <label class="form-label-prime-edit">
                    <i class="fas fa-coins"></i> Montant
                </label>
                <div class="input-group-modern">
                    {{ form_widget(form.montant, {'attr': {'class': 'form-control-prime-edit'}}) }}
                    <span class="input-group-text-modern">{{ currency }}</span>
                </div>
                <div class="text-danger small mt-1">
                    {{ form_errors(form.montant) }}
                </div>
                {% if currency != 'TND' %}
                    <div id="conversionInfo" class="conversion-info">
                        💡 Conversion en cours...
                    </div>
                {% endif %}
            </div>

            <!-- 📅 DATE -->
            <div class="col-md-6">
                <label class="form-label-prime-edit">
                    <i class="fas fa-calendar-check"></i> Date d'attribution
                </label>
                {{ form_widget(form.date_attribution, {'attr': {'class': 'form-control-prime-edit'}}) }}
                <div class="text-danger small mt-1">
                    {{ form_errors(form.date_attribution) }}
                </div>
            </div>

            <!-- 📝 DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label-prime-edit">
                    <i class="fas fa-file-text"></i> Description
                </label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control-prime-edit', 'rows': '4'}}) }}
                <div class="text-danger small mt-1">
                    {{ form_errors(form.description) }}
                </div>
            </div>

        </div>

        <!-- 🔥 BUTTONS -->
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a href="{{ path('app_rh_prime_index') }}" class="btn-cancel-prime-edit">
                <i class="fas fa-times-circle"></i> Annuler
            </a>
            <button type="submit" class="btn-save-prime-edit">
                <i class="fas fa-save"></i> Mettre à jour
            </button>
        </div>

        {{ form_end(form) }}

    </div>

  </div>
</div>

<script>
const montantInput = document.querySelector('[name$="[montant]"]');

const rate = {{ rate }};
const currency = "{{ currency }}";

if (montantInput && currency !== "TND") {
    montantInput.addEventListener("input", function () {
        let value = parseFloat(this.value);
        if (!isNaN(value)) {
            let tnd = (value / rate).toFixed(2);
            document.getElementById("conversionInfo").innerText = `💡 ≈ ${tnd} TND`;
        } else {
            document.getElementById("conversionInfo").innerText = "💡 Conversion en cours...";
        }
    });
    
    // Show conversion on load
    if (montantInput.value) {
        let value = parseFloat(montantInput.value);
        if (!isNaN(value)) {
            let tnd = (value / rate).toFixed(2);
            document.getElementById("conversionInfo").innerText = `💡 ≈ ${tnd} TND`;
        }
    }
}

function showError(input, message) {
    let container = input.closest('.col-md-6, .col-md-12');
    let oldError = container.querySelector('.live-error');
    if (oldError) oldError.remove();

    let error = document.createElement('div');
    error.className = 'text-danger small live-error mt-1';
    error.innerText = message;
    container.appendChild(error);
}

function clearError(input) {
    let container = input.closest('.col-md-6, .col-md-12');
    let error = container.querySelector('.live-error');
    if (error) error.remove();
}

// Inputs
const montant = document.querySelector('[name$="[montant]"]');
const date = document.querySelector('[name$="[date_attribution]"]');

// Real-time validation
montant.addEventListener('input', () => {
    clearError(montant);
    if (montant.value && parseFloat(montant.value) <= 0) {
        showError(montant, "Montant doit être positif");
    }
});

date.addEventListener('change', () => {
    clearError(date);
    if (!date.value) {
        showError(date, "Date obligatoire");
    }
});

// Final validation
document.querySelector('form').addEventListener('submit', function(e) {
    let hasError = false;
    document.querySelectorAll('.live-error').forEach(el => el.remove());

    if (!montant.value || parseFloat(montant.value) <= 0) {
        showError(montant, "Montant invalide");
        hasError = true;
    }

    if (!date.value) {
        showError(date, "Date obligatoire");
        hasError = true;
    }

    if (hasError) {
        e.preventDefault();
    }
});
</script>

{% endblock %}