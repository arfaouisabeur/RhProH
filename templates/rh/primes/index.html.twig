{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.primes-index-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.primes-index-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.primes-index-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.primes-index-wrap { max-width:1400px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.primes-index-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  gap:18px; flex-wrap:wrap; margin-bottom:32px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.primes-index-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.6rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.primes-index-title h1 i { font-size:2.2rem; -webkit-text-fill-color:var(--mv-600); }
.primes-index-title p { margin:8px 0 0; color:#64748b; font-size:1.05rem; font-weight:500; }

/* New button */
.btn-new-prime {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit'; text-decoration:none;
}
.btn-new-prime:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); color:#fff; }

/* KPI Cards */
.kpi-grid {
  display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px; margin-bottom:32px;
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .1s both;
}
.kpi-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:20px; padding:24px 28px;
  box-shadow:0 10px 40px rgba(143,76,201,.08);
  transition:all .2s; position:relative; overflow:hidden;
}
.kpi-card:hover { transform:translateY(-4px); box-shadow:0 20px 60px rgba(143,76,201,.15); }
.kpi-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:4px;
  background:linear-gradient(90deg,var(--mv-600),var(--mv-500));
}
.kpi-icon {
  width:52px; height:52px; border-radius:16px;
  background:linear-gradient(135deg,var(--mv-600),var(--mv-500));
  display:flex; align-items:center; justify-content:center;
  font-size:24px; color:#fff; margin-bottom:16px;
}
.kpi-label { font-size:.9rem; color:#64748b; font-weight:600; margin-bottom:8px; text-transform:uppercase; letter-spacing:.05em; }
.kpi-value { font-family:'Outfit'; font-weight:900; font-size:2rem; color:var(--mv-950); margin:0; }
.kpi-trend { font-size:.85rem; color:#10b981; font-weight:700; margin-top:8px; }

/* Filter Card */
.filter-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:20px; padding:20px 24px; margin-bottom:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.08);
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}
.search-input {
  width:100%; max-width:400px; padding:12px 16px; border-radius:14px;
  border:1.5px solid rgba(179,157,219,.28); background:var(--mv-50);
  font-family:inherit; font-size:.95rem; color:#0f172a;
  outline:none; transition:all .2s;
}
.search-input:focus { border-color:var(--mv-600); box-shadow:0 0 0 4px rgba(143,76,201,.14); background:#fff; }
.btn-search {
  display:inline-flex; align-items:center; gap:8px; padding:12px 20px;
  border-radius:14px; border:none;
  background:linear-gradient(135deg,var(--mv-600),var(--mv-500));
  color:#fff; font-weight:800; font-size:.9rem; cursor:pointer;
  transition:all .2s; margin-left:12px;
}
.btn-search:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(143,76,201,.3); }

/* Table Card */
.table-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px; overflow:hidden;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .3s both;
}
.table-header {
  background:linear-gradient(135deg,var(--mv-950),var(--mv-800));
  color:#fff; padding:20px 24px;
  display:flex; justify-content:space-between; align-items:center;
}
.table-header h5 {
  margin:0; font-family:'Outfit'; font-weight:900; font-size:1.3rem;
  display:flex; align-items:center; gap:10px;
}
.table-responsive { max-height:600px; overflow-y:auto; }
.table {
  margin:0; font-size:.95rem; table-layout:fixed; width:100%;
}
.table thead {
  background:rgba(143,76,201,.08); position:sticky; top:0; z-index:10;
}
.table thead th {
  border:none; padding:16px 20px; font-weight:800; font-size:.85rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.05em;
}
.table tbody td {
  border:none; padding:16px 20px; vertical-align:middle;
  border-bottom:1px solid rgba(179,157,219,.12);
}
.table tbody tr:hover { background:rgba(143,76,201,.04); }

/* 🔥 COLUMN WIDTHS FOR BETTER SPACING */
.table th:nth-child(1), .table td:nth-child(1) { width: 25%; } /* Employé */
.table th:nth-child(2), .table td:nth-child(2) { width: 15%; min-width: 120px; } /* Montant */
.table th:nth-child(3), .table td:nth-child(3) { width: 15%; } /* Date */
.table th:nth-child(4), .table td:nth-child(4) { width: 30%; } /* Description */
.table th:nth-child(5), .table td:nth-child(5) { width: 15%; } /* Actions */

/* Badge styles */
.badge-amount {
  background:linear-gradient(135deg,#10b981,#059669);
  color:#fff; padding:8px 16px; border-radius:999px;
  font-weight:800; font-size:.9rem; font-family:'Outfit';
  white-space:nowrap; display:inline-block;
  min-width:80px; text-align:center;
}
.employee-name { font-weight:700; color:var(--mv-700); }
.date-text { color:#64748b; font-weight:600; white-space:nowrap; }
.description-text { 
  color:#475569; font-style:italic; 
  overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  max-width:200px;
}

/* Action buttons */
.btn-edit {
  display:inline-flex; align-items:center; justify-content:center;
  width:36px; height:36px; border-radius:10px; border:none;
  background:linear-gradient(135deg,#f59e0b,#d97706);
  color:#fff; font-size:14px; cursor:pointer;
  transition:all .2s; margin-right:8px;
}
.btn-edit:hover { transform:translateY(-2px); box-shadow:0 6px 16px rgba(245,158,11,.4); }

.btn-delete {
  display:inline-flex; align-items:center; justify-content:center;
  width:36px; height:36px; border-radius:10px; border:none;
  background:linear-gradient(135deg,#ef4444,#dc2626);
  color:#fff; font-size:14px; cursor:pointer;
  transition:all .2s;
}
.btn-delete:hover { transform:translateY(-2px); box-shadow:0 6px 16px rgba(239,68,68,.4); }

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .primes-index-head { flex-direction:column; align-items:flex-start; }
  .kpi-grid { grid-template-columns:1fr; }
  .filter-card .d-flex { flex-direction:column; gap:12px; }
  .btn-search { margin-left:0; }
}
</style>
{% endblock %}

{% block body %}
<div class="primes-index-shell">
  <div class="primes-index-wrap">

    <!-- 🔥 HEADER -->
    <div class="primes-index-head">
      <div class="primes-index-title">
        <h1><i class="fas fa-gem"></i> Primes</h1>
        <p>Gérez les primes et récompenses des employés</p>
      </div>
      <a href="{{ path('app_rh_prime_new') }}" class="btn-new-prime">
        <i class="fas fa-plus-circle"></i> Nouvelle Prime
      </a>
    </div>

    <!-- 🔥 KPI CARDS -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-icon">
          <i class="fas fa-award"></i>
        </div>
        <div class="kpi-label">Total Primes</div>
        <div class="kpi-value">{{ primes|length }}</div>
        <div class="kpi-trend">
          <i class="fas fa-arrow-up"></i> Primes attribuées
        </div>
      </div>

      <div class="kpi-card">
        <div class="kpi-icon">
          <i class="fas fa-coins"></i>
        </div>
        <div class="kpi-label">Montant Total</div>
        <div class="kpi-value">{{ total_montant }}</div>
        <div class="kpi-trend">
          <i class="fas fa-chart-line"></i> {{ currency }}
        </div>
      </div>
    </div>

    <!-- 🔍 FILTER -->
    <div class="filter-card">
      <div class="d-flex align-items-center">
        <input type="text" id="search" class="search-input"
               placeholder="🔍 Rechercher un employé...">
        <button class="btn-search">
          <i class="fas fa-search"></i> Rechercher
        </button>
      </div>
    </div>

    <!-- 💎 TABLE -->
    <div class="table-card">
      <div class="table-header">
        <h5><i class="fas fa-table"></i> Liste des Primes</h5>
        <span class="badge bg-light text-dark">{{ primes|length }} primes</span>
      </div>

      <div class="table-responsive">
        <table class="table align-middle mb-0" id="table">
          <thead>
            <tr>
              <th><i class="fas fa-user"></i> Employé</th>
              <th><i class="fas fa-coins"></i> Montant</th>
              <th><i class="fas fa-calendar"></i> Date</th>
              <th><i class="fas fa-file-text"></i> Description</th>
              <th><i class="fas fa-cogs"></i> Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for prime in primes %}
              <tr data-name="{{ prime.contract.employe.user.fullName|lower }}">
                <td class="employee-name">
                  <i class="fas fa-user-circle me-2" style="color:var(--mv-600);"></i>
                  {{ prime.contract.employe.user.fullName }}
                </td>
                <td>
                  <span class="badge-amount">
                    {{ prime.montant }} {{ currency }}
                  </span>
                </td>
                <td class="date-text">
                  <i class="fas fa-calendar-alt me-1" style="color:var(--mv-500);"></i>
                  {{ prime.dateAttribution|date('d/m/Y') }}
                </td>
                <td class="description-text">
                  {{ prime.description ?: '-' }}
                </td>
                <td>
                  <div class="d-flex align-items-center">
                    <!-- ✏ EDIT -->
                    <a href="{{ path('app_rh_prime_edit', {'id': prime.id}) }}" class="btn-edit">
                      <i class="fas fa-edit"></i>
                    </a>
                    <!-- 🗑 DELETE -->
                    <form method="post"
                          action="{{ path('app_rh_prime_delete', {'id': prime.id}) }}"
                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette prime ?');"
                          style="display:inline;">
                      <input type="hidden" name="_token"
                             value="{{ csrf_token('delete' ~ prime.id) }}">
                      <button class="btn-delete" type="submit">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="5" class="text-center py-5">
                  <div style="color:#64748b;">
                    <i class="fas fa-inbox" style="font-size:3rem;opacity:0.5;display:block;margin-bottom:12px;"></i>
                    <p style="font-weight:700;margin:0;">Aucune prime trouvée</p>
                    <p style="margin:4px 0 0;">Commencez par créer une nouvelle prime</p>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<!-- 🔥 SEARCH SCRIPT -->
<script>
const input = document.getElementById('search');
const rows = document.querySelectorAll('#table tbody tr');

input.addEventListener('input', function() {
    const value = this.value.toLowerCase();

    rows.forEach(row => {
        const name = row.dataset.name;
        if (name) {
            row.style.display = name.includes(value) ? '' : 'none';
        }
    });
});
</script>

{% endblock %}