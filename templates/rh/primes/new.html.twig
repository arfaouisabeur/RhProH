{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.prime-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.prime-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.prime-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.prime-wrap { max-width:1200px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.prime-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  gap:18px; flex-wrap:wrap; margin-bottom:28px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.prime-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.4rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.prime-title h1 i { font-size:2rem; -webkit-text-fill-color:var(--mv-600); }
.prime-title p { margin:8px 0 0; color:#64748b; font-size:1.02rem; font-weight:500; }

/* Back button */
.btn-back-prime {
  display:inline-flex; align-items:center; gap:9px; padding:11px 22px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.93rem; cursor:pointer;
  transition:all .2s; backdrop-filter:blur(10px); text-decoration:none;
}
.btn-back-prime:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); box-shadow:0 8px 20px rgba(143,76,201,.16); color:var(--mv-700); }

/* AI Button */
.btn-ai-prime {
  display:inline-flex; align-items:center; gap:9px; padding:11px 22px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:800; font-size:.93rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:inherit;
}
.btn-ai-prime:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

/* Glass card */
.glass-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  padding:32px 36px;
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}

/* Form elements */
.form-label-prime {
  display:block; margin-bottom:8px; font-weight:800; font-size:.88rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.06em;
}
.form-label-prime i { margin-right:6px; color:var(--mv-600); }

.form-control-prime {
  width:100%; padding:12px 16px; border-radius:14px;
  border:1.5px solid rgba(179,157,219,.28); background:var(--mv-50);
  font-family:inherit; font-size:.95rem; color:#0f172a;
  outline:none; transition:all .2s;
}
.form-control-prime:focus { border-color:var(--mv-600); box-shadow:0 0 0 4px rgba(143,76,201,.14); background:#fff; }

.input-group-modern {
  display:flex; align-items:stretch;
}
.input-group-modern .form-control-prime {
  border-top-right-radius:0; border-bottom-right-radius:0;
}
.input-group-text-modern {
  padding:12px 16px; border-radius:0 14px 14px 0;
  border:1.5px solid rgba(179,157,219,.28); border-left:none;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-weight:800; font-size:.9rem;
}

.conversion-info {
  margin-top:8px; padding:8px 12px; border-radius:10px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-size:.85rem; font-weight:700;
}

/* Search results */
.search-results-dropdown {
  position:absolute; top:100%; left:0; right:0; z-index:1000;
  background:#fff; border-radius:14px; margin-top:6px;
  border:1.5px solid rgba(179,157,219,.28);
  box-shadow:0 10px 30px rgba(143,76,201,.15);
  max-height:280px; overflow-y:auto;
}
.search-results-dropdown .list-group-item {
  padding:12px 16px; border:none; cursor:pointer;
  transition:background .15s; font-weight:600; color:#0f172a;
}
.search-results-dropdown .list-group-item:hover {
  background:rgba(143,76,201,.08);
}

/* Buttons */
.btn-save-modern {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit';
}
.btn-save-modern:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

.btn-cancel-modern {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.95rem; cursor:pointer;
  transition:all .2s; text-decoration:none;
}
.btn-cancel-modern:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); color:var(--mv-700); }

.btn-tache-select {
  display:inline-flex; align-items:center; gap:9px; padding:11px 20px;
  border-radius:14px; border:1.5px solid var(--mv-500);
  background:#fff; color:var(--mv-700);
  font-weight:800; font-size:.9rem; cursor:pointer;
  transition:all .2s; font-family:inherit;
}
.btn-tache-select:hover { background:var(--mv-100); transform:translateY(-2px); }

/* Alert */
.alert-modern {
  padding:16px 20px; border-radius:16px; margin-bottom:20px;
  background:#fff1f2; border:1.5px solid #fecdd3; color:#be123c;
  font-weight:700; display:flex; align-items:center; gap:10px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }
@keyframes modalPop  { from{opacity:0;transform:scale(.88);}to{opacity:1;transform:scale(1);} }

/* ── AI Modal ── */
.ai-modal-overlay {
  display:none; position:fixed; inset:0; z-index:10000;
  background:rgba(46,13,82,.65); backdrop-filter:blur(10px);
  align-items:center; justify-content:center;
}
.ai-modal-overlay.active { display:flex; }
.ai-modal-box {
  background:#fff; border-radius:28px; padding:0;
  width:85%; max-width:1000px; height:75vh;
  position:relative; overflow:hidden;
  box-shadow:0 32px 90px rgba(46,13,82,.3);
  animation:modalPop .35s cubic-bezier(.175,.885,.32,1.275);
  border-top:4px solid var(--mv-600);
  display:flex; flex-direction:column;
}
.ai-modal-header {
  background:linear-gradient(135deg,var(--mv-950),var(--mv-700));
  color:#fff; padding:20px 24px;
  display:flex; justify-content:space-between; align-items:center;
  flex-shrink:0;
}
.ai-modal-header h3 {
  margin:0; font-family:'Outfit'; font-weight:900; font-size:1.4rem;
  display:flex; align-items:center; gap:10px;
}
.ai-close-btn {
  width:40px; height:40px; border-radius:50%; border:none;
  background:rgba(255,255,255,.15); color:#fff;
  font-size:20px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:all .18s;
}
.ai-close-btn:hover { background:rgba(255,255,255,.25); transform:rotate(90deg); }
.ai-modal-body {
  flex:1; overflow:hidden; display:flex;
  min-height:0;
}
.ai-modal-body iframe {
  width:100%; height:100%; border:none;
  min-height:500px;
}

/* ── Tache Modal ── */
.tache-modal-overlay {
  display:none; position:fixed; inset:0; z-index:9998;
  background:rgba(46,13,82,.55); backdrop-filter:blur(8px);
  align-items:center; justify-content:center;
}
.tache-modal-box {
  background:#fff; border-radius:24px; padding:28px 32px;
  max-width:650px; width:95%; max-height:80vh; overflow-y:auto;
  position:relative;
  box-shadow:0 32px 90px rgba(46,13,82,.24);
  animation:modalPop .35s cubic-bezier(.175,.885,.32,1.275);
  border-top:4px solid var(--mv-600);
}
.tache-modal-header {
  display:flex; justify-content:space-between; align-items:center;
  margin-bottom:20px; padding-bottom:16px;
  border-bottom:2px solid rgba(143,76,201,.12);
}
.tache-modal-header h3 {
  margin:0; font-family:'Outfit'; font-weight:900; font-size:1.5rem;
  background:linear-gradient(135deg,var(--mv-950),var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.tache-close-btn {
  width:36px; height:36px; border-radius:50%; border:none;
  background:var(--mv-50); color:#475569;
  font-size:16px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:all .18s;
}
.tache-close-btn:hover { background:var(--mv-100); color:var(--mv-700); }

.tache-item {
  display:flex; justify-content:space-between; align-items:center;
  border:1.5px solid rgba(179,157,219,.22); padding:14px 16px;
  border-radius:14px; margin-bottom:12px;
  transition:all .2s; cursor:pointer;
}
.tache-item:hover { background:rgba(143,76,201,.05); border-color:var(--mv-500); }
.tache-item input[type="checkbox"] {
  width:20px; height:20px; cursor:pointer; margin-right:12px;
  accent-color:var(--mv-600);
}
.tache-item-content { flex:1; }
.tache-item-title { font-weight:800; color:#0f172a; margin-bottom:4px; }
.tache-item-meta { font-size:.82rem; color:#64748b; }
.tache-item-montant { font-weight:900; color:var(--mv-700); font-size:1.1rem; }

.tache-total {
  margin-top:20px; padding:16px 20px; border-radius:14px;
  background:linear-gradient(135deg,rgba(143,76,201,.12),rgba(179,157,219,.08));
  display:flex; justify-content:space-between; align-items:center;
}
.tache-total-label { font-weight:800; color:var(--mv-700); font-size:1.05rem; }
.tache-total-value { font-family:'Outfit'; font-weight:900; font-size:1.8rem; color:var(--mv-950); }

.tache-actions {
  margin-top:24px; display:flex; gap:12px; justify-content:flex-end;
  flex-wrap:wrap;
}
.btn-tache-apply {
  display:inline-flex; align-items:center; gap:9px; padding:12px 24px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit';
}
.btn-tache-apply:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

.btn-tache-copy {
  display:inline-flex; align-items:center; gap:9px; padding:12px 24px;
  border-radius:999px; border:1.5px solid var(--mv-500);
  background:#fff; color:var(--mv-700);
  font-weight:800; font-size:.95rem; cursor:pointer;
  transition:all .2s; font-family:inherit;
}
.btn-tache-copy:hover { background:var(--mv-100); transform:translateY(-2px); }

.copy-success {
  position:fixed; top:20px; right:20px; z-index:10000;
  background:linear-gradient(135deg,#10b981,#059669);
  color:#fff; padding:14px 20px; border-radius:14px;
  font-weight:800; box-shadow:0 10px 30px rgba(16,185,129,.3);
  animation:slideDown .3s ease-out;
}

/* Quote Generator Styles */
.description-container {
  position:relative;
}
.btn-quote-generator {
  display:inline-flex; align-items:center; gap:8px; padding:10px 18px;
  border-radius:14px; border:1.5px solid var(--mv-500);
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-weight:800; font-size:.9rem; cursor:pointer;
  transition:all .2s; margin-top:8px; font-family:inherit;
}
.btn-quote-generator:hover { 
  background:linear-gradient(135deg,var(--mv-100),var(--mv-50)); 
  border-color:var(--mv-600); transform:translateY(-2px);
}
.btn-quote-generator:disabled {
  opacity:0.6; cursor:not-allowed; transform:none;
}
.btn-quote-generator.loading {
  background:linear-gradient(135deg,var(--mv-600),var(--mv-500));
  color:#fff; border-color:var(--mv-600);
}
.quote-attribution {
  margin-top:8px; padding:8px 12px; border-radius:10px;
  background:linear-gradient(135deg,rgba(16,185,129,.08),rgba(16,185,129,.05));
  color:#059669; font-size:.85rem; font-weight:700; font-style:italic;
  display:none;
}
.quote-attribution.show {
  display:block; animation:slideUp .3s ease-out;
}

@media(max-width:768px){
  .prime-head { flex-direction:column; align-items:flex-start; }
  .glass-card { padding:24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="prime-shell">
  <div class="prime-wrap">

    <!-- 🔙 BACK BUTTON & HEADER -->
    <div class="prime-head">
      <div>
        <a href="{{ path('app_rh_prime_index') }}" class="btn-back-prime">
          <i class="fas fa-arrow-left"></i> Retour aux Primes
        </a>
        <div class="prime-title" style="margin-top:16px;">
          <h1><i class="fas fa-gem"></i> Ajouter une Prime</h1>
          <p>Attribuer une prime à un employé pour ses tâches accomplies</p>
        </div>
      </div>
    </div>

    <!-- FORM ERRORS -->
    {% if form_errors(form) %}
        <div class="alert-modern">
            <i class="fas fa-exclamation-triangle"></i>
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <!-- 💎 FORM CARD -->
    <div class="glass-card">

{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'primeForm'}}) }}

        <div class="row g-4">

            <!-- EMPLOYEE SEARCH -->
            <div class="col-md-12 position-relative">
                <label class="form-label-prime">
                    <i class="fas fa-user-circle"></i> Employé
                </label>

                <!-- SEARCH INPUT -->
                <input type="text" id="employeeSearch" class="form-control-prime"
                       placeholder="🔍 Rechercher un employé par nom...">

                <!-- RESULTS -->
                <div id="results" class="search-results-dropdown"></div>

                <!-- HIDDEN SELECT -->
                <div style="display:none;">
                    {{ form_widget(form.contract) }}
                </div>

                <!-- ERROR -->
                <div class="text-danger small mt-1">
                    {{ form_errors(form.contract) }}
                </div>
            </div>

            <!-- MONTANT -->
            <div class="col-md-6">
                <label class="form-label-prime">
                    <i class="fas fa-coins"></i> Montant
                </label>
                <div class="input-group-modern">
                    {{ form_widget(form.montant, {
                        'attr': {'class': 'form-control-prime', 'placeholder': 'Ex: 500'}
                    }) }}
                    <span class="input-group-text-modern">{{ currency }}</span>
                </div>
                <div class="text-danger small mt-1">
                    {{ form_errors(form.montant) }}
                </div>
                {% if currency != 'TND' %}
                    <div id="conversionInfo" class="conversion-info">
                        💡 Conversion en cours...
                    </div>
                {% endif %}
                <button type="button" class="btn-tache-select mt-3" onclick="openTacheModal()">
                    <i class="fas fa-tasks"></i> Sélectionner des tâches
                </button>
            </div>

            <!-- DATE -->
            <div class="col-md-6">
                <label class="form-label-prime">
                    <i class="fas fa-calendar-check"></i> Date d'attribution
                </label>
                {{ form_widget(form.date_attribution, {
                    'attr': {'class': 'form-control-prime'}
                }) }}
                <div class="text-danger small mt-1">
                    {{ form_errors(form.date_attribution) }}
                </div>
            </div>

            <!-- DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label-prime">
                    <i class="fas fa-file-text"></i> Description
                </label>
                <div class="description-container">
                    {{ form_widget(form.description, {
                        'attr': {'class': 'form-control-prime', 'placeholder': 'Ajouter une description motivante...', 'rows': '4'}
                    }) }}
                    <button type="button" class="btn-quote-generator" onclick="generateMotivationalQuote()">
                        <i class="fas fa-lightbulb"></i> <span id="quoteButtonText">Générer Citation Motivante</span>
                    </button>
                </div>
                <div class="text-danger small mt-1">
                    {{ form_errors(form.description) }}
                </div>
                <div id="quoteAttribution" class="quote-attribution"></div>
            </div>

        </div>

        <!-- HIDDEN INPUT FOR SELECTED TACHES -->
        <input type="hidden" name="selected_taches" id="selectedTachesInput">

        <!-- SUBMIT -->
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a href="{{ path('app_rh_prime_index') }}" class="btn-cancel-modern">
                <i class="fas fa-times-circle"></i> Annuler
            </a>
            <button type="submit" class="btn-save-modern">
                <i class="fas fa-check-circle"></i> Enregistrer
            </button>
        </div>

        {{ form_end(form) }}

    </div>

  </div>
</div>

<!-- ══════════════════════════════════════════════════
     AI MODAL WITH CHATBASE IFRAME
══════════════════════════════════════════════════ -->
<div id="aiModal" class="ai-modal-overlay">
  <div class="ai-modal-box">
    <div class="ai-modal-header">
      <h3><i class="fas fa-robot"></i> Assistant IA - Analyse des Tâches</h3>
      <button class="ai-close-btn" onclick="closeAIModal()">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="ai-modal-body">
      <iframe src="https://www.chatbase.co/chatbot-iframe/B4HmaVFkyrAprVXBeURfp" 
              frameborder="0">
      </iframe>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════
     TACHE SELECTION MODAL
══════════════════════════════════════════════════ -->
<div id="tacheModal" class="tache-modal-overlay">
  <div class="tache-modal-box">
    <div class="tache-modal-header">
      <h3><i class="fas fa-tasks"></i> Sélectionner des tâches</h3>
      <button class="tache-close-btn" onclick="closeTacheModal()">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div id="tacheList"></div>
    <div class="tache-total">
      <span class="tache-total-label">Total sélectionné:</span>
      <span class="tache-total-value"><span id="totalMontant">0</span> {{ currency }}</span>
    </div>
    <div class="tache-actions">
      <button type="button" class="btn-tache-copy" onclick="copySelectedTachesData()">
        <i class="fas fa-copy"></i> Copier pour AI
      </button>
      <button type="button" class="btn-ai-prime" onclick="openAIModal()">
        <i class="fas fa-robot"></i> AI Assistant
      </button>
      <button type="button" class="btn-tache-apply" onclick="applyTaches()">
        <i class="fas fa-check"></i> Appliquer
      </button>
    </div>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════
// TACHES DATA & DEFAULT MONTANT CALCULATION
// ══════════════════════════════════════════════════
let taches = [
{% for t in taches %}
    {
        id: {{ t.id }},
        titre: "{{ t.titre|e('js') }}",
        description: "",
        statut: "{{ t.statut }}",
        level: "{{ t.montant }}", // Level value (converted to currency)
        date_debut: "",
        date_fin: "",
        projet_id: null,
        montant: {{ t.montant }},
        employe_id: {{ t.employe_id ?? 'null' }}
    }{% if not loop.last %},{% endif %}
{% endfor %}
];

// Note: The montant represents the level value calculated by the controller
</script>

<script>
// ══════════════════════════════════════════════════
// TACHE MODAL FUNCTIONS
// ══════════════════════════════════════════════════
let selectedTaches = [];

function openTacheModal() {
    const hiddenSelect = document.getElementById('{{ form.contract.vars.id }}');
    const selectedOption = hiddenSelect.options[hiddenSelect.selectedIndex];
    const selectedEmployeId = selectedOption.dataset.employe;

    if (!selectedEmployeId) {
        alert('⚠️ Veuillez d\'abord sélectionner un employé');
        return;
    }

    document.getElementById('tacheModal').style.display = 'flex';
    selectedTaches = [];
    updateTotal();

    let container = document.getElementById('tacheList');
    container.innerHTML = '';

    const employeeTaches = taches.filter(t => 
        t.employe_id == selectedEmployeId &&
        t.statut.toLowerCase() === "done"
    );

    if (employeeTaches.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:40px;color:#64748b;"><i class="fas fa-inbox" style="font-size:3rem;opacity:0.5;display:block;margin-bottom:12px;"></i><p style="font-weight:700;">Aucune tâche terminée pour cet employé</p></div>';
        return;
    }

    employeeTaches.forEach(t => {
        container.innerHTML += `
            <div class="tache-item">
                <input type="checkbox" onchange="toggleTache(${t.id}, ${t.montant}, this)" id="tache_${t.id}">
                <div class="tache-item-content">
                    <div class="tache-item-title">${t.titre}</div>
                    <div class="tache-item-meta">
                        <i class="fas fa-check-circle" style="color:#10b981;"></i> ${t.statut}
                    </div>
                </div>
                <div class="tache-item-montant">${t.montant} {{ currency }}</div>
            </div>
        `;
    });
}

function calculateDuration(dateDebut, dateFin) {
    if (!dateDebut || !dateFin) return 'N/A';
    const start = new Date(dateDebut);
    const end = new Date(dateFin);
    const diffTime = Math.abs(end - start);
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
    return `${diffDays} jour${diffDays > 1 ? 's' : ''}`;
}

function toggleTache(id, montant, checkbox) {
    let index = selectedTaches.findIndex(t => t.id === id);

    if (checkbox.checked && index === -1) {
        const tache = taches.find(t => t.id === id);
        selectedTaches.push(tache);
    } else if (!checkbox.checked && index !== -1) {
        selectedTaches.splice(index, 1);
    }

    updateTotal();
}

function updateTotal() {
    let total = selectedTaches.reduce((sum, t) => sum + t.montant, 0);
    document.getElementById('totalMontant').innerText = total;
}

function applyTaches() {
    let total = selectedTaches.reduce((sum, t) => sum + t.montant, 0);

    // Set montant
    document.querySelector('[name$="[montant]"]').value = total;

    // Send IDs to backend
    let ids = selectedTaches.map(t => t.id);
    document.getElementById('selectedTachesInput').value = JSON.stringify(ids);

    closeTacheModal();
    
    // Show success message
    showSuccessMessage('✅ Tâches appliquées avec succès!');
}

function copySelectedTachesData() {
    if (selectedTaches.length === 0) {
        alert('⚠️ Veuillez sélectionner au moins une tâche');
        return;
    }

    let copyText = "TÂCHES SÉLECTIONNÉES POUR ANALYSE IA:\n\n";
    
    selectedTaches.forEach((t, index) => {
        copyText += `═══ TÂCHE ${index + 1} ═══\n`;
        copyText += `ID: ${t.id}\n`;
        copyText += `Titre: ${t.titre}\n`;
        copyText += `Statut: ${t.statut}\n`;
        copyText += `Level: ${t.level}\n`;
        copyText += `\n`;
    });

    copyText += `═══ RÉSUMÉ ═══\n`;
    copyText += `Total tâches sélectionnées: ${selectedTaches.length}\n`;

    navigator.clipboard.writeText(copyText).then(() => {
        showSuccessMessage('📋 Données copiées! Collez-les dans l\'AI Assistant');
    }).catch(err => {
        alert('❌ Erreur lors de la copie: ' + err);
    });
}

function openAIModal() {
    if (selectedTaches.length === 0) {
        alert('⚠️ Veuillez d\'abord sélectionner des tâches');
        return;
    }
    document.getElementById('aiModal').classList.add('active');
}

function closeAIModal() {
    document.getElementById('aiModal').classList.remove('active');
}

function closeTacheModal() {
    document.getElementById('tacheModal').style.display = 'none';
}

function showSuccessMessage(message) {
    const div = document.createElement('div');
    div.className = 'copy-success';
    div.innerHTML = `<i class="fas fa-check-circle"></i> ${message}`;
    document.body.appendChild(div);
    
    setTimeout(() => {
        div.style.opacity = '0';
        div.style.transform = 'translateY(-20px)';
        setTimeout(() => div.remove(), 300);
    }, 3000);
}

// Close modal when clicking outside
window.onclick = function(e) {
    const tacheModal = document.getElementById('tacheModal');
    const aiModal = document.getElementById('aiModal');
    
    if (e.target === tacheModal) {
        closeTacheModal();
    }
    if (e.target === aiModal) {
        closeAIModal();
    }
}

// ══════════════════════════════════════════════════
// 🎯 MOTIVATIONAL QUOTE GENERATOR
