<script>
// ══════════════════════════════════════════════════
// FORM VALIDATION & CURRENCY CONVERSION
// ══════════════════════════════════════════════════
const montantInput = document.querySelector('[name$="[montant]"]');
const rate = {{ rate }};
const currency = "{{ currency }}";

// Currency conversion
if (montantInput && currency !== "TND") {
    montantInput.addEventListener("input", function () {
        let value = parseFloat(this.value);
        if (!isNaN(value)) {
            let tnd = (value / rate).toFixed(2);
            document.getElementById("conversionInfo").innerText = `💡 ≈ ${tnd} TND`;
        } else {
            document.getElementById("conversionInfo").innerText = "💡 Conversion en cours...";
        }
    });
}

// Validation helpers
function showError(input, message) {
    let container = input.closest('.col-md-6, .col-md-12');
    let oldError = container.querySelector('.live-error');
    if (oldError) oldError.remove();

    let error = document.createElement('div');
    error.className = 'text-danger small live-error mt-1';
    error.innerText = message;
    container.appendChild(error);
}

function clearError(input) {
    let container = input.closest('.col-md-6, .col-md-12');
    let error = container.querySelector('.live-error');
    if (error) error.remove();
}

const montant = document.querySelector('[name$="[montant]"]');
const date = document.querySelector('[name$="[date_attribution]"]');

// Real-time validation
montant.addEventListener('input', () => {
    clearError(montant);
    if (montant.value && parseFloat(montant.value) <= 0) {
        showError(montant, "Montant doit être positif");
    }
});

date.addEventListener('change', () => {
    clearError(date);
    if (!date.value) {
        showError(date, "Date obligatoire");
    }
});

// Submit validation
document.querySelector('form').addEventListener('submit', function(e) {
    let hasError = false;
    document.querySelectorAll('.live-error').forEach(el => el.remove());

    if (!montant.value || parseFloat(montant.value) <= 0) {
        showError(montant, "Montant invalide");
        hasError = true;
    }

    if (!date.value) {
        showError(date, "Date obligatoire");
        hasError = true;
    }

    if (hasError) e.preventDefault();
});
</script>

<script>
// ══════════════════════════════════════════════════
// EMPLOYEE SEARCH
// ══════════════════════════════════════════════════
const input = document.getElementById('employeeSearch');
const results = document.getElementById('results');
const hiddenSelect = document.getElementById('{{ form.contract.vars.id }}');

// 🔥 ENSURE NO EMPLOYEE IS PRE-SELECTED ON PAGE LOAD
hiddenSelect.selectedIndex = 0; // Select the empty option (first option)
input.dataset.selected = "false";

input.addEventListener('input', function() {
    input.dataset.selected = "false";
    const value = this.value.toLowerCase();
    results.innerHTML = '';

    Array.from(hiddenSelect.options).forEach(option => {
        if (!option.value) return; // Skip empty option

        if (option.text.toLowerCase().includes(value)) {
            const item = document.createElement('a');
            item.className = 'list-group-item list-group-item-action';
            item.textContent = option.text;

            item.onclick = () => {
                input.value = option.text;
                hiddenSelect.value = option.value;
                input.dataset.selected = "true";
                results.innerHTML = '';
            };

            results.appendChild(item);
        }
    });
});

// 🔥 CLEAR SELECTION WHEN INPUT IS CLEARED
input.addEventListener('keyup', function() {
    if (this.value.trim() === '') {
        hiddenSelect.selectedIndex = 0; // Reset to empty option
        input.dataset.selected = "false";
        results.innerHTML = '';
    }
});
</script>

