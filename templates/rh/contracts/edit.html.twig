{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.contract-edit-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.contract-edit-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.contract-edit-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.contract-edit-wrap { max-width:1000px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.contract-edit-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  gap:18px; flex-wrap:wrap; margin-bottom:28px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.contract-edit-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.4rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.contract-edit-title h1 i { font-size:2rem; -webkit-text-fill-color:var(--mv-600); }
.contract-edit-title p { margin:8px 0 0; color:#64748b; font-size:1.02rem; font-weight:500; }

/* Back button */
.btn-back-contract-edit {
  display:inline-flex; align-items:center; gap:9px; padding:11px 22px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.93rem; cursor:pointer;
  transition:all .2s; backdrop-filter:blur(10px); text-decoration:none;
}
.btn-back-contract-edit:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); box-shadow:0 8px 20px rgba(143,76,201,.16); color:var(--mv-700); }

/* Glass card */
.glass-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  padding:32px 36px;
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}

/* Employee box */
.employee-box {
  padding:16px 20px; border-radius:14px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  border:1.5px solid rgba(179,157,219,.28);
  color:var(--mv-700); font-weight:800; font-size:1.05rem;
  display:flex; justify-content:space-between; align-items:center;
}
.badge-id {
  background:var(--mv-600); color:#fff; padding:4px 12px;
  border-radius:999px; font-size:.8rem; font-weight:900;
}

/* Form elements */
.form-label-contract-edit {
  display:block; margin-bottom:8px; font-weight:800; font-size:.88rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.06em;
}
.form-label-contract-edit i { margin-right:6px; color:var(--mv-600); }

.form-control-contract-edit {
  width:100%; padding:12px 16px; border-radius:14px;
  border:1.5px solid rgba(179,157,219,.28); background:var(--mv-50);
  font-family:inherit; font-size:.95rem; color:#0f172a;
  outline:none; transition:all .2s;
}
.form-control-contract-edit:focus { border-color:var(--mv-600); box-shadow:0 0 0 4px rgba(143,76,201,.14); background:#fff; }

.input-group-modern {
  display:flex; align-items:stretch;
}
.input-group-modern .form-control-contract-edit {
  border-top-right-radius:0; border-bottom-right-radius:0;
}
.input-group-text-modern {
  padding:12px 16px; border-radius:0 14px 14px 0;
  border:1.5px solid rgba(179,157,219,.28); border-left:none;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-weight:800; font-size:.9rem;
}

.conversion-info {
  margin-top:8px; padding:8px 12px; border-radius:10px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-size:.85rem; font-weight:700;
}

/* Buttons */
.btn-save-contract-edit {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit';
}
.btn-save-contract-edit:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

.btn-cancel-contract-edit {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.95rem; cursor:pointer;
  transition:all .2s; text-decoration:none;
}
.btn-cancel-contract-edit:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); color:var(--mv-700); }

/* Alert */
.alert-modern {
  padding:16px 20px; border-radius:16px; margin-bottom:20px;
  background:#fff1f2; border:1.5px solid #fecdd3; color:#be123c;
  font-weight:700; display:flex; align-items:center; gap:10px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .contract-edit-head { flex-direction:column; align-items:flex-start; }
  .glass-card { padding:24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="contract-edit-shell">
  <div class="contract-edit-wrap">

    <!-- 🔙 BACK BUTTON & HEADER -->
    <div class="contract-edit-head">
      <div>
        <a href="{{ path('app_rh_contract_index') }}" class="btn-back-contract-edit">
          <i class="fas fa-arrow-left"></i> Retour aux Contrats
        </a>
        <div class="contract-edit-title" style="margin-top:16px;">
          <h1><i class="fas fa-edit"></i> Modifier le Contrat</h1>
          <p>Mettre à jour les informations du contrat d'employé</p>
        </div>
      </div>
    </div>

    <!-- FORM ERRORS -->
    {% if form_errors(form) %}
        <div class="alert-modern">
            <i class="fas fa-exclamation-triangle"></i>
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <!-- 💎 FORM CARD -->
    <div class="glass-card">

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <!-- 👤 EMPLOYEE (LOCKED) -->
        <div class="mb-4">
            <label class="form-label-contract-edit">
                <i class="fas fa-user-circle"></i> Employé
            </label>

            <div class="employee-box">
                {{ contract.employe.user.fullName }}
                <span class="badge-id">
                    {{ contract.employe.matricule }}
                </span>
            </div>
        </div>

        <div class="row g-4">

            <!-- 📅 START -->
            <div class="col-md-6">
                <label class="form-label-contract-edit">
                    <i class="fas fa-calendar-plus"></i> Date de Début
                </label>
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control-contract-edit'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_debut) }}
                </div>
            </div>

            <!-- 📅 END -->
            <div class="col-md-6">
                <label class="form-label-contract-edit">
                    <i class="fas fa-calendar-minus"></i> Date de Fin
                </label>
                {{ form_widget(form.date_fin, {'attr': {'class': 'form-control-contract-edit'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_fin) }}
                </div>
            </div>

            <!-- TYPE -->
            <div class="col-md-6">
                <label class="form-label-contract-edit">
                    <i class="fas fa-tag"></i> Type
                </label>
                {{ form_widget(form.type, {'attr': {'class': 'form-control-contract-edit'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.type) }}
                </div>
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label-contract-edit">
                    <i class="fas fa-info-circle"></i> Statut
                </label>
                {{ form_widget(form.statut, {'attr': {'class': 'form-control-contract-edit'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.statut) }}
                </div>
            </div>

            <!-- 💰 SALARY -->
            <div class="col-md-6">
                <label class="form-label-contract-edit">
                    <i class="fas fa-coins"></i> Salaire
                </label>

                <div class="input-group-modern">
                    {{ form_widget(form.salaire_base, {'attr': {'class': 'form-control-contract-edit'}}) }}
                    <span class="input-group-text-modern">{{ currency }}</span>
                </div>

                <div class="text-danger small">
                    {{ form_errors(form.salaire_base) }}
                </div>

                {% if currency != 'TND' %}
                    <div id="conversionInfo" class="conversion-info">
                        💡 Conversion en cours...
                    </div>
                {% endif %}
            </div>

            <!-- 📝 DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label-contract-edit">
                    <i class="fas fa-file-text"></i> Description
                </label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control-contract-edit', 'rows': '4'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.description) }}
                </div>
            </div>

        </div>

        <!-- 🔥 BUTTONS -->
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a href="{{ path('app_rh_contract_index') }}" class="btn-cancel-contract-edit">
                <i class="fas fa-times-circle"></i> Annuler
            </a>
            <button type="submit" class="btn-save-contract-edit">
                <i class="fas fa-save"></i> Mettre à jour
            </button>
        </div>

        {{ form_end(form) }}

    </div>

  </div>
</div>

<script>
const salaireInput = document.querySelector('[name$="[salaire_base]"]');

const rate = {{ rate }};
const currency = "{{ currency }}";

if (salaireInput && currency !== "TND") {

    function updateConversion() {
        let value = parseFloat(salaireInput.value);

        if (!isNaN(value)) {
            let tnd = (value / rate).toFixed(2);

            document.getElementById("conversionInfo").innerText =
                `💡 ≈ ${tnd} TND`;
        }
    }

    salaireInput.addEventListener("input", updateConversion);

    // 🔥 IMPORTANT: show on page load
    updateConversion();
}
</script>

<!-- 🔥 REAL-TIME VALIDATION -->
<script>
const start = document.querySelector('[name$="[date_debut]"]');
const end = document.querySelector('[name$="[date_fin]"]');
const salary = document.querySelector('[name$="[salaire_base]"]');
const type = document.querySelector('[name$="[type]"]');

function showError(input, message) {
    let error = input.parentElement.querySelector('.live-error');

    if (!error) {
        error = document.createElement('div');
        error.className = 'text-danger small live-error';
        input.parentElement.appendChild(error);
    }

    error.innerText = message;
}

function clearError(input) {
    const error = input.parentElement.querySelector('.live-error');
    if (error) error.remove();
}

// DATE CHECK
function validateDates() {
    clearError(end);

    if (!start.value || !end.value) return;

    if (new Date(end.value) <= new Date(start.value)) {
        showError(end, "End date must be after start date");
    }
}

start.addEventListener('change', validateDates);
end.addEventListener('change', validateDates);

// SALARY
salary.addEventListener('input', () => {
    clearError(salary);
    if (salary.value && parseFloat(salary.value) <= 0) {
        showError(salary, "Salary must be positive");
    }
});

// TYPE
type.addEventListener('input', () => {
    clearError(type);
    if (type.value.length > 0 && type.value.length < 3) {
        showError(type, "Min 3 characters");
    }
});

// SUBMIT BLOCK
document.querySelector('form').addEventListener('submit', function(e) {

    let hasError = false;

    document.querySelectorAll('.live-error').forEach(el => el.remove());

    if (!start.value || !end.value || new Date(end.value) <= new Date(start.value)) {
        showError(end, "Invalid dates");
        hasError = true;
    }

    if (!salary.value || parseFloat(salary.value) <= 0) {
        showError(salary, "Invalid salary");
        hasError = true;
    }

    if (!type.value || type.value.length < 3) {
        showError(type, "Invalid type");
        hasError = true;
    }

    if (hasError) e.preventDefault();
});
</script>

{% endblock %}