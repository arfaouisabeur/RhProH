

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; }

/* ── Shell ── */
.contract-form-shell {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 20% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.contract-form-shell::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:560px; height:560px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat1 9s ease-in-out infinite;
}
.contract-form-shell::after {
  content:''; position:fixed; bottom:-120px; left:-120px;
  width:420px; height:420px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0; animation:orbFloat2 11s ease-in-out infinite;
}
.contract-form-wrap { max-width:1000px; margin:0 auto; position:relative; z-index:1; }

/* ── Header ── */
.contract-form-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  gap:18px; flex-wrap:wrap; margin-bottom:28px;
  animation:slideDown .7s cubic-bezier(.16,1,.3,1) both;
}
.contract-form-title h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.4rem; margin:0;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  display:flex; align-items:center; gap:14px;
}
.contract-form-title h1 i { font-size:2rem; -webkit-text-fill-color:var(--mv-600); }
.contract-form-title p { margin:8px 0 0; color:#64748b; font-size:1.02rem; font-weight:500; }

/* Back button */
.btn-back-contract-form {
  display:inline-flex; align-items:center; gap:9px; padding:11px 22px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.93rem; cursor:pointer;
  transition:all .2s; backdrop-filter:blur(10px); text-decoration:none;
}
.btn-back-contract-form:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); box-shadow:0 8px 20px rgba(143,76,201,.16); color:var(--mv-700); }

/* Glass card */
.glass-card {
  background:rgba(255,255,255,.87);
  backdrop-filter:blur(22px); -webkit-backdrop-filter:blur(22px);
  border:1.5px solid rgba(179,157,219,.28);
  border-radius:24px;
  box-shadow:0 10px 40px rgba(143,76,201,.10);
  padding:32px 36px;
  animation:slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}

/* Form elements */
.form-label-contract {
  display:block; margin-bottom:8px; font-weight:800; font-size:.88rem;
  color:var(--mv-700); text-transform:uppercase; letter-spacing:.06em;
}
.form-label-contract i { margin-right:6px; color:var(--mv-600); }

.form-control-contract {
  width:100%; padding:12px 16px; border-radius:14px;
  border:1.5px solid rgba(179,157,219,.28); background:var(--mv-50);
  font-family:inherit; font-size:.95rem; color:#0f172a;
  outline:none; transition:all .2s;
}
.form-control-contract:focus { border-color:var(--mv-600); box-shadow:0 0 0 4px rgba(143,76,201,.14); background:#fff; }

.input-group-modern {
  display:flex; align-items:stretch;
}
.input-group-modern .form-control-contract {
  border-top-right-radius:0; border-bottom-right-radius:0;
}
.input-group-text-modern {
  padding:12px 16px; border-radius:0 14px 14px 0;
  border:1.5px solid rgba(179,157,219,.28); border-left:none;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-weight:800; font-size:.9rem;
}

.conversion-info {
  margin-top:8px; padding:8px 12px; border-radius:10px;
  background:linear-gradient(135deg,rgba(143,76,201,.08),rgba(179,157,219,.05));
  color:var(--mv-700); font-size:.85rem; font-weight:700;
}

/* Search results */
.search-results-dropdown {
  position:absolute; top:100%; left:0; right:0; z-index:1000;
  background:#fff; border-radius:14px; margin-top:6px;
  border:1.5px solid rgba(179,157,219,.28);
  box-shadow:0 10px 30px rgba(143,76,201,.15);
  max-height:280px; overflow-y:auto;
}
.search-results-dropdown .list-group-item {
  padding:12px 16px; border:none; cursor:pointer;
  transition:background .15s; font-weight:600; color:#0f172a;
}
.search-results-dropdown .list-group-item:hover {
  background:rgba(143,76,201,.08);
}

/* Status text */
.status-text {
  margin-top:8px; font-weight:700; font-size:.85rem;
}

/* Country selector */
.country-card {
  background:rgba(255,255,255,.6); border-radius:16px; padding:20px;
  border:1.5px solid rgba(179,157,219,.22); margin-top:16px;
}
.salary-suggestion {
  background:linear-gradient(135deg,rgba(16,185,129,.12),rgba(16,185,129,.08));
  border:1.5px solid rgba(16,185,129,.22); border-radius:14px;
  padding:12px 16px; margin-top:12px; color:#047857;
  font-weight:700; display:none;
}

/* Buttons */
.btn-save-contract {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:none;
  background:linear-gradient(135deg,var(--mv-700),var(--mv-600));
  color:#fff; font-weight:900; font-size:.95rem; cursor:pointer;
  transition:all .2s; box-shadow:0 8px 20px var(--mv-glow);
  font-family:'Outfit';
}
.btn-save-contract:hover { transform:translateY(-2px); box-shadow:0 12px 26px var(--mv-glow); }

.btn-cancel-contract {
  display:inline-flex; align-items:center; gap:9px; padding:13px 26px;
  border-radius:999px; border:1.5px solid rgba(179,157,219,.35);
  background:rgba(255,255,255,.88); color:var(--mv-700);
  font-weight:800; font-size:.95rem; cursor:pointer;
  transition:all .2s; text-decoration:none;
}
.btn-cancel-contract:hover { background:#fff; border-color:var(--mv-500); transform:translateY(-2px); color:var(--mv-700); }

/* Alert */
.alert-modern {
  padding:16px 20px; border-radius:16px; margin-bottom:20px;
  background:#fff1f2; border:1.5px solid #fecdd3; color:#be123c;
  font-weight:700; display:flex; align-items:center; gap:10px;
}

/* Animations */
@keyframes slideDown { from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes orbFloat1 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(-28px,20px) scale(1.05);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0) scale(1);}50%{transform:translate(20px,-26px) scale(1.07);} }

@media(max-width:768px){
  .contract-form-head { flex-direction:column; align-items:flex-start; }
  .glass-card { padding:24px 20px; }
}
</style>
{% endblock %}

{% block body %}
<div class="contract-form-shell">
  <div class="contract-form-wrap">

    <!-- 🔙 BACK BUTTON & HEADER -->
    <div class="contract-form-head">
      <div>
        <a href="{{ path('app_rh_contract_index') }}" class="btn-back-contract-form">
          <i class="fas fa-arrow-left"></i> Retour aux Contrats
        </a>
        <div class="contract-form-title" style="margin-top:16px;">
          <h1><i class="fas fa-file-contract"></i> {{ form.vars.value.id ? 'Modifier le Contrat' : 'Créer un Contrat' }}</h1>
          <p>{{ form.vars.value.id ? 'Mettre à jour les informations du contrat' : 'Créer un nouveau contrat d\'employé' }}</p>
        </div>
      </div>
    </div>

    <!-- FORM ERRORS -->
    {% for message in app.flashes('error') %}
        <div class="alert-modern">
            <i class="fas fa-exclamation-triangle"></i>
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="alert-modern" style="background:#f0fdf4; border-color:#86efac; color:#166534;">
            <i class="fas fa-check-circle"></i>
            {{ message }}
        </div>
    {% endfor %}

    {% if form_errors(form) %}
        <div class="alert-modern">
            <i class="fas fa-exclamation-triangle"></i>
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <!-- 💎 FORM CARD -->
    <div class="glass-card">

        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}

        <div class="row g-4">

            <!-- 👤 EMPLOYEE SEARCH -->
            {% if form.employe is defined %}
            <div class="col-md-12 position-relative">
                <label class="form-label-contract">
                    <i class="fas fa-user-circle"></i> Employé
                </label>

                <input type="text" id="employeeSearch"
                       class="form-control-contract"
                       placeholder="🔍 Rechercher un employé...">

                <small id="selectedEmployee" class="status-text"></small>

                <div id="results" class="search-results-dropdown"></div>

                <!-- hidden select -->
                <div style="display:none;">
                    {{ form_widget(form.employe) }}
                </div>

                <!-- 🔥 ERROR -->
                <div class="text-danger small">
                    {{ form_errors(form.employe) }}
                </div>
            </div>
            {% endif %}

            <!-- 📅 START -->
            <div class="col-md-6">
                <label class="form-label-contract">
                    <i class="fas fa-calendar-plus"></i> Date de Début
                </label>
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control-contract'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_debut) }}
                </div>
            </div>

            <!-- 📅 END -->
            <div class="col-md-6">
                <label class="form-label-contract">
                    <i class="fas fa-calendar-minus"></i> Date de Fin
                </label>
                {{ form_widget(form.date_fin, {'attr': {'class': 'form-control-contract'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.date_fin) }}
                </div>
            </div>

            <!-- TYPE -->
            <div class="col-md-6">
                <label class="form-label-contract">
                    <i class="fas fa-tag"></i> Type
                </label>
                {{ form_widget(form.type, {'attr': {'class': 'form-control-contract'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.type) }}
                </div>
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label class="form-label-contract">
                    <i class="fas fa-info-circle"></i> Statut
                </label>
                {{ form_widget(form.statut, {'attr': {'class': 'form-control-contract'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.statut) }}
                </div>
            </div>

            <!-- 💰 SALARY -->
           <div class="col-md-6">
                <label class="form-label-contract">
                    <i class="fas fa-coins"></i> Salaire
                </label>

                <div class="input-group-modern">
                    {{ form_widget(form.salaire_base, {'attr': {'class': 'form-control-contract'}}) }}
                    <span class="input-group-text-modern">{{ currency }}</span>
                </div>

                <div class="text-danger small">
                    {{ form_errors(form.salaire_base) }}
                </div>

                {% if currency != 'TND' %}
                    <div id="conversionInfo" class="conversion-info">
                        💡 Conversion en cours...
                    </div>
                {% endif %}
            </div>

            <!-- COUNTRY SELECTOR -->
            <div class="col-md-6">
                <div class="country-card">
                    <label class="form-label-contract">
                        <i class="fas fa-globe"></i> Pays (pour suggestion de salaire)
                    </label>

                   <select id="countrySelect" class="form-control-contract" onchange="loadSalary()">
                        <option value="">-- Sélectionner un Pays --</option>
                        <option value="TN">Tunisie 🇹🇳</option>
                        <option value="FR">France 🇫🇷</option>
                        <option value="US">USA 🇺🇸</option>
                        <option value="DE">Allemagne 🇩🇪</option>
                        <option value="IT">Italie 🇮🇹</option>
                        <option value="ES">Espagne 🇪🇸</option>
                        <option value="CA">Canada 🇨🇦</option>
                        <option value="GB">Royaume-Uni 🇬🇧</option>
                        <option value="AE">Émirats Arabes Unis 🇦🇪</option>
                        <option value="SA">Arabie Saoudite 🇸🇦</option>
                        <option value="MA">Maroc 🇲🇦</option>
                        <option value="DZ">Algérie 🇩🇿</option>
                        <option value="EG">Égypte 🇪🇬</option>
                        <option value="IN">Inde 🇮🇳</option>
                        <option value="CN">Chine 🇨🇳</option>
                        <option value="JP">Japon 🇯🇵</option>
                    </select>

                    <div id="salaryBox" class="salary-suggestion">
                        💰 Salaire moyen: <span id="salaryValue"></span>
                    </div>
                </div>
            </div>
            <!-- 📝 DESCRIPTION -->
            <div class="col-md-12">
                <label class="form-label-contract">
                    <i class="fas fa-file-text"></i> Description
                </label>
                {{ form_widget(form.description, {'attr': {'class': 'form-control-contract', 'rows': '4'}}) }}
                <div class="text-danger small">
                    {{ form_errors(form.description) }}
                </div>
            </div>

        </div>

        <!-- 🔥 BUTTONS -->
        <div class="d-flex justify-content-end gap-3 mt-4">
            <a href="{{ path('app_rh_contract_index') }}" class="btn-cancel-contract">
                <i class="fas fa-times-circle"></i> Annuler
            </a>
            <button type="submit" class="btn-save-contract">
                <i class="fas fa-save"></i> Enregistrer
            </button>
        </div>

        {{ form_end(form) }}

    </div>

  </div>
</div>

<script>
function loadSalary() {
    let country = document.getElementById('countrySelect').value;

    if (!country) return;

    fetch(`/rh/contracts/api/average-salary?country=${country}`)
        .then(res => res.json())
        .then(data => {

            let box = document.getElementById('salaryBox');
            let value = document.getElementById('salaryValue');

            if (data.salary) {
                value.innerHTML = `💰 Avg Salary: <b>${data.salary} ${data.currency}</b>`;
                box.style.display = 'block';
                document.querySelector('[name$="[salaire_base]"]').value = data.salary;
            } else {
                value.innerHTML = "❌ No data";
                box.style.display = 'block';
            }
        });
}
</script>

<script>
const salaireInput = document.querySelector('[name$="[salaire_base]"]');

const rate = {{ rate }};
const currency = "{{ currency }}";

if (salaireInput && currency !== "TND") {

    function updateConversion() {
        let value = parseFloat(salaireInput.value);

        if (!isNaN(value)) {
            let tnd = (value / rate).toFixed(2);

            document.getElementById("conversionInfo").innerText =
                `💡 ≈ ${tnd} TND`;
        }
    }

    salaireInput.addEventListener("input", updateConversion);

    // 🔥 IMPORTANT → show on load
    updateConversion();
}
</script>

<script>
// 🔥 REAL-TIME VALIDATION

function showError(input, message) {
    let error = input.parentElement.querySelector('.live-error');

    if (!error) {
        error = document.createElement('div');
        error.className = 'text-danger small live-error mt-1';
        input.parentElement.appendChild(error);
    }

    error.innerText = message;
}

function clearError(input) {
    const error = input.parentElement.querySelector('.live-error');
    if (error) error.remove();
}

// 📅 DATE VALIDATION
const startDate = document.querySelector('[name$="[date_debut]"]');
const endDate = document.querySelector('[name$="[date_fin]"]');

function validateDates() {
    clearError(endDate);

    if (!startDate.value || !endDate.value) return;

    const start = new Date(startDate.value);
    const end = new Date(endDate.value);

    if (end <= start) {
        showError(endDate, "End date must be after start date");
    }
}

startDate.addEventListener('change', validateDates);
endDate.addEventListener('change', validateDates);

// 💰 SALARY VALIDATION
const salary = document.querySelector('[name$="[salaire_base]"]');

salary.addEventListener('input', () => {
    clearError(salary);

    if (!salary.value) return;

    if (parseFloat(salary.value) <= 0) {
        showError(salary, "Salary must be positive");
    }
});

// 📝 TYPE VALIDATION
const type = document.querySelector('[name$="[type]"]');

type.addEventListener('input', () => {
    clearError(type);

    if (type.value.length > 0 && type.value.length < 3) {
        showError(type, "Minimum 3 characters");
    }
});

// 🔥 FINAL SUBMIT BLOCK (IMPORTANT)
document.querySelector('form').addEventListener('submit', function(e) {

    let hasError = false;

    // reset
    document.querySelectorAll('.live-error').forEach(el => el.remove());

    // check salary
    if (!salary.value || parseFloat(salary.value) <= 0) {
        showError(salary, "Invalid salary");
        hasError = true;
    }

    // check type
    if (!type.value || type.value.length < 3) {
        showError(type, "Invalid type");
        hasError = true;
    }

    // check dates
    if (!startDate.value || !endDate.value) {
        showError(endDate, "Dates required");
        hasError = true;
    } else {
        const start = new Date(startDate.value);
        const end = new Date(endDate.value);

        if (end <= start) {
            showError(endDate, "End date must be after start date");
            hasError = true;
        }
    }

    if (hasError) {
        e.preventDefault();
    }
});
</script>
<!-- 🔥 SCRIPT -->
<script>
const input = document.getElementById('employeeSearch');
const results = document.getElementById('results');
const hiddenSelect = document.getElementById('{{ form.employe.vars.id }}');
const selectedText = document.getElementById('selectedEmployee');

// 🔁 FIX EDIT PREFILL
window.addEventListener('DOMContentLoaded', () => {
    const selectedOption = hiddenSelect.options[hiddenSelect.selectedIndex];

    if (selectedOption && selectedOption.value) {
        input.value = selectedOption.text;
        hiddenSelect.value = selectedOption.value;
        selectedText.innerText = "✔ " + selectedOption.text;
        selectedText.style.color = "green";
    }
});

// 🔍 SEARCH
input.addEventListener('input', function() {

    const value = this.value.toLowerCase();
    results.innerHTML = '';

    Array.from(hiddenSelect.options).forEach(option => {

        if (!option.value) return;

        if (option.text.toLowerCase().includes(value)) {

            const item = document.createElement('a');
            item.className = 'list-group-item list-group-item-action';
            item.textContent = option.text;

            item.onclick = async () => {

                input.value = option.text;
                hiddenSelect.value = option.value;

                hiddenSelect.dispatchEvent(new Event('change'));

                try {
                    const response = await fetch('/rh/contracts/check-active/' + option.value);
                    const data = await response.json();

                    if (data.hasActive) {
                        selectedText.innerHTML = "❌ Already has active contract";
                        selectedText.style.color = "#dc2626";
                    } else {
                        selectedText.innerHTML = "✔ Available";
                        selectedText.style.color = "#16a34a";
                    }

                } catch (e) {
                    selectedText.innerHTML = "⚠ Error checking";
                    selectedText.style.color = "orange";
                }

                results.innerHTML = '';
            };

            results.appendChild(item);
        }

    });

});

// 🔥 SAFE SUBMIT
document.querySelector('form').addEventListener('submit', function(e) {

    if (!hiddenSelect.value || hiddenSelect.value === "") {
        e.preventDefault();
        alert('⚠ Please select an employee!');
    }

});
</script>


