{% extends 'rh/admin_base.html.twig' %}

{% block title %}Détails Utilisateur - RH{% endblock %}

{% block page_title %}Profil Utilisateur{% endblock %}
{% block page_subtitle %}Consultez les informations détaillées du profil{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-10">
        
        <!-- Profile Header Card -->
        <div class="admin-card mb-4">
            <div class="row align-items-center">
                <div class="col-md-auto text-center mb-3 mb-md-0">
                    {% if user.avatarPath %}
                        <img src="{{ asset(user.avatarPath) }}" style="width:120px; height:120px; border-radius:30px; object-fit:cover; box-shadow: 0 10px 25px rgba(0,0,0,0.1);" alt="Avatar">
                    {% else %}
                        <div class="mx-auto d-flex align-items-center justify-content-center text-white" style="width:120px; height:120px; border-radius:30px; background: linear-gradient(135deg, var(--purple-dark), var(--purple-mid)); font-size: 3rem; font-weight: 800; box-shadow: 0 10px 25px rgba(102, 34, 131, 0.2);">
                            {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                        </div>
                    {% endif %}
                </div>
                <div class="col-md ms-md-4">
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h2 class="fw-bold text-dark mb-0">{{ user.fullName }}</h2>
                        <span class="badge-soft {% if user.role == 'ROLE_RH' %}badge-soft-purple{% elseif user.role == 'ROLE_EMPLOYE' %}badge-soft-success{% else %}badge-soft-warning{% endif %}">
                            {{ user.role }}
                        </span>
                    </div>
                    <div class="d-flex flex-wrap gap-4 text-muted">
                        <span><i class="bi bi-envelope me-2"></i>{{ user.email }}</span>
                        <span><i class="bi bi-telephone me-2"></i>{{ user.telephone ?: '-' }}</span>
                        <span><i class="bi bi-geo-alt me-2"></i>{{ user.adresse ?: 'Non renseigné' }}</span>
                    </div>
                </div>
                <div class="col-md-auto text-md-end mt-4 mt-md-0">
                    <a href="{{ path('app_rh_dashboard') }}" class="btn-light-purple me-2">
                        <i class="bi bi-arrow-left me-2"></i>Retour
                    </a>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Basic Info -->
            <div class="col-md-6">
                <div class="admin-card h-100">
                    <div class="admin-card-title">
                        <div class="admin-card-title-icon"><i class="bi bi-person-lines-fill"></i></div>
                        Informations de base
                    </div>
                    <div class="d-flex flex-column gap-3">
                        <div class="border-bottom pb-2">
                            <label class="text-muted small fw-bold text-uppercase">Prénom</label>
                            <div class="fw-medium text-dark">{{ user.prenom }}</div>
                        </div>
                        <div class="border-bottom pb-2">
                            <label class="text-muted small fw-bold text-uppercase">Nom</label>
                            <div class="fw-medium text-dark">{{ user.nom }}</div>
                        </div>
                        <div class="border-bottom pb-2">
                            <label class="text-muted small fw-bold text-uppercase">Statut du compte</label>
                            <div>
                                {% if user.statut == 'actif' %}
                                    <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> ACTIF</span>
                                {% else %}
                                    <span class="text-warning fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> INACTIF</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Role Specific Info -->
            <div class="col-md-6">
                {% if user.candidat %}
                    <div class="admin-card h-100">
                        <div class="admin-card-title">
                            <div class="admin-card-title-icon"><i class="bi bi-mortarboard-fill"></i></div>
                            Fiche Candidat
                        </div>
                        <div class="d-flex flex-column gap-3">
                            <div class="border-bottom pb-2">
                                <label class="text-muted small fw-bold text-uppercase">Niveau d'études</label>
                                <div class="fw-medium text-dark">{{ user.candidat.niveauEtude ?: '-' }}</div>
                            </div>
                            <div class="border-bottom pb-2">
                                <label class="text-muted small fw-bold text-uppercase">Expérience professionnelle</label>
                                <div class="fw-medium text-dark">{{ user.candidat.experience }} ans</div>
                            </div>
                        </div>
                    </div>
                {% elseif user.employe %}
                    <div class="admin-card h-100">
                        <div class="admin-card-title">
                            <div class="admin-card-title-icon"><i class="bi bi-briefcase-fill"></i></div>
                            Fiche Employé
                        </div>
                        <div class="d-flex flex-column gap-3">
                            <div class="border-bottom pb-2">
                                <label class="text-muted small fw-bold text-uppercase">Matricule</label>
                                <div class="fw-bold text-purple" style="color: var(--purple-dark);">{{ user.employe.matricule }}</div>
                            </div>
                            <div class="border-bottom pb-2">
                                <label class="text-muted small fw-bold text-uppercase">Poste / Fonction</label>
                                <div class="fw-medium text-dark">{{ user.employe.position }}</div>
                            </div>
                            <div class="border-bottom pb-2">
                                <label class="text-muted small fw-bold text-uppercase">Date d'embauche</label>
                                <div class="fw-medium text-dark"><i class="bi bi-calendar-check me-2"></i>{{ user.employe.dateEmbauche|date('d/m/Y') }}</div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="admin-card h-100 d-flex flex-column align-items-center justify-content-center text-center">
                         <div class="admin-card-title-icon mb-3" style="width:60px; height:60px; font-size: 1.5rem;"><i class="bi bi-shield-lock"></i></div>
                         <h5 class="fw-bold">Administrateur</h5>
                         <p class="text-muted">Ce profil dispose des droits d'administration RH complets.</p>
                    </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
