        </div>
        <div class="cb-chips">
            <button class="cb-chip" onclick="envoyer('tâches bloquées')">🔴 Tâches bloquées</button>
            <button class="cb-chip" onclick="envoyer('projets en retard')">⏰ Projets en retard</button>
            <button class="cb-chip" onclick="envoyer('employé surchargé')">👤 Employé surchargé</button>
            <button class="cb-chip" onclick="envoyer('statistiques générales')">📊 Statistiques</button>
            <button class="cb-chip" onclick="envoyer('avancement des projets')">📈 Avancement</button>
            <button class="cb-chip" onclick="envoyer('tâches non assignées')">⚠️ Non assignées</button>
            <button class="cb-chip" onclick="envoyer('charge de l équipe')">⚖️ Charge équipe</button>
            <button class="cb-chip" onclick="envoyer('meilleur projet')">🏆 Meilleur projet</button>
        </div>
