                    <circle cx="12" cy="27.5" r="1.6" fill="#c4b5fd"/><circle cx="17" cy="27.5" r="1.6" fill="#a78bfa"/><circle cx="22" cy="27.5" r="1.6" fill="#8b5cf6"/>
                </svg>
            </div>
            <div class="cb-meta">
