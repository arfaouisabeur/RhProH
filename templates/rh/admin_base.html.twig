<script>
// ── Toggle chatbot ──
function cbToggle(){
    const box=document.getElementById('cb-box');
    const open=box.style.display==='block';
    box.style.display=open?'none':'block';
    if(!open)setTimeout(()=>document.getElementById('cb-inp').focus(),150);
}

// ── Synthèse vocale ──
function parler(texte) {
    if (!window.speechSynthesis) return;
    
    // Arrêter toute synthèse en cours
    window.speechSynthesis.cancel();
    
    // Attendre un peu pour que le cancel soit effectif
    setTimeout(function() {
        // Nettoyer les emojis et caractères spéciaux pour la voix
        const propre = texte.replace(/[\u{1F000}-\u{1FFFF}]/gu, '')
                            .replace(/[█░•]/g, '')
                            .replace(/[^\wÀ-ÿ\s\.,!?;:'-]/gu, ' ')
                            .replace(/\s+/g, ' ')
                            .replace(/\n/g, '. ')
                            .trim();
        
        // Limiter la longueur
        const texteLimit = propre.length > 500 ? propre.substring(0, 497) + '...' : propre;
        
        if (!texteLimit) return;
        
        console.log('[Vocal Admin] Synthèse:', texteLimit);
        
        const utterance = new SpeechSynthesisUtterance(texteLimit);
        utterance.lang = 'fr-FR';
        utterance.rate = 0.9;
        utterance.pitch = 1.0;
        utterance.volume = 1.0;
        
        // Gestionnaires d'événements
        utterance.onstart = function() {
            console.log('[Vocal Admin] ✅ Démarré');
        };
        
        utterance.onend = function() {
            console.log('[Vocal Admin] ✅ Terminé');
        };
        
        utterance.onerror = function(e) {
            console.error('[Vocal Admin] ❌ Erreur:', e.error);
            // Retry avec un texte plus simple
            if (e.error === 'synthesis-failed') {
                setTimeout(function() {
                    const utterSimple = new SpeechSynthesisUtterance('Message vocal indisponible');
                    utterSimple.lang = 'fr-FR';
                    window.speechSynthesis.speak(utterSimple);
                }, 1000);
            }
        };
        
        // Choisir une voix française si disponible
        function lancerSynthese() {
            const voix = window.speechSynthesis.getVoices().find(v => 
                v.lang === 'fr-FR' && !v.name.includes('Google')
            ) || window.speechSynthesis.getVoices().find(v => 
                v.lang.startsWith('fr')
            );
            
            if (voix) {
                utterance.voice = voix;
                console.log('[Vocal Admin] Voix:', voix.name);
            }
            
            try {
                window.speechSynthesis.speak(utterance);
            } catch (error) {
                console.error('[Vocal Admin] Erreur speak:', error);
            }
        }
        
        // Vérifier si les voix sont chargées
        const voices = window.speechSynthesis.getVoices();
        if (voices.length > 0) {
            lancerSynthese();
        } else {
            window.speechSynthesis.onvoiceschanged = function() {
                lancerSynthese();
            };
        }
    }, 100);
}

// ── Reconnaissance vocale ──
let recognition = null;
let isListening = false;

function cbVoice() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
        alert('Votre navigateur ne supporte pas la reconnaissance vocale. Utilisez Chrome.');
        return;
    }

    const mic = document.getElementById('cb-mic');
    const inp = document.getElementById('cb-inp');

    if (isListening) {
        recognition.stop();
        return;
    }

    recognition = new SpeechRecognition();
    recognition.lang = 'fr-FR';
    recognition.continuous = false;
    recognition.interimResults = true;

    recognition.onstart = () => {
        isListening = true;
        mic.classList.add('listening');
        inp.placeholder = '🎤 Écoute en cours...';
    };

    recognition.onresult = (e) => {
        const transcript = Array.from(e.results)
            .map(r => r[0].transcript)
            .join('');
        inp.value = transcript;
        // Si résultat final, envoyer automatiquement
        if (e.results[e.results.length - 1].isFinal) {
            setTimeout(() => envoyer(), 300);
        }
    };

    recognition.onerror = (e) => {
        console.error('Erreur micro:', e.error);
        inp.placeholder = '❌ Erreur micro. Réessayez.';
        setTimeout(() => inp.placeholder = 'Posez une question ou cliquez 🎤...', 2000);
    };

    recognition.onend = () => {
        isListening = false;
        mic.classList.remove('listening');
        inp.placeholder = 'Posez une question ou cliquez 🎤...';
    };

    recognition.start();
}

// ── Envoi message ──
async function envoyer(texte){
    const input=document.getElementById('cb-inp');
    const msg=texte||input.value.trim();
    if(!msg)return;

    // Ouvrir le chat si fermé
    const box=document.getElementById('cb-box');
    if(box.style.display!=='block') box.style.display='block';

    const msgs=document.getElementById('cb-msgs');
    const du=document.createElement('div');
    du.className='cb-bubble-usr';
    du.textContent=msg;
    msgs.appendChild(du);
    input.value='';
    msgs.scrollTop=msgs.scrollHeight;

    const dt=document.createElement('div');
    dt.className='cb-row-bot';
    dt.innerHTML='<div class="cb-mini-av"><svg viewBox="0 0 18 18" fill="none"><circle cx="6" cy="9" r="2.5" fill="white" opacity=".9"/><circle cx="12" cy="9" r="2.5" fill="white" opacity=".9"/></svg></div><div class="cb-bubble-bot"><div class="cb-typing"><span></span><span></span><span></span></div></div>';
    msgs.appendChild(dt);
    msgs.scrollTop=msgs.scrollHeight;

    try{
        const url="/chatbot/ask";
        const res=await fetch(url,{
            method:'POST',
            credentials:'same-origin',
            headers:{
                'Content-Type':'application/json',
                'X-Requested-With':'XMLHttpRequest',
                'Accept':'application/json'
            },
            body:JSON.stringify({message:msg})
        });
        const text=await res.text();
        const clean=text.replace(/^\uFEFF/,'').trim();
        const bubble=dt.querySelector('.cb-bubble-bot');
        if(!clean.startsWith('{')){bubble.textContent='Erreur serveur';return;}
        const data=JSON.parse(clean);
        const reponse = data.reponse||'Pas de réponse';
        bubble.innerHTML=reponse.replace(/\n/g,'<br>');
        if(data.timestamp){
            const t=document.createElement('div');
            t.className='cb-ts';
            t.textContent=data.timestamp;
            bubble.appendChild(t);
        }
        // 🔊 Lire la réponse à voix haute
        parler(reponse);
    }catch(e){
        dt.querySelector('.cb-bubble-bot').textContent='Erreur : '+e.message;
    }
    msgs.scrollTop=msgs.scrollHeight;
}

// Charger les voix dès que disponibles
if (window.speechSynthesis) {
    // Forcer le chargement initial des voix
    window.speechSynthesis.getVoices();
    
    // Gestionnaire pour le chargement des voix (une seule fois)
    let voicesLoaded = false;
    window.speechSynthesis.onvoiceschanged = function() {
        if (!voicesLoaded) {
            voicesLoaded = true;
            const voices = window.speechSynthesis.getVoices();
            console.log('[Vocal Admin] Voix disponibles:', voices.length);
        }
    };
}
</script>

<script>
// Fonction pour gérer les dropdowns du sidebar
function toggleSidebarDropdown(button) {
    const dropdownMenu = button.nextElementSibling;
    const isOpen = button.classList.contains('open');
    
    // Fermer tous les autres dropdowns
    document.querySelectorAll('.dropdown-toggle-sidebar').forEach(btn => {
        if (btn !== button) {
            btn.classList.remove('open');
            btn.nextElementSibling.classList.remove('show');
        }
    });
    
    // Toggle le dropdown actuel
    if (isOpen) {
        button.classList.remove('open');
        dropdownMenu.classList.remove('show');
    } else {
        button.classList.add('open');
        dropdownMenu.classList.add('show');
    }
}

// Ouvrir automatiquement le dropdown si un de ses liens est actif
document.addEventListener('DOMContentLoaded', function() {
    const currentPath = window.location.pathname;
    
    document.querySelectorAll('.dropdown-menu-sidebar').forEach(menu => {
        const links = menu.querySelectorAll('.dropdown-item-sidebar');
        links.forEach(link => {
            if (currentPath.includes(link.getAttribute('href'))) {
                const toggleButton = menu.previousElementSibling;
                toggleButton.classList.add('open');
                menu.classList.add('show');
            }
        });
    });
});
</script>

