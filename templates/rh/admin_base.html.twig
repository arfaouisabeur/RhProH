    </button>

    <div id="cb-box">
        <div class="cb-hdr">
            <div class="cb-av">
                <svg viewBox="0 0 34 34" fill="none">
                    <rect x="5" y="3" width="24" height="18" rx="7" fill="rgba(255,255,255,.9)"/>
                    <circle cx="11.5" cy="12" r="3.2" fill="#6b2d8b"/><circle cx="12.5" cy="11" r="1" fill="white" opacity=".8"/>
                    <circle cx="22.5" cy="12" r="3.2" fill="#6b2d8b"/><circle cx="23.5" cy="11" r="1" fill="white" opacity=".8"/>
