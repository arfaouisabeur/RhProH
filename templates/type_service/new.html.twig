{% extends 'base.html.twig' %}

{% block title %}Nouveau type de service{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  * { box-sizing: border-box; }
  .app {
    font-family: 'Inter', sans-serif;
    background: radial-gradient(circle at top right, #eef2ff 0%, #ffffff 55%, #f5f3ff 100%);
    min-height: 90vh; padding: 40px 20px; color: #0f172a;
  }
  .wrap { max-width: 720px; margin: 0 auto; animation: fadeUp .6s ease-out; }
  .head { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; }
  .ic { width: 52px; height: 52px; border-radius: 18px; display: flex; align-items: center; justify-content: center; color: #fff;
       background: linear-gradient(135deg, #6366f1, #4f46e5); box-shadow: 0 12px 26px rgba(99,102,241,.28); }
  h1 { font-family: 'Outfit'; font-weight: 900; font-size: 2.1rem; margin: 0;
       background: linear-gradient(135deg, #312e81, #4f46e5); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .sub { margin: 6px 0 0 0; color: #64748b; font-weight: 600; }

  .info-banner {
    background: #eef2ff; border-left: 4px solid #6366f1;
    padding: 14px 18px; border-radius: 12px; margin-bottom: 24px;
    display: flex; gap: 14px; align-items: flex-start;
    color: #312e81; font-size: .95rem; line-height: 1.5;
  }
  .info-banner i { color: #6366f1; font-size: 1.1rem; margin-top: 2px; }

  .card {
    background: rgba(255,255,255,.8); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,.9); border-radius: 24px;
    box-shadow: 0 10px 40px rgba(79,70,229,.08); padding: 32px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; margin-bottom: 18px; }
  .lbl { font-size: .78rem; font-weight: 900; text-transform: uppercase; letter-spacing: .1em; color: #475569; }
  .ctl, .card input, .card select, .card textarea {
    width: 100%; border-radius: 14px; border: 1.5px solid #e2e8f0; background: #f8fafc;
    padding: 12px 14px; outline: none; font-family: inherit;
    transition: border-color .18s, box-shadow .18s, background .18s;
  }
  .card input:focus, .card select:focus, .card textarea:focus {
    border-color: #6366f1; background: #fff; box-shadow: 0 0 0 4px rgba(99,102,241,.12);
  }
  textarea { min-height: 110px; resize: vertical; }

  .actions { display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
             padding-top: 20px; border-top: 1px solid rgba(0,0,0,.05); margin-top: 8px; }
  .btn-back {
    display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    padding: 12px 18px; border-radius: 999px; font-weight: 900; color: #64748b;
    border: 1.5px solid rgba(148,163,184,.35); background: transparent; transition: all .18s;
  }
  .btn-back:hover { background: #fff; color: #0f172a; transform: translateY(-1px); }
  .btn-submit {
    display: inline-flex; align-items: center; gap: 8px; border: 0; cursor: pointer;
    padding: 12px 22px; border-radius: 999px; font-weight: 900; color: #fff; font-family: 'Outfit';
    background: linear-gradient(135deg, #6366f1, #4f46e5); box-shadow: 0 12px 26px rgba(99,102,241,.28);
    transition: transform .18s, box-shadow .18s;
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 16px 32px rgba(99,102,241,.36); }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
</style>
{% endblock %}

{% block body %}
<div class="app">
  <div class="wrap">
    <div class="head">
      <div class="ic"><i class="fas fa-plus"></i></div>
      <div>
        <h1>Nouveau type de service</h1>
        <div class="sub">Ajoutez un item dans une catégorie de service (ex. PC → Matériel Informatique).</div>
      </div>
    </div>

    <div class="card">
      <div class="info-banner">
        <i class="fas fa-info-circle"></i>
        <div>
          La <strong>catégorie</strong> est la famille (ex. <em>Matériel Informatique</em>).
          Le <strong>nom</strong> est l'item précis (ex. <em>PC portable</em>, <em>Souris</em>).
          Les employés choisissent d'abord la famille, puis l'item.
        </div>
      </div>

      {{ include('type_service/_form.html.twig', {'button_label': 'Créer le type'}) }}

      <div class="actions">
        <a class="btn-back" href="{{ path('app_type_service_index') }}">
          <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
      </div>
    </div>
  </div>
</div>
{% endblock %}
