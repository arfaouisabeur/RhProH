{% extends 'base.html.twig' %}

{% block title %}{{ type_service.nom }} — Type de Service{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

.app {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 15% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.app::before {
  content:''; position:fixed; top:-160px; right:-160px;
  width:520px; height:520px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.16), transparent 68%);
  pointer-events:none; z-index:0;
  animation: orbFloat 9s ease-in-out infinite;
}
.app::after {
  content:''; position:fixed; bottom:-100px; left:-100px;
  width:380px; height:380px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.14), transparent 68%);
  pointer-events:none; z-index:0;
  animation: orbFloat2 11s ease-in-out infinite;
}

.wrap {
  max-width:860px; margin:0 auto;
  position:relative; z-index:1;
  animation: slideUp .7s cubic-bezier(.16,1,.3,1) both;
}

/* Nav */
.nav-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:26px; }
.btn-back {
  display:inline-flex; align-items:center; gap:9px;
  color:#64748b; text-decoration:none; font-weight:700;
  padding:10px 20px; border-radius:999px;
  background:rgba(255,255,255,.9);
  border:1.5px solid rgba(179,157,219,.3);
  transition:.2s; box-shadow:0 4px 14px rgba(0,0,0,.06);
  backdrop-filter:blur(10px);
}
.btn-back:hover { background:#fff; color:var(--mv-700); border-color:var(--mv-500); transform:translateX(-2px); }

/* ── Hero ── */
.hero { border-radius:26px; overflow:hidden; box-shadow:0 18px 55px var(--mv-glow); margin-bottom:24px; }
.hero-head {
  padding:40px 44px; display:flex; justify-content:space-between; align-items:center;
  background: linear-gradient(135deg, var(--mv-950) 0%, var(--mv-700) 60%, var(--mv-600) 100%);
  position:relative; overflow:hidden;
}
.hero-head::before {
  content:''; position:absolute; top:-60px; right:-60px;
  width:280px; height:280px; border-radius:50%;
  background: radial-gradient(circle, rgba(255,255,255,.1), transparent);
  pointer-events:none;
}
.hero-head::after {
  content:'\f0b1'; font-family:'Font Awesome 6 Free'; font-weight:900;
  position:absolute; right:-20px; bottom:-30px; font-size:160px;
  color:rgba(255,255,255,.07); transform:rotate(-12deg);
  pointer-events:none;
}
.hero-head h2 {
  font-family:'Outfit'; font-weight:900; font-size:2.3rem;
  margin:0; color:#fff; line-height:1.1;
}
.hero-head .subtitle { margin:8px 0 0; color:rgba(255,255,255,.72); font-size:1.05rem; }
.cat-pill {
  background:rgba(255,255,255,.18); border:1.5px solid rgba(255,255,255,.32);
  padding:9px 20px; border-radius:999px; color:#fff;
  font-weight:800; font-size:.95rem;
  backdrop-filter:blur(10px); display:flex; align-items:center; gap:8px;
  flex-shrink:0;
  animation: pillSlide .6s cubic-bezier(.16,1,.3,1) .3s both;
}

/* ── Detail grid ── */
.detail-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:18px; padding:34px 40px;
  background:rgba(255,255,255,.88);
  backdrop-filter:blur(14px);
}
.detail-item {
  background: linear-gradient(135deg, #ffffff, var(--mv-50));
  border-radius:18px; padding:20px;
  border:1.5px solid rgba(179,157,219,.2);
  box-shadow:0 4px 14px rgba(143,76,201,.06);
  transition: transform .2s, box-shadow .2s, border-color .2s;
}
.detail-item:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(143,76,201,.12); border-color:rgba(143,76,201,.3); }
.detail-item.full { grid-column:1/-1; }
.dl-lbl { font-size:.76rem; font-weight:900; text-transform:uppercase; letter-spacing:.12em; color:#64748b; margin-bottom:8px; }
.dl-val {
  font-family:'Outfit'; font-size:1.22rem; font-weight:800;
  color:#0f172a; display:flex; align-items:center; gap:9px;
}
.dl-val i { color:var(--mv-600); font-size:1rem; }

/* ── Linked box ── */
.linked-box {
  background:rgba(255,255,255,.85); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px);
  border:1px solid rgba(179,157,219,.28); border-radius:24px;
  box-shadow:0 10px 36px rgba(143,76,201,.09);
  overflow:hidden; margin-bottom:24px;
  animation: slideUp .7s cubic-bezier(.16,1,.3,1) .2s both;
}
.linked-head {
  padding:20px 28px; border-bottom:1px solid rgba(143,76,201,.1);
  display:flex; justify-content:space-between; align-items:center;
  background: linear-gradient(135deg, rgba(143,76,201,.07), rgba(179,157,219,.04));
}
.linked-head h3 {
  font-family:'Outfit'; font-weight:900; font-size:1.22rem;
  margin:0; color:var(--mv-800);
  display:flex; align-items:center; gap:10px;
}
.badge-count {
  background: linear-gradient(135deg, var(--mv-700), var(--mv-600));
  color:#fff; border-radius:999px; padding:3px 12px;
  font-size:.82rem; font-weight:900;
  box-shadow:0 4px 10px var(--mv-glow);
}
.warn-tag {
  color:#b45309; background:#fffbeb; border:1px solid #fde68a;
  padding:5px 12px; border-radius:999px; font-size:.78rem; font-weight:800;
  display:flex; align-items:center; gap:5px;
}

.linked-table { width:100%; border-collapse:collapse; }
.linked-table th {
  text-align:left; padding:12px 28px; font-size:.78rem;
  text-transform:uppercase; letter-spacing:.12em;
  color:var(--mv-700); border-bottom:1px solid rgba(143,76,201,.1);
  font-weight:800; background:rgba(179,157,219,.04);
}
.linked-table td { padding:14px 28px; border-bottom:1px solid rgba(0,0,0,.04); vertical-align:middle; }
.linked-table tr:last-child td { border-bottom:none; }
.linked-table tr { transition:background .18s; }
.linked-table tr:hover td { background:rgba(143,76,201,.05); }
.linked-table td:first-child { font-weight:900; color:var(--mv-700); }

/* Pills */
.pill { padding:5px 13px; border-radius:999px; font-weight:800; font-size:.82rem; display:inline-flex; align-items:center; gap:7px; }
.pill::before { content:''; width:7px; height:7px; border-radius:50%; display:inline-block; }
.p-pend { background:#fffbeb; color:#b45309; border:1px solid #fde68a; } .p-pend::before { background:#f59e0b; animation:pulseDot 2s infinite; }
.p-ok   { background:#ecfdf5; color:#047857; border:1px solid #a7f3d0; } .p-ok::before   { background:#10b981; }
.p-no   { background:#fff1f2; color:#be123c; border:1px solid #fecdd3; } .p-no::before   { background:#f43f5e; }

/* Empty linked */
.no-linked {
  background:rgba(255,255,255,.8); border-radius:20px; padding:28px;
  text-align:center; margin-bottom:24px;
  border:1px dashed rgba(179,157,219,.35);
  animation: slideUp .6s ease-out .4s both;
}

/* Page actions */
.page-actions { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; animation: slideUp .6s ease-out .3s both; }
.btn-edit {
  display:inline-flex; align-items:center; gap:9px; text-decoration:none;
  padding:13px 26px; border-radius:999px; font-weight:900; color:#fff; font-family:'Outfit';
  background: linear-gradient(135deg, var(--mv-700), var(--mv-600));
  box-shadow:0 12px 28px var(--mv-glow);
  transition:transform .2s, box-shadow .2s;
  position:relative; overflow:hidden;
}
.btn-edit::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(255,255,255,.15), transparent);
  opacity:0; transition:opacity .2s;
}
.btn-edit:hover { transform:translateY(-3px); box-shadow:0 18px 38px var(--mv-glow); }
.btn-edit:hover::before { opacity:1; }

@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes pillSlide { from{opacity:0;transform:translateX(16px);}to{opacity:1;transform:translateX(0);} }
@keyframes orbFloat  { 0%,100%{transform:translate(0,0);}50%{transform:translate(-25px,18px);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0);}50%{transform:translate(18px,-22px);} }
@keyframes pulseDot  { 0%,100%{opacity:1;}50%{opacity:.4;} }

@media(max-width:640px){
  .detail-grid{grid-template-columns:1fr;padding:22px;}
  .hero-head{flex-direction:column;align-items:flex-start;gap:16px;padding:28px;}
  .page-actions{flex-direction:column;}
  .page-actions > *{width:100%;justify-content:center;}
}
</style>
{% endblock %}

{% block body %}
<div class="app">
  <div class="wrap">
    <div class="nav-bar">
      <a href="{{ path('app_type_service_index') }}" class="btn-back">
        <i class="fas fa-arrow-left"></i> Tous les types
      </a>
    </div>

    {# ── Hero ── #}
    <div class="hero">
      <div class="hero-head">
        <div>
          <h2>{{ type_service.nom }}</h2>
          <p class="subtitle">Fiche détaillée du type de service</p>
        </div>
        <div class="cat-pill"><i class="fas fa-folder-open"></i> {{ type_service.categorie }}</div>
      </div>
      <div class="detail-grid">
        <div class="detail-item">
          <div class="dl-lbl">Nom du type</div>
          <div class="dl-val"><i class="fas fa-tag"></i> {{ type_service.nom }}</div>
        </div>
        <div class="detail-item">
          <div class="dl-lbl">Catégorie</div>
          <div class="dl-val"><i class="fas fa-folder-open"></i> {{ type_service.categorie }}</div>
        </div>
        <div class="detail-item">
          <div class="dl-lbl">Identifiant</div>
          <div class="dl-val"><i class="fas fa-hashtag"></i> {{ type_service.id }}</div>
        </div>
        <div class="detail-item">
          <div class="dl-lbl">Demandes liées</div>
          <div class="dl-val"><i class="fas fa-file-alt"></i> {{ type_service.demandeServices|length }}</div>
        </div>
        {% if type_service.description %}
        <div class="detail-item full">
          <div class="dl-lbl">Description</div>
          <div style="color:#475569;line-height:1.75;margin-top:6px;font-style:italic;font-size:.97rem;">"{{ type_service.description }}"</div>
        </div>
        {% endif %}
      </div>
    </div>

    {# ── Demandes liées ── #}
    {% if type_service.demandeServices|length > 0 %}
    <div class="linked-box">
      <div class="linked-head">
        <h3><i class="fas fa-link"></i> Demandes liées <span class="badge-count">{{ type_service.demandeServices|length }}</span></h3>
        <span class="warn-tag"><i class="fas fa-exclamation-triangle"></i> Suppression en cascade</span>
      </div>
      <div style="overflow:auto;">
        <table class="linked-table">
          <thead>
            <tr>
              <th>ID</th><th>Titre</th><th>Statut</th><th>Date</th>
            </tr>
          </thead>
          <tbody>
            {% for d in type_service.demandeServices %}
            {% set st = d.statut %}
            <tr>
              <td>#{{ d.id }}</td>
              <td style="font-weight:700;">{{ d.titre }}</td>
              <td>
                {% if st == 'Accepté' or st == 'approuvé' %}<span class="pill p-ok">Accepté</span>
                {% elseif st == 'Refusé' or st == 'refusé' %}<span class="pill p-no">Refusé</span>
                {% else %}<span class="pill p-pend">En attente</span>{% endif %}
              </td>
              <td style="color:#64748b;font-weight:700;">{{ d.dateDemande ?: '—' }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% else %}
    <div class="no-linked">
      <i class="fas fa-inbox" style="font-size:2.2rem;color:var(--mv-400);opacity:.7;"></i>
      <div style="font-family:'Outfit';font-weight:900;color:#64748b;margin-top:10px;">Aucune demande liée à ce type.</div>
    </div>
    {% endif %}

    {# ── Actions ── #}
    <div class="page-actions">
      <a href="{{ path('app_type_service_index') }}" class="btn-back">
        <i class="fas fa-arrow-left"></i> Retour
      </a>
      <a href="{{ path('app_type_service_edit', {'id': type_service.id}) }}" class="btn-edit">
        <i class="fas fa-pen"></i> Modifier ce type
      </a>
    </div>
  </div>
</div>
{% endblock %}
