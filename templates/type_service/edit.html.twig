{% extends 'base.html.twig' %}

{% block title %}Modifier le type de service{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root {
  --mv-950:#2e0d52; --mv-800:#5b2b82; --mv-700:#7c3dac;
  --mv-600:#8f4cc9; --mv-500:#b39ddb; --mv-400:#c4b0e4;
  --mv-200:#e9d5ff; --mv-100:#f3e8ff; --mv-50:#faf5ff;
  --mv-glow: rgba(143,76,201,0.4);
}
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

.app {
  font-family:'Inter',sans-serif;
  background: radial-gradient(ellipse at 80% 0%, #f3e8ff 0%, #ffffff 50%, #faf5ff 100%);
  min-height:90vh; padding:44px 20px; color:#0f172a;
  position:relative; overflow:hidden;
}
.app::before {
  content:''; position:fixed; top:-180px; right:-180px;
  width:520px; height:520px; border-radius:50%;
  background: radial-gradient(circle, rgba(143,76,201,.15), transparent 68%);
  pointer-events:none; z-index:0; animation: orbFloat 9s ease-in-out infinite;
}
.app::after {
  content:''; position:fixed; bottom:-100px; left:-100px;
  width:360px; height:360px; border-radius:50%;
  background: radial-gradient(circle, rgba(179,157,219,.12), transparent 68%);
  pointer-events:none; z-index:0; animation: orbFloat2 12s ease-in-out infinite;
}

.wrap { max-width:740px; margin:0 auto; position:relative; z-index:1; animation: slideUp .7s cubic-bezier(.16,1,.3,1) both; }

/* ── Head ── */
.head { display:flex; align-items:center; gap:16px; margin-bottom:26px; }
.ic {
  width:56px; height:56px; border-radius:20px;
  display:flex; align-items:center; justify-content:center; color:#fff;
  background: linear-gradient(135deg, var(--mv-700), var(--mv-600));
  box-shadow:0 12px 28px var(--mv-glow); flex-shrink:0;
  animation: iconPop .6s cubic-bezier(.175,.885,.32,1.275) .2s both;
}
h1 {
  font-family:'Outfit'; font-weight:900; font-size:2.1rem;
  background: linear-gradient(135deg, var(--mv-950), var(--mv-600));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.sub { margin:6px 0 0; color:#64748b; font-weight:600; font-size:.95rem; }

/* ── Warning banner ── */
.warning-banner {
  background: linear-gradient(135deg, #fff7ed, #fffbeb);
  border-left:4px solid #f59e0b; border-radius:16px;
  padding:16px 20px; margin-bottom:24px;
  display:flex; gap:14px; align-items:flex-start;
  color:#92400e; font-size:.93rem; line-height:1.55;
  box-shadow:0 4px 14px rgba(245,158,11,.1);
  animation: slideDown .5s ease-out .3s both;
}
.warning-banner i { color:#f59e0b; font-size:1.1rem; margin-top:2px; flex-shrink:0; }

/* ── Card ── */
.card {
  background:rgba(255,255,255,.85);
  backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
  border:1.5px solid rgba(179,157,219,.25);
  border-radius:26px;
  box-shadow:0 14px 44px rgba(143,76,201,.10);
  padding:34px;
  position:relative; overflow:hidden;
  animation: slideUp .6s cubic-bezier(.16,1,.3,1) .1s both;
}
.card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background: linear-gradient(90deg, var(--mv-700), var(--mv-600), var(--mv-400));
}

.field { display:flex; flex-direction:column; gap:8px; margin-bottom:20px; }
.lbl { font-size:.75rem; font-weight:900; text-transform:uppercase; letter-spacing:.11em; color:#475569; }
.card input, .card select, .card textarea {
  width:100%; border-radius:16px; border:1.5px solid rgba(179,157,219,.3);
  background:var(--mv-50); padding:12px 16px; outline:none; font-family:inherit;
  color:#0f172a; font-size:.97rem;
  transition:border-color .2s, box-shadow .2s, background .2s;
}
.card input:focus, .card select:focus, .card textarea:focus {
  border-color:var(--mv-600); background:#fff;
  box-shadow:0 0 0 4px rgba(143,76,201,.14);
}
textarea { min-height:120px; resize:vertical; }

/* ── Actions ── */
.actions {
  display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap;
  padding-top:22px; border-top:1px solid rgba(179,157,219,.2);
  margin-top:12px; align-items:center;
}
.btn-back {
  display:inline-flex; align-items:center; gap:9px; text-decoration:none;
  padding:12px 20px; border-radius:999px; font-weight:900; color:#64748b;
  border:1.5px solid rgba(179,157,219,.35); background:transparent;
  transition:all .2s; font-family:inherit;
}
.btn-back:hover { background:#fff; color:var(--mv-700); border-color:var(--mv-500); transform:translateX(-2px); }

.btn-submit {
  display:inline-flex; align-items:center; gap:9px; border:0; cursor:pointer;
  padding:13px 26px; border-radius:999px; font-weight:900; color:#fff; font-family:'Outfit';
  background: linear-gradient(135deg, var(--mv-700), var(--mv-600));
  box-shadow:0 12px 28px var(--mv-glow);
  transition:transform .2s, box-shadow .2s;
  position:relative; overflow:hidden;
}
.btn-submit::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg, rgba(255,255,255,.15), transparent);
  opacity:0; transition:opacity .2s;
}
.btn-submit:hover { transform:translateY(-3px); box-shadow:0 18px 36px var(--mv-glow); }
.btn-submit:hover::before { opacity:1; }

.btn-view-link {
  text-decoration:none; font-weight:800; color:#64748b;
  padding:12px 20px; border-radius:999px;
  border:1.5px solid rgba(179,157,219,.3); background:rgba(255,255,255,.8);
  display:inline-flex; align-items:center; gap:8px; transition:.18s;
}
.btn-view-link:hover { background:#fff; color:var(--mv-700); border-color:var(--mv-500); transform:translateY(-1px); }

.del-form { display:inline; }
.btn-del {
  display:inline-flex; align-items:center; gap:9px;
  border:1.5px solid #fecdd3; background:#fff1f2; cursor:pointer;
  padding:12px 20px; border-radius:999px;
  font-weight:900; color:#be123c; font-family:'Outfit';
  transition:all .2s;
}
.btn-del:hover { background:#f43f5e; color:#fff; border-color:#f43f5e; transform:translateY(-2px); box-shadow:0 8px 20px rgba(244,63,94,.22); }

/* ── Modal de confirmation ── */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(46,13,82,.5); backdrop-filter:blur(8px); z-index:9999; align-items:center; justify-content:center; }
.modal-overlay.active { display:flex; }
.modal-box {
  background:#fff; border-radius:26px; padding:36px; max-width:440px; width:92%;
  box-shadow:0 28px 70px rgba(46,13,82,.22);
  animation:modalPop .3s cubic-bezier(.175,.885,.32,1.275);
  border-top:4px solid #f59e0b; position:relative;
}
.modal-box h3 { font-family:'Outfit'; font-weight:900; font-size:1.4rem; margin:0 0 12px; color:#0f172a; }
.modal-box p  { color:#64748b; line-height:1.65; margin:0 0 24px; }
.modal-btns { display:flex; gap:10px; justify-content:flex-end; }
.btn-cancel { padding:11px 20px; border-radius:999px; border:1.5px solid rgba(143,76,201,.25); background:var(--mv-50); font-weight:800; cursor:pointer; color:var(--mv-700); font-family:inherit; transition:all .18s; }
.btn-cancel:hover { background:var(--mv-100); }
.btn-confirm-del { padding:11px 22px; border-radius:999px; border:0; background:linear-gradient(135deg,#f43f5e,#e11d48); color:#fff; font-weight:900; cursor:pointer; font-family:inherit; box-shadow:0 8px 20px rgba(244,63,94,.24); transition:all .2s; }
.btn-confirm-del:hover { transform:translateY(-2px); }

@keyframes slideUp   { from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);} }
@keyframes slideDown { from{opacity:0;transform:translateY(-14px);}to{opacity:1;transform:translateY(0);} }
@keyframes iconPop   { from{opacity:0;transform:scale(.5);}to{opacity:1;transform:scale(1);} }
@keyframes modalPop  { from{opacity:0;transform:scale(.88);}to{opacity:1;transform:scale(1);} }
@keyframes orbFloat  { 0%,100%{transform:translate(0,0);}50%{transform:translate(-25px,18px);} }
@keyframes orbFloat2 { 0%,100%{transform:translate(0,0);}50%{transform:translate(18px,-22px);} }
</style>
{% endblock %}

{% block body %}
<div class="app">
  <div class="wrap">
    <div class="head">
      <div class="ic"><i class="fas fa-pen-to-square"></i></div>
      <div>
        <h1>Modifier le type</h1>
        <div class="sub">Mise à jour de : <strong>{{ type_service.nom }}</strong> ({{ type_service.categorie }})</div>
      </div>
    </div>

    <div class="warning-banner">
      <i class="fas fa-exclamation-triangle"></i>
      <div>
        Attention : si vous supprimez ce type, <strong>toutes les demandes de service liées seront supprimées</strong> (suppression en cascade).
        Modifier le nom ou la catégorie n'affecte pas les demandes existantes.
      </div>
    </div>

    <div class="card">
      {{ include('type_service/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

      <div class="actions">
        <a class="btn-back" href="{{ path('app_type_service_index') }}">
          <i class="fas fa-arrow-left"></i> Retour
        </a>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <a href="{{ path('app_type_service_show', {'id': type_service.id}) }}" class="btn-view-link">
            <i class="fas fa-eye"></i> Voir le détail
          </a>
          <button type="button" onclick="openDelModal()" class="btn-del">
            <i class="fas fa-trash"></i> Supprimer (cascade)
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

{# Formulaire caché de suppression #}
<form id="delConfirmForm" action="{{ path('app_type_service_delete', {'id': type_service.id}) }}" method="post" style="display:none;">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type_service.id) }}">
</form>

{# Modal de confirmation ── #}
<div class="modal-overlay" id="delModal">
  <div class="modal-box">
    <h3><i class="fas fa-exclamation-triangle" style="color:#f59e0b;margin-right:8px;"></i> Confirmer la suppression</h3>
    <p>
      Vous allez supprimer le type <strong>"{{ type_service.nom }}"</strong> et
      <strong>toutes les demandes de service associées</strong>. Cette action est <strong>irréversible</strong>.
    </p>
    <div class="modal-btns">
      <button type="button" class="btn-cancel" onclick="closeDelModal()">Annuler</button>
      <button type="button" class="btn-confirm-del" onclick="document.getElementById('delConfirmForm').submit()">
        <i class="fas fa-trash"></i> Oui, supprimer
      </button>
    </div>
  </div>
</div>

<script>
  function openDelModal()  { document.getElementById('delModal').classList.add('active'); }
  function closeDelModal() { document.getElementById('delModal').classList.remove('active'); }
  document.getElementById('delModal').addEventListener('click', function(e){ if(e.target===this) closeDelModal(); });
</script>
{% endblock %}
