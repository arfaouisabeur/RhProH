###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=your_app_secret_32_chars_here
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

OAUTH_GOOGLE_ID=your_google_oauth_client_id_here
OAUTH_GOOGLE_SECRET=your_google_oauth_client_secret_here
OAUTH_API_KEY=none
GOOGLE_AUTH_CONFIG=%kernel.project_dir%/config/google_service_account.json

###> symfony/routing ###
DEFAULT_URI=http://localhost
LOCAL_IP_OVERRIDE=
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# ╔══════════════════════════════════════════════════════════════════╗
# ║  ✅  SECURITY — Dedicated user configured                       ║
# ║  User 'pidevf_app' has only SELECT/INSERT/UPDATE/DELETE/DDL     ║
# ║  on pidevf database (principle of least privilege).             ║
# ║  Emergency root access (admin only, never in production):       ║
# ║  mysql -u root -e "..."                                         ║
# ╚══════════════════════════════════════════════════════════════════╝
DATABASE_URL="mysql://username:password@127.0.0.1:3306/database_name?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN="smtp://your_email@gmail.com:your_app_password@smtp.gmail.com:587"
MAILER_DSNB="smtp://your_email@gmail.com:your_app_password@smtp.gmail.com:587"
###< symfony/mailer ###

# =========================
# SERVICES
# =========================
GROQ_API_KEY=your_groq_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_NETWORK=eth-sepolia
GEOAPIFY_API_KEY=your_geoapify_api_key_here
NLP_API_URL=http://127.0.0.1:5000

# =========================
# FRIEND SERVICES
# =========================
HUGGINGFACE_TOKEN=your_huggingface_token_here
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# =========================
# NEW SERVICES
# =========================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_phone_number_here

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

OCR_SPACE_API_KEY=your_ocr_space_api_key_here

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###
